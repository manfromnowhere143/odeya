 "defs_comparator": {
  "prose_stripped_keys": [
   "$comment",
   "description",
   "examples",
   "title"
  ],
  "scalar_constraint_keys_blanked": [
   "exclusiveMaximum",
   "exclusiveMinimum",
   "format",
   "maxItems",
   "maxLength",
   "maxProperties",
   "maximum",
   "minItems",
   "minLength",
   "minProperties",
   "minimum",
   "multipleOf",
   "pattern"
  ],
  "set_semantic_keys_sorted": [
   "allOf",
   "anyOf",
   "oneOf",
   "required",
   "type"
  ],
  "vocabulary_keys": [
   "enum",
   "const"
  ],
  "rule": "skeletons mask scalar constraint values, enum contents, and const values; enum lists and const values form the vocabulary. One shared skeleton and one vocabulary is D6; one skeleton with differing vocabularies is D8; differing skeletons is D7. Constraint-keyword presence is treated as structure, the conservative reading; the presence-insensitive triage is recorded so the sensitivity is visible rather than silent",
  "presence_insensitive_triage": null
 },
 "classes": [
  {
   "class_id": "D1",
   "title": "Fixture timestamp normalization",
   "finding_id": "CANON-FIXTURE-TIME-001",
   "selector": "every entry of fixtures[].nonconformant_timestamp_values",
   "count": 0,
   "kind": "mechanical",
   "recommendation": "normalize every value to the frozen UTC microsecond lexical form and regenerate the audit corpus digests; zero schema reissues"
  },
  {
   "class_id": "D2",
   "title": "Datetime profile pinning",
   "finding_id": "CANON-SCHEMA-TIME-001",
   "selector": "every entry of schemas[].unprofiled_datetime_paths",
   "count": 0,
   "kind": "mechanical_after_exemption_pass",
   "recommendation": "pin each path to one shared profiled timestamp definition and reissue; one enumeration pass first for any source-reported external-time exemption"
  },
  {
   "class_id": "D3",
   "title": "Scientific-decimal typed-object migration",
   "finding_id": "CANON-SCHEMA-NUMBER-001",
   "selector": "every entry of schemas[].generic_scientific_decimal_paths",
   "count": 0,
   "kind": "table_driven",
   "recommendation": "migrate each field to the frozen typed scientific-decimal object; the semantic type, unit, and precision per row require operator approval of the embedded table"
  },
  {
   "class_id": "D4",
   "title": "Binary-number domain declaration",
   "finding_id": "CANON-SCHEMA-NUMBER-001",
   "selector": "every entry of schemas[].generic_json_number_paths",
   "count": 0,
   "kind": "single_judgment",
   "recommendation": "declare a frozen bounded-integer domain or migrate to decimal strings; both findings are in research-mission.schema.json"
  },
  {
   "class_id": "D5",
   "title": "Digest scope annotation",
   "finding_id": "CANON-SCHEMA-DIGEST-001",
   "selector": "every schemas[].digest_fields[] entry with scope_annotation_present false",
   "count": 398,
   "kind": "table_driven",
   "recommendation": "annotate each field via shared scoped-digest definitions distinguishing byte digests from canonical object digests; rows proposing a domain beyond the frozen 21 require separate operator judgment and re-freeze the profile core"
  },
  {
   "class_id": "D6",
   "title": "Divergent definitions: constraint-only, converge",
   "finding_id": "CANON-SCHEMA-DEFS-001",
   "selector": "divergent_common_definitions entries whose variants share one structural skeleton and one enum vocabulary under the comparator in defs_comparator",
   "count": 5,
   "kind": "semi_mechanical",
   "recommendation": "converge to one canonical shared definition per name; every narrowing carries a known-bad vector proving the stricter form refuses what the profile intends to refuse"
  },
  {
   "class_id": "D7",
   "title": "Divergent definitions: structural",
   "finding_id": "CANON-SCHEMA-DEFS-001",
   "selector": "divergent_common_definitions entries whose variants differ structurally under the comparator in defs_comparator",
   "count": 46,
   "kind": "per_name_decision",
   "recommendation": "rename-distinct by default; converge-to-superset only where provably safe, decided per name over the retained variant diffs"
  },
  {
   "class_id": "D8",
   "title": "Divergent definitions: enum vocabulary policy",
   "finding_id": "CANON-SCHEMA-DEFS-001",
   "selector": "divergent_common_definitions entries whose variants share one skeleton but differ in enum vocabularies under the comparator in defs_comparator",
   "count": 4,
   "kind": "operator_judgment",
   "recommendation": "closed central vocabularies with declared per-context subsets"
  },
  {
   "class_id": "D9",
   "title": "Profile-binding pinning",
   "finding_id": "CANON-SCHEMA-PROFILE-001",
   "selector": "every schemas[].canonical_profile_bindings entry not pinned",
   "count": 11,
   "kind": "mechanical_strictly_last",
   "recommendation": "pin the exact prospective profile reference members only after the profile core bytes are final; any later core edit invalidates every pin"
  }
 ],
