      "parsing_helpers",
      "normalization_helpers",
      "intermediate_state",
      "expected_result_fixtures",
      "another_implementation_output"
    ],
    "implementation_ids_unique": true,
    "implementation_source_digests_unique": true,
    "exact_toolchain_identity_required": true,
    "exact_dependency_lock_binding_required": true,
    "exact_input_manifest_binding_required": true,
    "complete_direct_output_top_level_field_order": [
      "participant_id",
      "domain_results",
      "categorical_results",
      "categorical_failures",
      "final_disposition",
      "reason_codes"
    ],
    "complete_domain_result_object_field_order": [
