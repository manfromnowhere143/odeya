  "independent_recomputation_contract": {
    "required_result_roles": [
      "python",
      "nodejs_24_18_0",
      "java_21_0_9"
    ],
    "required_toolchain_versions": {
      "python": "3.14.2",
      "nodejs_24_18_0": "24.18.0",
      "java_21_0_9": "21.0.9"
    },
