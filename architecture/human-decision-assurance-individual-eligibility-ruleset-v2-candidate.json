    "object_member_names_unique": true,
    "unknown_members": "refuse",
    "numbers": "base_10_integers_only_where_declared",
    "strings": "exact_unicode_scalar_sequences_without_normalization",
    "arrays": "ordered_and_duplicate_preserving_unless_a_field_rule_requires_uniqueness",
    "content_address_pattern": "^sha256:[0-9a-f]{64}$",
    "identifier_pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)+$",
    "observation_status_domain": [
      "supported",
      "contradicted",
      "unknown",
      "not_applicable"
    ],
    "read_disposition_domain": [
      "readable_complete",
      "missing",
      "unreadable",
      "resolver_failure",
      "denied",
      "truncated_no_complete_candidate"
    ],
    "comparison_disposition_domain": [
      "match",
      "mismatch",
      "not_compared_no_read"
    ],
    "result_disposition_domain": [
      "eligible",
      "indeterminate",
      "invalid"
    ]
  },
  "required_domains": [
