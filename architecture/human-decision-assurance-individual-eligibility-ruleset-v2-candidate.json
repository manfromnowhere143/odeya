    "domain_local_reason_code_comparison_required": true,
    "categorical_local_reason_code_comparison_required": true,
    "lossy_status_vector_projection_allowed": false,
    "java_result_missing_or_unreadable": "indeterminate",
    "any_readable_field_disagreement": "invalid",
    "final_disposition_only_comparison_allowed": false,
    "exact_agreement_is_necessary_not_sufficient": true
  },
  "acyclic_chain_contract": {
