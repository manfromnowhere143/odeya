        "participant_id",
        "domain_results",
        "categorical_results",
        "categorical_failures",
        "final_disposition",
        "reason_codes"
      ],
      "exact_agreement_reason_codes": [
        "eligible.comparison.exact_three_way_full_projection_agreement"
      ],
      "missing_result_code_template": "indeterminate.comparison.{implementation_role}.result_missing",
      "unreadable_result_code_template": "indeterminate.comparison.{implementation_role}.result_unreadable",
      "field_disagreement_code_template": "invalid.comparison.{complete_projection_field}.disagreement",
      "field_disagreement_evaluation": "compare_each_complete_top_level_field_across_all_readable_results_and_emit_disagreement_when_any_two_readable_values_differ",
      "field_missing_or_unreadable_evaluation": "emit_missing_or_unreadable_for_a_field_when_no_readable_pair_disagrees_and_any_required_result_is_missing_or_unreadable",
      "exact_agreement_result": "all_three_results_readable_and_all_six_complete_fields_equal",
      "indeterminate_result_reason_set": "sorted_unique_set_of_every_missing_or_unreadable_result_code_when_no_field_disagrees",
      "invalid_result_reason_set": "sorted_unique_union_of_every_field_disagreement_code_and_every_missing_or_unreadable_result_code",
      "recorded_set_must_equal_recomputed_set": true,
      "status_vector_substitution_permitted": false,
      "final_disposition_only_comparison_permitted": false
    },
    "full_ordered_domain_projection_required": true,
    "full_categorical_projection_required": true,
    "full_reason_code_set_required": true,
    "participant_identity_comparison_required": true,
