    "challenge_consumption_state_fresh_consumed_once",
    "challenge_not_previously_consumed",
    "challenge_consumed_exactly_once",
    "assertion_acceptance_and_consumption_atomic_action_equal",
    "decision_confirmation_principal_matches_observation",
    "decision_confirmation_human_initiated",
    "decision_confirmation_separate_from_authenticator_gesture",
    "same_origin_candidate_context_supported",
    "no_authenticator_clone_risk_signal",
    "no_shared_effective_control_principals",
    "verifier_distinct_principal_and_effective_control"
  ],
  "domain_fold": {
    "input": "one_nonempty_ordered_observation_status_sequence_per_required_evidence_domain",
    "algorithm": [
      "scan_the_complete_sequence_without_short_circuiting_or_overwriting_prior_findings",
      "if_any_status_is_contradicted_emit_that_domain_as_contradicted",
      "otherwise_if_any_status_is_unknown_or_not_applicable_emit_that_domain_as_indeterminate",
      "otherwise_emit_that_domain_as_supported"
    ],
    "empty_or_absent_required_sequence": "indeterminate_missing",
    "contradicted_then_unknown": "contradicted",
    "unknown_then_contradicted": "contradicted",
    "reason_emission": "emit_exactly_the_code_for_the_single_folded_domain_outcome_not_one_code_per_raw_observation",
    "lower_precedence_raw_observation_codes_retained_after_contradiction": false,
    "implementation_private_domains_allowed": false,
    "undeclared_eligibility_bearing_input": "invalid"
  },
  "domain_input_observation_count_contract": {
    "exact_core_and_evidence_binding": "one_compound_binding_observation",
    "backing_byte_integrity": "number_of_present_verification_rows_not_number_of_descriptors",
    "ordinary_public_domain": "number_of_present_items_in_that_public_domain_observation_sequence",
    "sanitation": "sum_of_public_sanitation_observations_sanitization_verification_observations_and_forbidden_content_observations",
    "missing_required_sequence": 0,
    "fabricated_minimum_count_allowed": false
  },
  "backing_byte_integrity_fold": {
    "inventory_must_equal_resolver_profile_closed_role_inventory": true,
    "inventory_validation_precedes_per_role_resolution": true,
    "invalid_inventory_result": "emit_only_invalid.backing_byte.closed_role_inventory_mismatch_for_the_backing_domain",
    "one_total_receipt_row_per_inventory_role": true,
    "duplicate_or_unexpected_role": "invalid",
    "readable_match_and_well_formed": "supported",
    "missing_or_unreadable": "indeterminate",
    "readable_mismatch": "invalid",
    "readable_malformed": "invalid",
    "successful_zero_byte_representation_of_missing_bytes": "invalid",
    "missing_observation_is_never_zero": true,
    "receipt_frame_relation_mismatch": "invalid"
  },
  "categorical_law": {
    "challenge_consumption_state": {
      "satisfied_value": "fresh_consumed_once",
      "unknown_or_absent": "indeterminate",
      "any_other_present_value": "invalid"
    },
    "prior_consumption_count": {
      "satisfied_value": 0,
      "unknown_or_absent": "indeterminate",
      "any_other_nonnegative_integer": "invalid"
    },
    "result_consumption_count": {
      "satisfied_value": 1,
      "unknown_or_absent": "indeterminate",
      "any_other_nonnegative_integer": "invalid"
    },
    "atomic_action": {
      "acceptance_identifier_field": "assertion_acceptance_atomic_action_id",
      "consumption_identifier_field": "consumption_atomic_action_id",
      "identifier_pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)+$",
      "absent_identifier_definition": "json_null_or_missing_member_before_schema_admission",
      "both_identifiers_absent": "indeterminate",
      "either_identifier_absent": "indeterminate",
      "either_identifier_non_string_empty_or_malformed": "invalid",
      "equality_checked_only_after_presence_type_nonempty_and_syntax_checks": true,
      "two_valid_unequal_identifiers": "invalid",
      "two_valid_equal_identifiers": "continue_to_backing_record",
      "atomic_action_record_role_required_value": "sanitized_challenge_lifecycle_and_atomic_consumption_record",
      "atomic_action_record_role_absent_or_unavailable": "indeterminate",
      "atomic_action_record_role_wrong_present_value": "invalid",
      "atomic_action_record_observation_unknown_or_not_applicable": "indeterminate",
      "atomic_action_record_observation_contradicted": "invalid",
      "atomic_action_record_observation_supported_and_identifier_equal": "satisfied",
      "null_equality_establishes_atomicity": false
    },
    "decision_confirmation_principal_id": {
      "satisfied_relation": "exactly_equals_participant_principal_id",
      "present_unequal_identifier": "invalid",
      "null_or_absent": "indeterminate"
    },
    "decision_confirmation_initiator_class": {
      "satisfied_value": "human_initiated",
      "unknown_or_absent": "indeterminate",
      "any_other_present_value": "invalid"
    },
    "decision_confirmation_separate_from_authenticator_gesture": {
      "satisfied_value": true,
      "false": "invalid",
      "unknown_or_absent": "indeterminate"
    },
    "cross_origin_disposition": {
      "satisfied_value": "same_origin_supported",
      "unknown_or_absent": "indeterminate",
      "any_other_present_value": "invalid"
    },
    "signature_counter_disposition": {
      "satisfied_value": "observed_no_clone_conclusion",
      "unknown_or_absent": "indeterminate",
      "any_other_present_value": "invalid"
    },
    "shared_effective_control_principal_ids": {
      "satisfied_value": [],
      "unknown_or_absent": "indeterminate",
      "nonempty_array": "invalid"
    },
    "verifier_relation_to_decision_principal": {
      "satisfied_value": "distinct_principal_and_effective_control",
      "unknown_or_absent": "indeterminate",
      "any_other_present_value": "invalid"
    }
  },
  "sanitation_law": {
    "observation_sequence_uses_domain_fold": true,
    "any_contradicted_observation": "invalid",
    "any_nonempty_forbidden_content_finding": "invalid",
    "missing_unknown_or_not_applicable_without_contradiction": "indeterminate",
    "all_required_observations_supported_and_no_forbidden_content": "supported",
    "contradiction_may_be_collapsed_to_unknown": false,
    "dedicated_contradiction_code": "invalid.sanitation.contradicted",
    "generic_domain_contradiction_code_also_emitted": false
