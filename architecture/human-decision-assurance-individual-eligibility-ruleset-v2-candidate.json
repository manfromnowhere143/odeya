    "resource_identity_version_mismatch": "exact_core_and_evidence_binding_domain",
    "global_reason_set_copies_each_attributed_negative_code": true
  },
  "reason_code_contract": {
    "grammar": "^(eligible|indeterminate|invalid)\\.[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$",
    "character_set": "ascii",
    "sort_order": "ascending_unsigned_utf8_byte_sequence",
    "uniqueness": "set_uniqueness_before_sort",
    "negative_prefixes": [
      "indeterminate.",
      "invalid."
    ],
    "eligible_exact_reason_codes": [
      "eligible.all_required_inputs_supported"
    ],
    "invalid_result_reason_set": "sorted_unique_union_of_every_recomputed_invalid_and_indeterminate_finding",
    "indeterminate_result_reason_set": "sorted_unique_set_of_every_recomputed_indeterminate_finding",
    "positive_code_in_negative_result": "invalid_output",
    "negative_code_in_eligible_result": "invalid_output",
    "stale_unknown_duplicate_unsorted_or_extra_code": "invalid_output",
    "recorded_set_must_equal_recomputed_set": true,
    "dynamic_domain_code_templates": {
      "supported": "eligible.domain.{domain_id}.supported",
      "contradicted": "invalid.domain.{domain_id}.contradicted",
      "missing": "indeterminate.domain.{domain_id}.missing",
      "unknown": "indeterminate.domain.{domain_id}.unknown",
      "not_applicable": "indeterminate.domain.{domain_id}.not_applicable"
    },
    "dynamic_backing_code_templates": {
      "supported": "eligible.domain.backing_byte_integrity.supported",
      "missing": "indeterminate.backing_byte.{role}.missing",
      "unreadable": "indeterminate.backing_byte.{role}.unreadable",
      "mismatch": "invalid.backing_byte.{role}.mismatch",
      "malformed": "invalid.backing_byte.{role}.malformed"
    },
    "categorical_projection_code_templates": {
      "satisfied": "eligible.categorical.{condition_id}.satisfied",
      "failed": "invalid.categorical.{condition_id}.failed",
      "unknown": "indeterminate.categorical.{condition_id}.unknown",
      "not_applicable": "indeterminate.categorical.{condition_id}.not_applicable",
      "global_negative_union_rule": "include_each_non_satisfied_categorical_projection_code_except_atomic_action_uses_the_more_specific_fixed_codes_below",
      "global_eligible_rule": "emit_only_eligible.all_required_inputs_supported_not_the_per_projection_positive_codes"
    },
    "fixed_reason_codes": [
