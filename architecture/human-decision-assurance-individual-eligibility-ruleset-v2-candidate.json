  "supersedes_ruleset_id": "urn:odeya:human-decision-assurance-eligibility:0.1.0-candidate",
  "scope": {
    "principal_act_cardinality": "exactly_one",
    "derives": "individual_participant_eligibility_only",
    "aggregate_quorum_evaluation": "deferred_to_future_assured_decision_wrapper",
    "currentness_evaluation": "deferred_to_future_assured_decision_wrapper",
    "authority_evaluation": "deferred_to_future_assured_decision_wrapper",
    "admission_evaluation": "separate_and_unresolved"
  },
  "normative_data_model": {
