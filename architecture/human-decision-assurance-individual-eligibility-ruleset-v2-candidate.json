  "precedence_and_totality": {
    "ordered_precedence": [
      "invalid",
      "indeterminate",
      "eligible"
    ],
    "invalid": "any_explicit_contradiction_readable_mismatch_readable_malformed_failed_categorical_condition_forbidden_content_finding_or_readable_independent_result_disagreement",
    "indeterminate": "no_invalid_finding_and_any_absent_missing_unreadable_unknown_or_not_applicable_required_input",
    "eligible": "every_required_domain_supported_every_categorical_condition_satisfied_no_negative_integrity_finding_and_complete_independent_agreement",
    "later_inputs_may_weaken_an_earlier_finding": false,
    "evaluation_is_total_over_every_declared_input": true,
