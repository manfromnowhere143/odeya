    {
      "name": "construction-order-rejects-reordered-seal-before-evidence",
      "kind": "adversarial",
      "adversarial_tag": "construction_phase_reordered",
      "model": "construction_order",
      "fixture": "tests/constitutional-construction/fixtures/construction-order.valid.json",
      "expect": "reject",
      "mutations": [
        {
          "op": "replace",
          "path": "/phase_order",
          "value": [
            "canonicalize_core_projection",
            "compute_core_digest",
            "assemble_seal_subject_from_unchanged_core_and_ordered_evidence_refs",
            "produce_evidence_over_core_digest",
            "compute_seal_digest",
            "produce_external_attestations_over_seal_digest"
          ]
        }
      ],
      "expected_refusal_contains": "phase order is not core -> core digest -> evidence -> seal -> seal digest -> attestation"
    },
