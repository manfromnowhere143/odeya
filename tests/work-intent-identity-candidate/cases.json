{
  "suite_version": "0.1.0",
  "description": "Bounded safe and adversarial checks for the nonrecursive WorkIntent semantic-core and external identity-candidate evidence construction.",
  "cases": [
    {
      "name": "exact-nonrecursive-candidate-is-safe-but-unissued",
      "kind": "safe",
      "expected_errors": [],
      "mutations": []
    },
    {
      "name": "core-rejects-canonical-self-digest",
      "kind": "adversarial",
      "expected_errors": [
        "core_contains_identity_binding",
        "core_raw_binding_mismatch",
        "core_schema_invalid",
        "legacy_projection_mismatch"
      ],
      "mutations": [
        {
          "target": "core",
          "op": "add",
          "path": "/canonical_digest",
          "value": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        }
      ],
      "intent_errors": [
        "core_contains_identity_binding"
      ]
    },
