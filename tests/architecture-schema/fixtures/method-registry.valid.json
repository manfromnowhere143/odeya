    {
      "method_id": "method.paired-stratified-bootstrap",
      "version": "0.1.0",
      "status": "proposed",
      "method_class": "paired_agent_evaluation",
      "scientific_domains": [
        "agent-evaluation",
        "simulation"
      ],
      "supported_claim_types": [
        "bounded-comparative-performance"
      ],
      "supported_data_types": [
        "paired-episode-outcomes"
      ],
      "formal_guarantee": {
        "guarantee_kind": "empirical_only",
        "statement": "Produces a prespecified paired, task-stratified bootstrap interval for the selected estimand under the frozen resampling procedure.",
        "scope": "The retained Sentinel simulation task distribution and declared primary metric only.",
        "assumption_dependency": true,
        "non_guarantees": [
          "Does not establish transport to HUGSIM or the physical world.",
          "Does not establish safety, causality, or general agent superiority."
        ]
      },
      "assumptions": [
        {
          "assumption_id": "paired-identities-correct",
          "statement": "Each comparison preserves the planned baseline/candidate episode pairing and task stratum.",
          "checkability": "enforced",
          "violation_consequence": "invalid"
        },
        {
          "assumption_id": "planned-exclusions-only",
          "statement": "Episode inclusion and exclusion follow the prospectively frozen protocol.",
          "checkability": "externally_reviewed",
          "violation_consequence": "invalid"
        }
      ],
      "required_inputs": [
        {
          "input_id": "paired-episode-table",
          "schema_id": "urn:odeya:data:paired-episode-table",
          "schema_version_range": ">=0.1.0 <0.2.0",
          "required": true
        },
        {
          "input_id": "resampling-plan",
          "schema_id": "urn:odeya:data:resampling-plan",
          "schema_version_range": ">=0.1.0 <0.2.0",
          "required": true
        }
      ],
      "incompatible_operations": [
        "post-hoc metric substitution",
        "dropping failed episodes without the frozen missingness rule",
        "interpreting an interval crossing zero as equivalence"
      ],
      "diagnostics": [
        "pair-completeness",
        "stratum-counts",
        "seed-replay"
      ],
      "sensitivity_analyses": [
        "task-cluster-resampling",
        "missing-episode-worst-case"
      ],
