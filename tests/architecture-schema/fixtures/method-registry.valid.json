          "semantic_type": "interval_confidence_level",
          "unit": "dimensionless",
          "precision": "6"
        },
        "simultaneity": "pointwise",
        "stopping_rule": "fixed_in_advance",
        "interpretation": "A fixed-procedure bootstrap interval for the frozen paired estimand; it is not a posterior probability or equivalence region."
      },
