{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:conformance-collections:0.1.0",
  "title": "Fixture-only ordered and normalized-set subject",
  "type": "object",
  "additionalProperties": false,
  "required": ["sequence", "tags"],
  "properties": {
    "sequence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
