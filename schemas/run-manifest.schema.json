{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:run-manifest:0.9.0",
  "title": "Odeya RunManifest",
  "description": "An immutable, authorized compilation of one execution attempt family. It binds inputs, code, environment, tools, budgets, controls, and expected outputs; it is not proof that a run occurred or was valid.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_manifest_id",
    "version",
    "mission_id",
    "protocol_snapshot",
    "stage_id",
    "run_class",
    "source_run_manifest",
    "independence_profile_ref",
    "inputs",
    "execution",
    "evaluator_bindings",
    "expected_outputs",
    "known_bad_controls",
    "preflight_validation_results",
    "authority_grant_refs",
    "recovery",
    "canonical_payload_digest",
    "sealed_at_ledger_position",
    "sealed_at",
    "sealed_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.9.0"
    },
    "run_manifest_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mission_id": {
      "$ref": "#/$defs/identifier"
    },
    "protocol_snapshot": {
      "$ref": "#/$defs/protocol_reference"
    },
    "stage_id": {
      "$ref": "#/$defs/identifier"
    },
    "run_class": {
      "enum": [
        "producer",
        "verification",
        "replication"
      ]
    },
    "source_run_manifest": {
      "oneOf": [
        {
          "$ref": "#/$defs/manifest_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "independence_profile_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "artifact",
          "exposure_class"
        ],
        "properties": {
          "role": {
            "enum": [
              "source",
              "dataset",
              "split",
              "configuration",
              "sealed_truth",
              "fixture",
              "prior_output"
            ]
          },
          "artifact": {
            "$ref": "#/$defs/artifact_reference"
          },
          "exposure_class": {
            "enum": [
              "model_visible",
              "worker_visible",
              "verifier_only",
              "sealed"
            ]
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint",
        "code_ref",
        "environment_ref",
        "harness_ref",
        "model_bindings",
        "tool_bindings",
        "randomness_policy",
        "seed_set",
        "sandbox_profile_ref",
        "network_profile_ref",
        "resource_request"
      ],
      "properties": {
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "code_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "environment_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "harness_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "model_bindings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "role",
              "model_id",
              "version",
              "context_policy_ref"
            ],
            "properties": {
              "role": {
                "$ref": "#/$defs/identifier"
              },
              "model_id": {
                "$ref": "#/$defs/identifier"
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "context_policy_ref": {
                "$ref": "#/$defs/artifact_reference"
              },
              "weights_digest": {
                "$ref": "#/$defs/digest",
                "x-odeya-digest-scope": {
                  "kind": "byte_digest",
                  "subject": "exact model weights bytes",
                  "algorithm": "sha-256",
                  "profile": "not_a_canonical_object_digest",
                  "status": "accepted_construction_decision"
                }
              },
              "endpoint_descriptor_digest": {
                "$ref": "#/$defs/digest",
                "x-odeya-digest-scope": {
                  "kind": "byte_digest",
                  "subject": "serialized provider endpoint descriptor bytes",
                  "algorithm": "sha-256",
                  "profile": "not_a_canonical_object_digest",
                  "status": "accepted_construction_decision"
                }
              }
            },
            "oneOf": [
              {
                "required": [
                  "weights_digest"
                ]
              },
              {
                "required": [
                  "endpoint_descriptor_digest"
                ]
              }
            ]
          }
        },
        "tool_bindings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool_id",
              "version",
              "interface_digest"
            ],
            "properties": {
              "tool_id": {
                "$ref": "#/$defs/identifier"
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "interface_digest": {
                "$ref": "#/$defs/digest",
                "x-odeya-digest-scope": {
                  "kind": "canonical_object_digest",
                  "domain": "odeya-tool-interface-descriptor-v1",
                  "algorithm": "sha-256",
                  "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
                  "status": "prospective_domain_reserved_not_declared"
                }
              }
            }
          }
        },
        "randomness_policy": {
          "enum": [
            "deterministic_seeded",
            "recorded_external_nondeterminism",
            "not_applicable"
          ]
        },
        "seed_set": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "sandbox_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "network_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "resource_request": {
          "$ref": "#/$defs/run_manifest_resource_budget"
        }
      }
    },
    "evaluator_bindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/method_reference"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "output_id",
          "role",
          "media_type",
          "schema_id",
          "required"
        ],
        "properties": {
          "output_id": {
            "$ref": "#/$defs/identifier"
          },
          "role": {
            "enum": [
              "raw_observation",
              "derived_data",
              "metric_result",
              "falsifier_result",
              "log",
              "checkpoint",
              "report"
            ]
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "schema_id": {
            "oneOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "null"
              }
            ]
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "known_bad_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "fixture",
          "evaluator_id",
          "expected_verdict"
        ],
        "properties": {
          "control_id": {
            "$ref": "#/$defs/identifier"
          },
          "fixture": {
            "$ref": "#/$defs/artifact_reference"
          },
          "evaluator_id": {
            "$ref": "#/$defs/identifier"
          },
          "expected_verdict": {
            "const": "reject"
          }
        }
      }
    },
    "preflight_validation_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "validation_result_id",
          "digest",
          "disposition"
        ],
        "properties": {
          "validation_result_id": {
            "$ref": "#/$defs/identifier"
          },
          "digest": {
            "$ref": "#/$defs/digest",
            "x-odeya-digest-scope": {
              "kind": "canonical_object_digest",
              "domain_resolution": "target_resolved_via_sibling_reference",
              "algorithm": "sha-256",
              "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
              "status": "target_resolved_domain"
            }
          },
          "disposition": {
            "const": "pass"
          }
        }
      }
    },
    "authority_grant_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_policy_ref",
        "idempotency_scope",
        "resume_strategy"
      ],
      "properties": {
        "checkpoint_policy_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "idempotency_scope": {
          "$ref": "#/$defs/identifier"
        },
        "resume_strategy": {
          "enum": [
            "resume_from_verified_checkpoint",
            "restart_attempt",
            "no_resume"
          ]
        }
      }
    },
    "canonical_payload_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-run-manifest-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "sealed_at_ledger_position": {
      "type": "integer",
      "minimum": 0
    },
    "sealed_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "sealed_by": {
      "$ref": "#/$defs/run_manifest_principal"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "run_class": {
            "const": "producer"
          }
        },
        "required": [
          "run_class"
        ]
      },
      "then": {
        "properties": {
          "source_run_manifest": {
            "type": "null"
          },
          "independence_profile_ref": {
            "type": "null"
          }
        }
      },
      "else": {
        "properties": {
          "source_run_manifest": {
            "$ref": "#/$defs/manifest_reference"
          },
          "independence_profile_ref": {
            "$ref": "#/$defs/artifact_reference"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution": {
            "properties": {
              "randomness_policy": {
                "const": "deterministic_seeded"
              }
            },
            "required": [
              "randomness_policy"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "execution": {
            "properties": {
              "seed_set": {
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocol_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_snapshot_id",
        "version",
        "digest"
      ],
      "properties": {
        "protocol_snapshot_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-protocol-snapshot-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "manifest_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_manifest_id",
        "version",
        "digest"
      ],
      "properties": {
        "run_manifest_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "method_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "version",
        "registry_digest"
      ],
      "properties": {
        "method_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "registry_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-method-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "run_manifest_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type",
        "authority_grant_ref"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service"
          ]
        },
        "authority_grant_ref": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "run_manifest_resource_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_seconds",
        "model_tokens",
        "cpu_seconds",
        "memory_gib_seconds",
        "accelerator_seconds",
        "storage_bytes",
        "network_bytes",
        "external_cost_usd",
        "human_hours"
      ],
      "properties": {
        "wall_time_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "duration_seconds"
            },
            "unit": {
              "const": "seconds"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "model_tokens": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "resource_amount"
            },
            "unit": {
              "const": "tokens"
            },
            "precision": {
              "const": "0"
            }
          }
        },
        "cpu_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "duration_seconds"
            },
            "unit": {
              "const": "seconds"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "memory_gib_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "memory_gib_seconds"
            },
            "unit": {
              "const": "GiB*s"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "accelerator_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "duration_seconds"
            },
            "unit": {
              "const": "seconds"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "storage_bytes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "byte_count"
            },
            "unit": {
              "const": "bytes"
            },
            "precision": {
              "const": "0"
            }
          }
        },
        "network_bytes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "byte_count"
            },
            "unit": {
              "const": "bytes"
            },
            "precision": {
              "const": "0"
            }
          }
        },
        "external_cost_usd": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "monetary_amount_usd"
            },
            "unit": {
              "const": "USD"
            },
            "precision": {
              "type": "string",
              "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
            }
          }
        },
        "human_hours": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "human_effort_hours"
            },
            "unit": {
              "const": "hours"
            },
            "precision": {
              "const": "2"
            }
          }
        }
      }
    }
  }
}
