{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:artifact-custody-observation:0.2.0",
  "title": "Odeya ArtifactCustodyObservation",
  "description": "An immutable observation in an artifact custody chain. It records an action and evidence without rewriting the ArtifactManifest. Chain order, grant scope, and digest recomputation are semantic checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "observation_id",
    "mission_id",
    "artifact",
    "action",
    "storage_binding",
    "integrity_check",
    "rights_decision_ref",
    "authority_grant_ref",
    "reason_codes",
    "evidence_refs",
    "previous_observation",
    "observed_at",
    "recorded_at_ledger_position",
    "recorded_at",
    "recorded_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "observation_id": {
      "$ref": "#/$defs/identifier"
    },
    "mission_id": {
      "oneOf": [
        {
          "$ref": "#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifact": {
      "$ref": "#/$defs/artifact_reference"
    },
    "action": {
      "enum": [
        "staged",
        "integrity_verified",
        "promoted",
        "quarantined",
        "accessed",
        "copied",
        "released",
        "destroyed",
        "retention_extended"
      ]
    },
    "storage_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "store_id",
        "object_key"
      ],
      "properties": {
        "store_id": {
          "$ref": "#/$defs/identifier"
        },
        "object_key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "integrity_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_digest",
        "observed_digest",
        "verdict",
        "method_ref"
      ],
      "properties": {
        "expected_digest": {
          "$ref": "#/$defs/digest"
        },
        "observed_digest": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "verdict": {
          "enum": [
            "pass",
            "fail",
            "indeterminate",
            "not_performed"
          ]
        },
        "method_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/method_reference"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "rights_decision_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_grant_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "reason_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "previous_observation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "observation_id",
            "digest"
          ],
          "properties": {
            "observation_id": {
              "$ref": "#/$defs/identifier"
            },
            "digest": {
              "$ref": "#/$defs/digest"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "recorded_at_ledger_position": {
      "type": "integer",
      "minimum": 0
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "recorded_by": {
      "$ref": "#/$defs/execution_identity"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "integrity_verified",
              "promoted"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "integrity_check": {
            "properties": {
              "observed_digest": {
                "$ref": "#/$defs/digest"
              },
              "verdict": {
                "const": "pass"
              },
              "method_ref": {
                "$ref": "#/$defs/method_reference"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "promoted"
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "rights_decision_ref": {
            "$ref": "#/$defs/identifier"
          },
          "authority_grant_ref": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "quarantined",
              "destroyed"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "reason_codes": {
            "minItems": 1
          },
          "evidence_refs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "method_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "version",
        "registry_digest"
      ],
      "properties": {
        "method_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "registry_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "execution_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "execution_id",
        "code_digest",
        "environment_digest"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "execution_id": {
          "$ref": "#/$defs/identifier"
        },
        "code_digest": {
          "$ref": "#/$defs/digest"
        },
        "environment_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    }
  }
}
