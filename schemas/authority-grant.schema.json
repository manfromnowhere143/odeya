{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:authority-grant:0.5.0",
  "title": "Odeya AuthorityGrant",
  "description": "An immutable, bounded permission with an explicit action boundary, consumption point, and reservation policy. Status is derived from issue, reservation, use, expiry, release, and revocation events; JSON Schema does not prove their race order.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "version",
    "mission_id",
    "role",
    "issuer_assignment_ref",
    "subject",
    "scope",
    "limits",
    "replay",
    "consumption",
    "dependencies",
    "delegation",
    "decision_evidence",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5.0"
    },
    "grant_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mission_id": {
      "$ref": "#/$defs/identifier"
    },
    "role": {
      "enum": [
        "proposal",
        "protocol",
        "safety",
        "data_rights",
        "resource",
        "execution",
        "verification",
        "outcome",
        "publication"
      ]
    },
    "issuer_assignment_ref": {
      "$ref": "#/$defs/digest"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type",
        "execution_identity_selector",
        "authentication_binding_ref"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "organization",
            "model_run",
            "tool",
            "instrument"
          ]
        },
        "execution_identity_selector": {
          "type": "string",
          "minLength": 1
        },
        "authentication_binding_ref": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_types",
        "capability_ids",
        "action_classes",
        "resource_selectors",
        "protocol_digest",
        "run_manifest_digest",
        "stage_id",
        "purpose",
        "maximum_risk_tier",
        "data_classes",
        "publication_manifest_digest"
      ],
      "properties": {
        "command_types": {
          "$ref": "#/$defs/nonempty_unique_strings"
        },
        "capability_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "action_classes": {
          "$ref": "#/$defs/nonempty_unique_strings"
        },
        "resource_selectors": {
          "$ref": "#/$defs/nonempty_unique_strings"
        },
        "protocol_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-protocol-snapshot-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "run_manifest_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-run-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "stage_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "purpose": {
          "type": "string",
          "minLength": 3
        },
        "maximum_risk_tier": {
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3",
            "R4"
          ]
        },
        "data_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "publication_manifest_digest": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ],
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-publication-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "external_effect_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not_before",
        "expires_at",
        "max_uses",
        "max_concurrency",
        "resource_budget",
        "spend_limit_usd",
        "egress_allowlist",
        "allowed_methods",
        "sandbox_tier"
      ],
      "properties": {
        "not_before": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
        },
        "max_uses": {
          "type": "integer",
          "minimum": 1
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "resource_budget": {
          "$ref": "#/$defs/resource_budget"
        },
        "spend_limit_usd": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "monetary_amount_usd"
            },
            "unit": {
              "const": "USD"
            },
            "precision": {
              "type": "string",
              "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
            }
          }
        },
        "egress_allowlist": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_methods": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "sandbox_tier": {
          "enum": [
            "trusted_fixture",
            "hardened_container",
            "kernel_isolated",
            "microvm",
            "external_controlled_system"
          ]
        }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "idempotency_scope"
      ],
      "properties": {
        "mode": {
          "enum": [
            "single_use",
            "bounded_use",
            "reusable"
          ]
        },
        "idempotency_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "consumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_boundary",
        "consumption_point",
        "reservation_policy",
        "reservation_identity_fields",
        "maximum_open_reservations",
        "reservation_ttl_seconds",
        "pre_consumption_rechecks",
        "unused_reservation_release",
        "consumed_reservation_release"
      ],
      "properties": {
        "action_boundary": {
          "enum": [
            "in_ledger",
            "cross_boundary_effect"
          ]
        },
        "consumption_point": {
          "enum": [
            "domain_commit",
            "dispatch_claim"
          ]
        },
        "reservation_policy": {
          "enum": [
            "atomic_reserve_and_consume",
            "exact_t1_reservation"
          ]
        },
        "reservation_identity_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "grant_id",
              "command_id",
              "effect_id",
              "authorization_request_digest",
              "publication_manifest_digest"
            ]
          }
        },
        "maximum_open_reservations": {
          "type": "integer",
          "minimum": 0
        },
        "reservation_ttl_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "pre_consumption_rechecks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "active_assignment",
              "grant_not_revoked",
              "controlled_time_before_expiry",
              "prior_use_absent",
              "exact_scope_match"
            ]
          }
        },
        "unused_reservation_release": {
          "enum": [
            "not_applicable_atomic_commit",
            "release_on_revoke_expiry_cancellation_before_claim"
          ]
        },
        "consumed_reservation_release": {
          "const": "forbidden"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_grant_refs",
        "authorization_request_digest",
        "quorum",
        "distinct_principals",
        "forbidden_role_overlap"
      ],
      "properties": {
        "required_grant_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "authorization_request_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-request-v2",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "quorum": {
          "type": "integer",
          "minimum": 1
        },
        "distinct_principals": {
          "type": "boolean"
        },
        "forbidden_role_overlap": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "proposal",
              "protocol",
              "safety",
              "data_rights",
              "resource",
              "execution",
              "verification",
              "outcome",
              "publication"
            ]
          }
        }
      }
    },
    "delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "maximum_depth",
        "child_scope_rule"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "maximum_depth": {
          "type": "integer",
          "minimum": 0
        },
        "child_scope_rule": {
          "enum": [
            "none",
            "strict_subset"
          ]
        }
      }
    },
    "decision_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_decision_id",
        "policy_bundle_digest",
        "policy_input_digest",
        "approval_refs",
        "issued_by"
      ],
      "properties": {
        "policy_decision_id": {
          "$ref": "#/$defs/identifier"
        },
        "policy_bundle_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-policy-bundle-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "policy_input_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-policy-input-binding-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "approval_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "issued_by": {
          "$ref": "#/$defs/principal"
        }
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "role": {
            "const": "publication"
          }
        },
        "required": [
          "role"
        ]
      },
      "then": {
        "properties": {
          "scope": {
            "required": [
              "external_effect_id"
            ],
            "properties": {
              "publication_manifest_digest": {
                "$ref": "#/$defs/digest",
                "x-odeya-digest-scope": {
                  "kind": "canonical_object_digest",
                  "domain": "odeya-publication-manifest-v1",
                  "algorithm": "sha-256",
                  "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
                  "status": "prospective_domain_reserved_not_declared"
                }
              },
              "external_effect_id": {
                "$ref": "#/$defs/identifier"
              }
            }
          },
          "decision_evidence": {
            "properties": {
              "issued_by": {
                "properties": {
                  "principal_type": {
                    "const": "human"
                  }
                }
              }
            }
          },
          "replay": {
            "properties": {
              "mode": {
                "const": "single_use"
              }
            }
          },
          "limits": {
            "properties": {
              "max_uses": {
                "const": 1
              },
              "max_concurrency": {
                "const": 1
              }
            }
          },
          "delegation": {
            "properties": {
              "allowed": {
                "const": false
              },
              "maximum_depth": {
                "const": 0
              },
              "child_scope_rule": {
                "const": "none"
              }
            }
          },
          "consumption": {
            "properties": {
              "action_boundary": {
                "const": "cross_boundary_effect"
              },
              "consumption_point": {
                "const": "dispatch_claim"
              },
              "reservation_policy": {
                "const": "exact_t1_reservation"
              },
              "reservation_identity_fields": {
                "const": [
                  "grant_id",
                  "effect_id",
                  "authorization_request_digest",
                  "publication_manifest_digest"
                ]
              },
              "maximum_open_reservations": {
                "const": 1
              },
              "reservation_ttl_seconds": {
                "minimum": 1
              },
              "pre_consumption_rechecks": {
                "const": [
                  "active_assignment",
                  "grant_not_revoked",
                  "controlled_time_before_expiry",
                  "prior_use_absent",
                  "exact_scope_match"
                ]
              },
              "unused_reservation_release": {
                "const": "release_on_revoke_expiry_cancellation_before_claim"
              },
              "consumed_reservation_release": {
                "const": "forbidden"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "consumption": {
            "properties": {
              "action_boundary": {
                "const": "cross_boundary_effect"
              }
            },
            "required": [
              "action_boundary"
            ]
          }
        },
        "required": [
          "consumption"
        ]
      },
      "then": {
        "properties": {
          "consumption": {
            "properties": {
              "consumption_point": {
                "const": "dispatch_claim"
              },
              "reservation_policy": {
                "const": "exact_t1_reservation"
              },
              "reservation_identity_fields": {
                "minItems": 3,
                "allOf": [
                  {
                    "contains": {
                      "const": "grant_id"
                    }
                  },
                  {
                    "contains": {
                      "const": "effect_id"
                    }
                  },
                  {
                    "contains": {
                      "const": "authorization_request_digest"
                    }
                  }
                ]
              },
              "maximum_open_reservations": {
                "minimum": 1
              },
              "reservation_ttl_seconds": {
                "minimum": 1
              },
              "pre_consumption_rechecks": {
                "const": [
                  "active_assignment",
                  "grant_not_revoked",
                  "controlled_time_before_expiry",
                  "prior_use_absent",
                  "exact_scope_match"
                ]
              },
              "unused_reservation_release": {
                "const": "release_on_revoke_expiry_cancellation_before_claim"
              },
              "consumed_reservation_release": {
                "const": "forbidden"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "consumption": {
            "properties": {
              "consumption_point": {
                "const": "domain_commit"
              },
              "reservation_policy": {
                "const": "atomic_reserve_and_consume"
              },
              "reservation_identity_fields": {
                "const": [
                  "grant_id",
                  "command_id",
                  "authorization_request_digest"
                ]
              },
              "maximum_open_reservations": {
                "const": 0
              },
              "reservation_ttl_seconds": {
                "const": 0
              },
              "pre_consumption_rechecks": {
                "const": [
                  "active_assignment",
                  "grant_not_revoked",
                  "controlled_time_before_expiry",
                  "prior_use_absent",
                  "exact_scope_match"
                ]
              },
              "unused_reservation_release": {
                "const": "not_applicable_atomic_commit"
              },
              "consumed_reservation_release": {
                "const": "forbidden"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "nonnegative_decimal": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    },
    "nonempty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "organization"
          ]
        }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resource_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_seconds",
        "model_tokens",
        "cpu_seconds",
        "memory_gib_seconds",
        "accelerator_seconds",
        "storage_bytes",
        "network_bytes",
        "human_hours"
      ],
      "properties": {
        "wall_time_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "duration_seconds"
            },
            "unit": {
              "const": "seconds"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "model_tokens": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "resource_amount"
            },
            "unit": {
              "const": "tokens"
            },
            "precision": {
              "const": "0"
            }
          }
        },
        "cpu_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "duration_seconds"
            },
            "unit": {
              "const": "seconds"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "memory_gib_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "memory_gib_seconds"
            },
            "unit": {
              "const": "GiB*s"
            },
            "precision": {
              "const": "6"
            }
          }
        },
        "accelerator_seconds": {
          "type": "object",
          "additionalProperties": false,
