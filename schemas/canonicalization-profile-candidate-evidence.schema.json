{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:canonicalization-profile-candidate-evidence:0.3.0",
  "title": "Odeya Canonicalization Profile Candidate Evidence",
  "description": "External nonrecursive binding of exact canonicalization-profile core bytes to bounded conformance and migration evidence. It is architecture evidence only and cannot issue a canonical profile or authorize Gate A, runtime, deployment, or effects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_class",
    "candidate_status",
    "frozen_at",
    "profile_core_binding",
    "conformance_evidence",
    "declared_domain_inventory",
    "migration_snapshot",
    "acceptance_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "artifact_class": {
      "const": "canonicalization_profile_candidate_evidence"
    },
    "candidate_status": {
      "const": "candidate_parameters_frozen_profile_unissued_gate_a_blocked"
    },
    "frozen_at": {
      "$ref": "#/$defs/candidate_evidence_timestamp"
    },
    "profile_core_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "profile_core_path",
        "profile_core_schema_path",
        "profile_core_schema_id",
        "profile_core_raw_digest",
        "profile_core_bytes",
        "profile_core_schema_raw_digest",
        "profile_core_schema_bytes",
        "core_contains_self_hash",
        "binding_is_external_to_core"
      ],
      "properties": {
        "profile_id": {
          "const": "urn:odeya:canonicalization:odeya-jcs-0.1"
        },
        "profile_version": {
          "const": "0.1.0"
        },
        "profile_core_path": {
          "const": "architecture/canonicalization-profile-core-candidate.json"
        },
        "profile_core_schema_path": {
          "const": "schemas/canonicalization-profile-core.schema.json"
        },
        "profile_core_schema_id": {
          "const": "urn:odeya:schema:canonicalization-profile-core:0.3.0"
        },
        "profile_core_raw_digest": {
          "$ref": "#/$defs/candidate_evidence_raw_digest"
        },
        "profile_core_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "profile_core_schema_raw_digest": {
          "$ref": "#/$defs/candidate_evidence_raw_digest"
        },
        "profile_core_schema_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "core_contains_self_hash": {
          "const": false
        },
        "binding_is_external_to_core": {
          "const": true
        }
      }
    },
    "conformance_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_id",
        "profile_id",
        "evidence_label",
        "case_count",
        "accepted_count",
        "refused_count",
        "unclassified_error_count",
        "metamorphic_relation_count",
        "implementation_paths",
        "implementation_agreement",
        "organizational_independence_proven",
        "independent_host_reproduction_complete",
        "networkless_replay_contract_documented",
        "artifacts"
      ],
      "properties": {
        "suite_id": {
          "const": "urn:odeya:conformance:canonical-identity:0.1.0"
        },
        "profile_id": {
          "const": "urn:odeya:canonicalization:odeya-jcs-0.1"
        },
        "evidence_label": {
          "const": "gate-a-candidate-2026-07-15"
        },
        "case_count": {
          "const": 64
        },
        "accepted_count": {
          "const": 19
        },
        "refused_count": {
          "const": 45
        },
        "unclassified_error_count": {
          "const": 0
        },
        "metamorphic_relation_count": {
          "const": 4
        },
        "implementation_paths": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "const": "python_rfc8785_0.1.4"
            },
            {
              "const": "node_canonicalize_3.0.0"
            }
          ],
          "items": false
        },
        "implementation_agreement": {
          "const": true
        },
        "organizational_independence_proven": {
          "const": false
        },
        "independent_host_reproduction_complete": {
          "const": false
        },
        "networkless_replay_contract_documented": {
          "const": true
        },
        "artifacts": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "$ref": "#/$defs/candidate_evidence_artifact_binding"
          }
        }
      }
    },
    "declared_domain_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_glob",
        "declared_domain_count",
        "domain_constants_unique",
        "profile_core_matches_current_schema_constants",
        "current_consumers_admitted"
      ],
      "properties": {
        "schema_glob": {
          "const": "schemas/*.json"
        },
        "declared_domain_count": {
          "const": 21
        },
        "domain_constants_unique": {
          "const": true
        },
        "profile_core_matches_current_schema_constants": {
          "const": true
        },
        "current_consumers_admitted": {
          "const": false
        }
      }
    },
    "migration_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_ref",
        "audit_raw_digest",
        "audit_gate_a_disposition",
        "schema_count",
        "fixture_count",
        "unprofiled_datetime_paths",
        "number_or_decimal_findings",
        "unscoped_digest_fields",
        "divergent_common_definition_names",
        "unpinned_profile_bindings",
        "nonconformant_fixture_timestamps",
        "candidate_profile_parameters_frozen_for_review",
        "candidate_digest_framing_frozen_for_review",
        "candidate_profile_reference_shape_frozen_for_review",
        "current_consumer_migration_complete",
        "all_blocking_findings_resolved_or_versioned",
        "profile_final_acceptance_complete"
      ],
      "properties": {
        "audit_ref": {
          "const": "tests/canonicalization/SCHEMA_AUDIT.json"
        },
        "audit_raw_digest": {
          "$ref": "#/$defs/candidate_evidence_raw_digest"
        },
        "audit_gate_a_disposition": {
          "const": "blocked"
        },
        "schema_count": {
          "type": "integer",
          "minimum": 1
        },
        "fixture_count": {
          "type": "integer",
          "minimum": 1
        },
        "unprofiled_datetime_paths": {
          "type": "integer",
          "minimum": 0
        },
        "number_or_decimal_findings": {
          "type": "integer",
          "minimum": 0
        },
        "unscoped_digest_fields": {
          "type": "integer",
          "minimum": 0
        },
        "divergent_common_definition_names": {
          "type": "integer",
          "minimum": 0
        },
        "unpinned_profile_bindings": {
          "type": "integer",
          "minimum": 0
        },
        "nonconformant_fixture_timestamps": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_profile_parameters_frozen_for_review": {
          "const": true
        },
        "candidate_digest_framing_frozen_for_review": {
          "const": true
        },
        "candidate_profile_reference_shape_frozen_for_review": {
          "const": true
        },
        "current_consumer_migration_complete": {
          "const": false
        },
        "all_blocking_findings_resolved_or_versioned": {
          "const": false
        },
        "profile_final_acceptance_complete": {
          "const": false
        }
      }
    },
    "acceptance_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_core_canonical_digest",
        "operator_acceptance_ref",
        "canonical_profile_registry_member_ref",
        "engine_contract_root_ref",
        "canonical_identity_may_be_issued",
        "gate_a_complete",
        "runtime_authorized",
        "deployment_authorized",
        "external_effects_authorized",
        "publication_authorized"
      ],
      "properties": {
        "profile_core_canonical_digest": {
          "type": "null",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "subject": "canonicalization_profile_core_candidate",
            "profile": "unissued",
            "schema": "urn:odeya:schema:canonicalization-profile-core:0.3.0",
            "algorithm": "sha-256",
            "status": "not_constructible"
          }
        },
        "operator_acceptance_ref": {
          "type": "null"
        },
        "canonical_profile_registry_member_ref": {
          "type": "null"
        },
        "engine_contract_root_ref": {
          "type": "null"
        },
        "canonical_identity_may_be_issued": {
          "const": false
        },
        "gate_a_complete": {
          "const": false
        },
        "runtime_authorized": {
          "const": false
        },
        "deployment_authorized": {
          "const": false
        },
        "external_effects_authorized": {
          "const": false
        },
        "publication_authorized": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "candidate_evidence_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "candidate_evidence_raw_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "x-odeya-digest-scope": {
        "kind": "raw_byte_digest",
        "subject": "path_named_by_sibling_artifact_binding",
        "profile": "raw_bytes_no_canonicalization",
        "schema": "not_applicable",
        "algorithm": "sha-256"
      }
    },
    "candidate_evidence_artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "raw_digest",
        "bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?:docs|tests)/[A-Za-z0-9_./-]+$"
        },
        "role": {
          "enum": [
            "profile_specification",
            "vector_manifest",
            "exact_expectations",
            "dependency_and_source_lock",
            "python_implementation",
            "node_implementation",
            "python_retained_result",
            "node_retained_result",
            "comparison_receipt"
          ]
        },
        "raw_digest": {
          "$ref": "#/$defs/candidate_evidence_raw_digest"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        }
      }
    }
  }
}
