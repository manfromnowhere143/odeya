              "const": "urn:odeya:schema:work-intent:0.10.0"
            },
            "successor_work_intent_schema_raw_digest": {
              "const": "sha256:47332f95f5310bd40036a89710405886c440239eedabfe115cd030e69e4d19bd",
              "x-odeya-digest-scope": {
                "kind": "raw_schema_resource_digest",
                "subject": "schemas/work-intent-profile-bound-candidate.schema.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-intent:0.10.0",
                "algorithm": "sha-256",
                "status": "exact_successor_schema_binding"
              }
            },
            "successor_work_intent_schema_bytes": {
              "const": 13915
            },
            "successor_candidate_raw_digest": {
              "const": "sha256:b12c0a304efe87301aa0829ea5d3808b644c832ba572325ff70673090f10634c",
              "x-odeya-digest-scope": {
                "kind": "raw_file_digest",
                "subject": "architecture/work-intent-profile-bound-candidate.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-intent:0.10.0",
                "algorithm": "sha-256",
                "status": "successor_candidate_bootstrap_binding"
              }
            },
            "successor_candidate_bytes": {
              "const": 8657
            },
            "successor_canonical_digest": {
              "type": "null",
              "x-odeya-digest-scope": {
                "kind": "canonical_object_digest",
                "subject": "WorkIntent 0.2 identity subject",
                "profile": "urn:odeya:canonicalization:odeya-jcs-0.1 unissued",
                "schema": "urn:odeya:schema:work-intent:0.10.0",
                "algorithm": "sha-256",
                "status": "not_constructible"
              }
            },
            "binding_status": {
              "const": "successor_present_identity_unissued_derivation_blocked"
            },
            "admission_ref": {
              "type": "null"
            }
          }
        }
      }
    },
    "canonical_digest": {
      "type": "null",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "subject": "identity_subject under work-contract:0.3.0 envelope",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1 unissued",
        "schema": "urn:odeya:schema:work-contract:0.8.0",
        "algorithm": "sha-256",
        "status": "not_constructible_until_profile_work_intent_assignment_cohort_derivation_and_admission"
      }
    },
    "canonical_identity_status": {
      "const": "not_constructible_work_intent_successor_and_assignment_cohort_unresolved"
    },
    "registry_member_ref": {
      "type": "null"
    },
    "admission_ref": {
      "type": "null"
    },
    "operator_acceptance_ref": {
      "type": "null"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_contract_constructed",
        "work_contract_admitted",
        "assignment_authorized",
        "lease_authorized",
        "materialization_authorized",
        "dispatch_authorized",
        "runtime_authorized",
        "deployment_authorized",
        "external_effects_authorized"
      ],
      "properties": {
        "work_contract_constructed": {
          "const": false
        },
        "work_contract_admitted": {
          "const": false
        },
        "assignment_authorized": {
          "const": false
        },
        "lease_authorized": {
          "const": false
        },
        "materialization_authorized": {
          "const": false
        },
        "dispatch_authorized": {
          "const": false
        },
        "runtime_authorized": {
          "const": false
        },
        "deployment_authorized": {
          "const": false
        },
        "external_effects_authorized": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "work_contract_successor_identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]+$"
    },
    "work_contract_successor_profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "profile_core_schema_id",
        "profile_core_raw_digest"
      ],
      "properties": {
        "profile_id": {
          "const": "urn:odeya:canonicalization:odeya-jcs-0.1"
        },
        "profile_version": {
          "const": "0.1.0"
        },
        "profile_core_schema_id": {
          "const": "urn:odeya:schema:canonicalization-profile-core:0.3.0"
        },
        "profile_core_raw_digest": {
          "const": "sha256:ee64570e046a4d1a8252495b3f2f62ecea4c3481e68a1abdcd91668a9693cb43",
          "x-odeya-digest-scope": {
            "kind": "raw_file_digest",
            "subject": "architecture/canonicalization-profile-core-candidate.json raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "urn:odeya:schema:canonicalization-profile-core:0.3.0",
            "algorithm": "sha-256",
            "status": "candidate_profile_unissued"
          }
        }
      }
    }
  }
}
