      "required": [
        "predecessor_binding",
        "work_contract_candidate",
        "work_intent_successor_binding"
      ],
      "properties": {
        "predecessor_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_path",
            "schema_id",
            "schema_raw_digest",
            "schema_bytes",
            "fixture_path",
            "fixture_raw_digest",
            "fixture_bytes"
          ],
          "properties": {
            "schema_path": {
              "const": "schemas/work-contract.schema.json"
            },
            "schema_id": {
              "const": "urn:odeya:schema:work-contract:0.9.0"
            },
            "schema_raw_digest": {
              "const": "sha256:324f3f70be0c28390bbdb5030fcbcaf5274b8c82f9a9316bbf1cf128979852be",
              "x-odeya-digest-scope": {
                "kind": "raw_schema_resource_digest",
                "subject": "schemas/work-contract.schema.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-contract:0.9.0",
                "algorithm": "sha-256",
                "status": "immutable_predecessor_binding"
              }
            },
            "schema_bytes": {
              "const": 11188
            },
            "fixture_path": {
              "const": "tests/cognitive-contracts/fixtures/work-contract.blocked-candidate.valid.json"
            },
            "fixture_raw_digest": {
              "const": "sha256:cd27cef37319f513305e26e7548a49b418abd35048a26c3a0399808d6d2b48c8",
              "x-odeya-digest-scope": {
                "kind": "raw_fixture_digest",
                "subject": "work-contract.blocked-candidate.valid.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-contract:0.9.0",
                "algorithm": "sha-256",
                "status": "architecture_fixture_binding"
              }
            },
            "fixture_bytes": {
              "const": 3568
            }
          }
        },
        "work_contract_candidate": {
          "$ref": "urn:odeya:schema:work-contract:0.9.0"
        },
        "work_intent_successor_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "work_contract_pointer",
            "legacy_work_intent_schema_id",
            "legacy_object_id",
            "legacy_version",
            "legacy_canonical_digest",
            "successor_work_intent_schema_id",
            "successor_work_intent_schema_raw_digest",
            "successor_work_intent_schema_bytes",
            "successor_candidate_raw_digest",
            "successor_candidate_bytes",
            "successor_canonical_digest",
            "binding_status",
            "admission_ref"
          ],
          "properties": {
            "work_contract_pointer": {
              "const": "/work_intent_ref"
            },
            "legacy_work_intent_schema_id": {
              "const": "urn:odeya:schema:work-intent:0.4.0"
            },
            "legacy_object_id": {
              "$ref": "#/$defs/work_contract_successor_identifier"
            },
            "legacy_version": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "legacy_canonical_digest": {
