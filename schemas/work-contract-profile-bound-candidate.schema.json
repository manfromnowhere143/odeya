        "assignment_authorized": {
          "const": false
        },
        "lease_authorized": {
          "const": false
        },
        "materialization_authorized": {
          "const": false
        },
        "dispatch_authorized": {
          "const": false
        },
        "runtime_authorized": {
          "const": false
        },
        "deployment_authorized": {
          "const": false
        },
        "external_effects_authorized": {
          "const": false
        }
      }
    }
