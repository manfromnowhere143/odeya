{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:work-contract:0.8.0",
  "title": "Odeya Profile-Bound WorkContract Successor Candidate",
  "description": "Side-by-side immutable successor wrapper for blocked WorkContract 0.2. It retains the exact nonconstructible predecessor candidate and binds its legacy WorkIntent reference to the present WorkIntent 0.2 successor resource. No resolved WorkIntent identity, assignment commit, exact cohort, derived WorkContract, dispatch claim, or runtime authority is asserted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_class",
    "candidate_status",
    "canonicalization_profile_ref",
    "identity_subject",
    "canonical_digest",
    "canonical_identity_status",
    "registry_member_ref",
    "admission_ref",
    "operator_acceptance_ref",
    "authority_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "0.8.0"
    },
    "artifact_class": {
      "const": "work_contract_profile_bound_successor_candidate"
    },
    "candidate_status": {
      "const": "successor_materialized_work_intent_successor_bound_construction_blocked"
    },
    "canonicalization_profile_ref": {
      "$ref": "#/$defs/work_contract_successor_profile_ref"
    },
    "identity_subject": {
