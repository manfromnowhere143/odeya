{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:claim-version:0.9.0",
  "title": "Odeya ClaimVersion",
  "description": "An immutable semantic claim version compiled from a proposal and an adjudication. Operational, verification, replication, transport, and publication state remain separate aggregates and are referenced rather than embedded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "claim_id",
    "version",
    "mission_id",
    "version_kind",
    "proposal_id",
    "adjudication_id",
    "protocol_digest",
    "claim_type",
    "text",
    "scope",
    "scientific_outcome",
    "eligibility",
    "uncertainty",
    "evidence_edges",
    "verification_run_ids",
    "supersedes",
    "change_reason",
    "compiled_at_ledger_position",
    "created_at",
    "created_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.9.0"
    },
    "claim_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mission_id": {
      "$ref": "#/$defs/identifier"
    },
    "version_kind": {
      "enum": [
        "initial",
        "correction",
        "retraction_notice"
      ]
    },
    "proposal_id": {
      "$ref": "#/$defs/identifier"
    },
    "adjudication_id": {
      "oneOf": [
        {
          "$ref": "#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "protocol_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-protocol-snapshot-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "claim_type": {
      "$ref": "#/$defs/claim_type"
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "$ref": "#/$defs/claim_scope"
    },
    "scientific_outcome": {
      "oneOf": [
        {
          "$ref": "#/$defs/scientific_outcome"
        },
        {
          "type": "null"
        }
      ]
    },
    "eligibility": {
      "$ref": "#/$defs/eligibility"
    },
    "uncertainty": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/uncertainty_channel"
      }
    },
    "evidence_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_edge"
      }
    },
    "verification_run_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "supersedes": {
      "oneOf": [
        {
          "$ref": "#/$defs/claim_claim_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "change_reason": {
      "oneOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "compiled_at_ledger_position": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "created_by": {
      "$ref": "#/$defs/claim_principal"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "version_kind": {
            "const": "initial"
          }
        },
        "required": [
          "version_kind"
        ]
      },
      "then": {
        "properties": {
          "version": {
            "const": 1
          },
          "supersedes": {
            "type": "null"
          },
          "change_reason": {
            "type": "null"
          }
        }
      },
      "else": {
        "properties": {
          "version": {
            "minimum": 2
          },
          "supersedes": {
            "$ref": "#/$defs/claim_claim_reference"
          },
          "change_reason": {
            "$ref": "#/$defs/artifact_reference"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "version_kind": {
            "const": "retraction_notice"
          }
        },
        "required": [
          "version_kind"
        ]
      },
      "then": {
        "properties": {
          "adjudication_id": {
            "type": "null"
          },
          "scientific_outcome": {
            "type": "null"
          },
          "eligibility": {
            "properties": {
              "status": {
                "const": "ineligible"
              },
              "eligible_language": {
                "maxItems": 0
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "adjudication_id": {
            "$ref": "#/$defs/identifier"
          },
          "scientific_outcome": {
            "$ref": "#/$defs/scientific_outcome"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility": {
            "properties": {
              "status": {
                "const": "eligible"
              }
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "eligibility"
        ]
      },
      "then": {
        "properties": {
          "evidence_edges": {
            "minItems": 1
          },
          "verification_run_ids": {
            "minItems": 1
          },
          "eligibility": {
            "properties": {
              "eligible_language": {
                "minItems": 1
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "eligibility": {
            "properties": {
              "eligible_language": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scientific_outcome": {
            "const": "supported_within_scope"
          }
        },
        "required": [
          "scientific_outcome"
        ]
      },
      "then": {
        "properties": {
          "evidence_edges": {
            "contains": {
              "properties": {
                "relation": {
                  "const": "supports"
                }
              },
              "required": [
                "relation"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scientific_outcome": {
            "enum": [
              "contradicted",
              "falsified"
            ]
          }
        },
        "required": [
          "scientific_outcome"
        ]
      },
      "then": {
        "properties": {
          "evidence_edges": {
            "contains": {
              "properties": {
                "relation": {
                  "enum": [
                    "contradicts",
                    "falsifies"
                  ]
                }
              },
              "required": [
                "relation"
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "claim_type": {
      "enum": [
        "measurement",
        "descriptive",
        "predictive",
        "causal",
        "agent_comparison",
        "safety_reliability",
        "value",
        "evidence_synthesis"
      ]
    },
    "scientific_outcome": {
      "enum": [
        "supported_within_scope",
        "contradicted",
        "falsified",
        "null_result",
        "inconclusive"
      ]
    },
    "claim_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "population",
        "environment",
        "time",
        "intervention",
        "exclusions"
      ],
      "properties": {
        "population": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "string",
          "minLength": 1
        },
        "intervention": {
          "type": "string",
          "minLength": 1
        },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation",
        "artifact",
        "activity_id",
        "scope_note"
      ],
      "properties": {
        "relation": {
          "enum": [
            "supports",
            "contradicts",
            "tests",
            "falsifies",
            "derived_from",
            "replicates",
            "supersedes",
            "corrects",
            "invalidates",
            "bounded_to",
            "withheld_by"
          ]
        },
        "artifact": {
          "$ref": "#/$defs/artifact_reference"
        },
        "activity_id": {
          "$ref": "#/$defs/identifier"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "rule_id",
        "rule_version",
        "rule_registry_digest",
        "reason_codes",
        "eligible_language",
        "forbidden_language"
      ],
      "properties": {
        "status": {
          "enum": [
            "eligible",
            "ineligible"
          ]
        },
        "rule_id": {
          "$ref": "#/$defs/identifier"
        },
        "rule_version": {
          "type": "string",
          "minLength": 1
        },
        "rule_registry_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-validation-rule-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "eligible_language": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_language": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "uncertainty_channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "representation",
        "estimate",
        "interval",
        "missingness",
        "assumptions"
      ],
      "properties": {
        "channel": {
          "enum": [
            "measurement",
            "sampling",
            "parameter",
            "predictive",
            "structural_model",
            "distribution_transport",
            "decision_utility",
            "infrastructure_operational"
          ]
        },
        "representation": {
          "enum": [
            "interval",
            "distribution",
            "set",
            "qualitative_bounded",
            "not_applicable",
            "unknown"
          ]
        },
        "estimate": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "decimal",
                "precision",
                "semantic_type",
                "unit"
              ],
              "properties": {
                "decimal": {
                  "type": "string",
                  "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
                },
                "semantic_type": {
                  "const": "measured_quantity"
                },
                "unit": {
                  "type": "string",
                  "minLength": 1
                },
                "precision": {
                  "type": "string",
                  "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "interval": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "lower",
                "upper",
                "level",
                "interval_type"
              ],
              "properties": {
                "lower": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "decimal",
                    "precision",
                    "semantic_type",
                    "unit"
                  ],
                  "properties": {
                    "decimal": {
                      "type": "string",
                      "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
                    },
                    "semantic_type": {
                      "const": "measured_quantity"
                    },
                    "unit": {
                      "type": "string",
                      "minLength": 1
                    },
                    "precision": {
                      "type": "string",
                      "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
                    }
                  }
                },
                "upper": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "decimal",
                    "precision",
                    "semantic_type",
                    "unit"
                  ],
                  "properties": {
                    "decimal": {
                      "type": "string",
                      "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
                    },
                    "semantic_type": {
                      "const": "measured_quantity"
                    },
                    "unit": {
                      "type": "string",
                      "minLength": 1
                    },
                    "precision": {
                      "type": "string",
                      "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
                    }
                  }
                },
                "level": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "decimal",
                    "precision",
                    "semantic_type",
                    "unit"
                  ],
                  "properties": {
                    "decimal": {
                      "type": "string",
                      "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
                    },
                    "semantic_type": {
                      "const": "interval_confidence_level"
                    },
                    "unit": {
                      "const": "dimensionless"
                    },
                    "precision": {
                      "const": "6"
                    }
                  }
                },
                "interval_type": {
                  "enum": [
                    "fixed",
                    "simultaneous",
                    "time_uniform",
                    "credible",
                    "measurement_uncertainty"
                  ]
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "missingness": {
          "enum": [
            "measured",
            "partially_measured",
            "unmeasured",
            "unavailable",
            "withheld",
            "not_applicable"
          ]
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "missingness": {
                "enum": [
                  "unmeasured",
                  "unavailable",
                  "withheld",
                  "not_applicable"
                ]
              }
            },
            "required": [
              "missingness"
            ]
          },
          "then": {
            "properties": {
              "estimate": {
                "type": "null"
              },
              "interval": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "claim_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "organization"
          ]
        }
      }
    },
    "claim_claim_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "version"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "claim_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "code"
      ],
      "properties": {
        "system": {
          "enum": [
            "SI",
            "UCUM",
            "dimensionless",
            "domain_registered"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "claim_quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "unit"
      ],
      "properties": {
        "value": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decimal",
            "precision",
            "semantic_type",
            "unit"
          ],
          "properties": {
            "decimal": {
              "type": "string",
              "pattern": "^(?:(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?|-(?:0\\.[0-9]*[1-9][0-9]*|[1-9][0-9]*(?:\\.[0-9]+)?))(?:e-?(?:0|[1-9][0-9]*))?$"
            },
            "semantic_type": {
              "const": "measured_quantity"
            },
            "unit": {
              "type": "string",
              "minLength": 1
            },
            "precision": {
              "type": "string",
              "pattern": "^(?:0|[1-9][0-9]{0,2}|exact_lexical)$"
            }
          }
        },
        "unit": {
          "$ref": "#/$defs/claim_unit"
        }
      }
    }
  }
}
