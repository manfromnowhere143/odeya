{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:work-contract:0.1.0",
  "title": "Odeya WorkContract",
  "description": "A proposed lease-bounded instruction for one worker capability. It binds an exact immutable canonical lease record and reducer frontier plus an externally sealed, admitted state-compilation bundle, separates local isolation from governed external processing, rejects caller-supplied authority, and requires a separately admitted dispatch with a current lease recheck before work or external processing begins.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "record_status", "work_contract_id", "version", "mission_id",
    "stage_id", "attempt_id", "branch_id", "principal_correlation_group_id",
    "worker_principal", "execution_mode", "state_compilation_bundle", "objective",
    "permitted_deliverable_classes", "capabilities", "forbidden_effects",
    "data_boundary", "limits", "output_contract", "artifact_custody",
    "required_evidence_dispositions", "known_bad_check_refs", "lease",
    "cancellation", "checkpoint", "handoff", "fallback_and_retry",
    "dispatch_boundary", "authority_boundary", "created_at", "created_by"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "record_status": { "const": "deterministic_control_artifact" },
    "work_contract_id": { "$ref": "#/$defs/identifier" },
    "version": { "type": "integer", "minimum": 1 },
    "mission_id": { "$ref": "#/$defs/identifier" },
    "stage_id": { "$ref": "#/$defs/identifier" },
    "attempt_id": { "$ref": "#/$defs/identifier" },
    "branch_id": { "$ref": "#/$defs/identifier" },
    "principal_correlation_group_id": { "$ref": "#/$defs/identifier" },
    "worker_principal": { "$ref": "#/$defs/principal" },
    "execution_mode": { "enum": ["local_isolated_worker", "governed_external_processing"] },
    "state_compilation_bundle": {
      "type": "object", "additionalProperties": false,
      "required": [
        "bundle_ref", "binding_profile_ref", "view", "receipt", "sealed_root_ref",
        "compilation_disposition", "receipt_compilation_result", "receipt_replay_result",
        "required_evidence_coverage", "contradiction_coverage", "negative_flow_check"
      ],
      "properties": {
        "bundle_ref": { "$ref": "#/$defs/artifact_reference" },
        "binding_profile_ref": { "$ref": "#/$defs/versioned_reference" },
        "view": { "$ref": "#/$defs/research_state_view_reference" },
        "receipt": { "$ref": "#/$defs/context_compilation_receipt_reference" },
        "sealed_root_ref": { "$ref": "#/$defs/artifact_reference" },
        "compilation_disposition": { "const": "admitted" },
        "receipt_compilation_result": { "const": "pass" },
        "receipt_replay_result": { "const": "pass" },
        "required_evidence_coverage": { "const": "complete" },
        "contradiction_coverage": { "const": "complete" },
        "negative_flow_check": { "const": "pass" }
      }
    },
    "objective": { "type": "string", "minLength": 1 },
    "permitted_deliverable_classes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
    "capabilities": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["capability_id", "handle_ref", "grant_ref", "allowed_operations", "ambient_credential"],
        "properties": {
          "capability_id": { "$ref": "#/$defs/identifier" },
          "handle_ref": { "$ref": "#/$defs/artifact_reference" },
          "grant_ref": { "$ref": "#/$defs/immutable_reference" },
          "allowed_operations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
          "ambient_credential": { "const": false }
        }
      }
    },
    "forbidden_effects": {
      "type": "array", "minItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" },
      "allOf": [
        { "contains": { "const": "canonical_event_append" } },
        { "contains": { "const": "authority_mutation" } },
        { "contains": { "const": "undeclared_external_effect" } }
      ]
    },
    "data_boundary": {
      "type": "object", "additionalProperties": false,
      "required": ["purpose", "classes", "exposure_ceiling", "residency", "egress", "provider_retention"],
      "properties": {
        "purpose": { "$ref": "#/$defs/identifier" },
        "classes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["public", "internal", "confidential", "restricted_allowed"] } },
        "exposure_ceiling": { "enum": ["public", "internal", "confidential", "restricted_allowed"] },
        "residency": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
        "egress": { "enum": ["none", "bounded_provider", "approved_region_only"] },
        "provider_retention": { "enum": ["none", "bounded", "unknown"] }
      }
    },
    "limits": {
      "type": "object", "additionalProperties": false,
      "required": ["execution_budget", "context_window_tokens", "retry_count"],
      "properties": {
        "execution_budget": { "$ref": "#/$defs/execution_budget" },
        "context_window_tokens": { "type": "integer", "minimum": 1 },
        "retry_count": { "type": "integer", "minimum": 0 }
      }
    },
    "output_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_ref", "candidate_artifact_required", "claim_authority", "private_reasoning_evidence_eligible"],
      "properties": {
        "schema_ref": { "$ref": "#/$defs/versioned_reference" },
        "candidate_artifact_required": { "const": true },
        "claim_authority": { "const": false },
        "private_reasoning_evidence_eligible": { "const": false }
      }
    },
    "artifact_custody": {
      "type": "object", "additionalProperties": false,
      "required": ["manifest_required", "custody_observation_required", "settlement_required", "rule_ref"],
      "properties": {
        "manifest_required": { "const": true },
        "custody_observation_required": { "const": true },
        "settlement_required": { "const": true },
        "rule_ref": { "$ref": "#/$defs/immutable_reference" }
      }
    },
    "required_evidence_dispositions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/artifact_reference" } },
    "known_bad_check_refs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/immutable_reference" } },
    "lease": {
      "type": "object", "additionalProperties": false,
      "required": [
        "lease_record_ref", "lease_frontier", "scope_binding",
        "constraints_snapshot", "constraints_snapshot_must_equal_record",
        "lease_is_dispatch_authority"
      ],
      "properties": {
        "lease_record_ref": { "$ref": "#/$defs/canonical_work_lease_reference" },
        "lease_frontier": {
          "type": "object", "additionalProperties": false,
          "required": [
            "ledger_position", "checkpoint_ref", "lease_state_event_ref",
            "lease_state_root_digest", "lease_reducer_ref", "frontier_digest",
            "lease_state_at_frontier", "controlled_time_evidence_ref"
          ],
          "properties": {
            "ledger_position": { "type": "integer", "minimum": 0 },
            "checkpoint_ref": { "$ref": "#/$defs/immutable_reference" },
            "lease_state_event_ref": { "$ref": "#/$defs/immutable_reference" },
            "lease_state_root_digest": { "$ref": "#/$defs/digest" },
            "lease_reducer_ref": { "$ref": "#/$defs/immutable_reference" },
            "frontier_digest": { "$ref": "#/$defs/digest" },
            "lease_state_at_frontier": { "const": "active" },
            "controlled_time_evidence_ref": { "$ref": "#/$defs/artifact_reference" }
          }
        },
        "scope_binding": {
          "type": "object", "additionalProperties": false,
          "required": ["mission_id", "stage_id", "attempt_id", "worker_principal_id"],
          "properties": {
            "mission_id": { "$ref": "#/$defs/identifier" },
            "stage_id": { "$ref": "#/$defs/identifier" },
            "attempt_id": { "$ref": "#/$defs/identifier" },
            "worker_principal_id": { "$ref": "#/$defs/identifier" }
          }
        },
        "constraints_snapshot": {
          "type": "object", "additionalProperties": false,
          "required": ["expires_at", "renewal_requires_new_record", "new_claims_after_expiry_allowed"],
          "properties": {
            "expires_at": { "$ref": "#/$defs/timestamp" },
            "renewal_requires_new_record": { "const": true },
            "new_claims_after_expiry_allowed": { "const": false }
          }
        },
        "constraints_snapshot_must_equal_record": { "const": true },
        "lease_is_dispatch_authority": { "const": false }
      }
    },
    "cancellation": {
      "type": "object", "additionalProperties": false,
      "required": ["check_interval_seconds", "cancellation_ref", "new_claims_after_cancellation_allowed", "observed_external_facts_rewritten"],
      "properties": {
        "check_interval_seconds": { "type": "integer", "minimum": 1 },
        "cancellation_ref": { "$ref": "#/$defs/immutable_reference" },
        "new_claims_after_cancellation_allowed": { "const": false },
        "observed_external_facts_rewritten": { "const": false }
      }
    },
    "checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": [
        "required", "frequency_seconds", "schema_ref", "checkpoint_scope",
        "candidate_progress_recoverable", "canonical_state_included",
        "canonical_reconstruction_source"
      ],
      "properties": {
        "required": { "const": true },
        "frequency_seconds": { "type": "integer", "minimum": 1 },
        "schema_ref": { "$ref": "#/$defs/versioned_reference" },
        "checkpoint_scope": { "const": "candidate_progress_only" },
        "candidate_progress_recoverable": { "const": true },
        "canonical_state_included": { "const": false },
        "canonical_reconstruction_source": { "const": "ledger_only" }
      }
    },
    "handoff": {
      "type": "object", "additionalProperties": false,
      "required": ["required_on_stop", "handoff_schema_ref", "unsettled_effects_must_be_listed"],
      "properties": {
        "required_on_stop": { "const": true },
        "handoff_schema_ref": { "$ref": "#/$defs/versioned_reference" },
        "unsettled_effects_must_be_listed": { "const": true }
      }
    },
    "fallback_and_retry": {
      "type": "object", "additionalProperties": false,
      "required": ["provider_or_model_change_requires_new_attempt", "same_attempt_identity_reuse_allowed", "confirmatory_continuation_allowed", "fallback_rule_ref"],
      "properties": {
        "provider_or_model_change_requires_new_attempt": { "const": true },
        "same_attempt_identity_reuse_allowed": { "const": false },
        "confirmatory_continuation_allowed": { "const": false },
        "fallback_rule_ref": { "$ref": "#/$defs/immutable_reference" }
      }
    },
    "dispatch_boundary": {
      "type": "object", "additionalProperties": false,
      "required": [
        "current_frontier", "data_use_decisions", "prospective_materialization",
        "sandbox_capability", "required_authority_grant_refs",
        "required_policy_refs", "dispatch_time_recheck_required", "recheck_dimensions",
        "lease_recheck",
        "resource_and_spend_reservation", "stale_or_revoked_disposition",
        "dispatch_command_type", "dispatch_command_profile_ref", "dispatch_consumption_point",
        "separate_work_dispatch_admission_required", "work_contract_is_dispatch_admission",
        "bytes_may_cross_before_dispatch_admission", "provider_spend_may_incur_before_dispatch_admission",
        "local_isolated", "governed_external_processing"
      ],
      "properties": {
        "current_frontier": {
          "type": "object", "additionalProperties": false,
          "required": [
            "ledger_position", "checkpoint_ref", "frontier_digest",
            "legal_frontier_digest", "authority_policy_set_digest",
            "lease_state_root_digest", "data_use_state_root_digest",
            "resource_state_root_digest", "sandbox_policy_set_digest"
          ],
          "properties": {
            "ledger_position": { "type": "integer", "minimum": 0 },
            "checkpoint_ref": { "$ref": "#/$defs/immutable_reference" },
            "frontier_digest": { "$ref": "#/$defs/digest" },
            "legal_frontier_digest": { "$ref": "#/$defs/digest" },
            "authority_policy_set_digest": { "$ref": "#/$defs/digest" },
            "lease_state_root_digest": { "$ref": "#/$defs/digest" },
            "data_use_state_root_digest": { "$ref": "#/$defs/digest" },
            "resource_state_root_digest": { "$ref": "#/$defs/digest" },
            "sandbox_policy_set_digest": { "$ref": "#/$defs/digest" }
          }
        },
        "data_use_decisions": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["decision_ref", "state_at_frontier", "purpose", "data_class"],
            "properties": {
              "decision_ref": { "$ref": "#/$defs/immutable_reference" },
              "state_at_frontier": { "const": "active" },
              "purpose": { "$ref": "#/$defs/identifier" },
              "data_class": { "enum": ["public", "internal", "confidential", "restricted_allowed"] }
            }
          }
        },
        "prospective_materialization": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": [
                "intent_ref", "source_input_manifest_ref", "prospective_input_manifest_ref",
                "materialization_target_digest", "mount_mode", "materialization_consumption_point",
                "bytes_visible_before_attempt_start_commit", "data_exposure_record_required",
                "external_effect_authority_required"
              ],
              "properties": {
                "intent_ref": { "$ref": "#/$defs/immutable_reference" },
                "source_input_manifest_ref": { "$ref": "#/$defs/artifact_reference" },
                "prospective_input_manifest_ref": { "$ref": "#/$defs/artifact_reference" },
                "materialization_target_digest": { "$ref": "#/$defs/digest" },
                "mount_mode": { "const": "read_only" },
                "materialization_consumption_point": { "const": "after_attempt_start_commit" },
                "bytes_visible_before_attempt_start_commit": { "const": false },
                "data_exposure_record_required": { "const": false },
                "external_effect_authority_required": { "const": false }
              }
            },
            { "type": "null" }
          ]
        },
        "sandbox_capability": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": [
                "capability_ref", "sandbox_ref", "policy_ref", "preflight_observation_ref",
                "launcher_profile_ref", "network_access", "ambient_credentials_present",
                "provider_authority_granted", "model_authority_granted",
                "external_effect_authority_granted"
              ],
              "properties": {
                "capability_ref": { "$ref": "#/$defs/immutable_reference" },
                "sandbox_ref": { "$ref": "#/$defs/immutable_reference" },
                "policy_ref": { "$ref": "#/$defs/immutable_reference" },
                "preflight_observation_ref": { "$ref": "#/$defs/artifact_reference" },
                "launcher_profile_ref": { "$ref": "#/$defs/versioned_reference" },
                "network_access": { "const": "none" },
                "ambient_credentials_present": { "const": false },
                "provider_authority_granted": { "const": false },
                "model_authority_granted": { "const": false },
                "external_effect_authority_granted": { "const": false }
              }
            },
            { "type": "null" }
          ]
        },
        "required_authority_grant_refs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/immutable_reference" } },
        "required_policy_refs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/immutable_reference" } },
        "dispatch_time_recheck_required": { "const": true },
        "recheck_dimensions": {
          "type": "array", "minItems": 8, "maxItems": 10, "uniqueItems": true,
          "items": { "enum": ["authority", "state", "policy", "data_use", "resource_reservation", "data_materialization", "sandbox", "lease", "exposure", "provider_configuration"] },
          "allOf": [
            { "contains": { "const": "authority" } },
            { "contains": { "const": "state" } },
            { "contains": { "const": "policy" } },
            { "contains": { "const": "data_use" } },
            { "contains": { "const": "resource_reservation" } },
            { "contains": { "const": "data_materialization" } },
            { "contains": { "const": "sandbox" } },
            { "contains": { "const": "lease" } }
          ]
        },
        "lease_recheck": {
          "type": "object", "additionalProperties": false,
          "required": [
            "lease_record_ref", "bound_lease_frontier", "current_lease_state_evidence_ref",
            "current_lease_state_event_ref", "current_controlled_time",
            "current_controlled_time_evidence_ref", "lease_recheck_required",
            "exact_record_and_frontier_match_required", "required_state_at_dispatch",
            "stale_expired_revoked_or_indeterminate_disposition"
          ],
          "properties": {
            "lease_record_ref": { "$ref": "#/$defs/canonical_work_lease_reference" },
            "bound_lease_frontier": {
              "type": "object", "additionalProperties": false,
              "required": ["ledger_position", "checkpoint_ref", "lease_state_event_ref", "lease_state_root_digest", "frontier_digest"],
              "properties": {
                "ledger_position": { "type": "integer", "minimum": 0 },
                "checkpoint_ref": { "$ref": "#/$defs/immutable_reference" },
                "lease_state_event_ref": { "$ref": "#/$defs/immutable_reference" },
                "lease_state_root_digest": { "$ref": "#/$defs/digest" },
                "frontier_digest": { "$ref": "#/$defs/digest" }
              }
            },
            "current_lease_state_evidence_ref": { "$ref": "#/$defs/artifact_reference" },
            "current_lease_state_event_ref": { "$ref": "#/$defs/immutable_reference" },
            "current_controlled_time": { "$ref": "#/$defs/timestamp" },
            "current_controlled_time_evidence_ref": { "$ref": "#/$defs/artifact_reference" },
            "lease_recheck_required": { "const": true },
            "exact_record_and_frontier_match_required": { "const": true },
            "required_state_at_dispatch": { "const": "active" },
            "stale_expired_revoked_or_indeterminate_disposition": { "const": "refuse" }
          }
        },
        "resource_and_spend_reservation": {
          "type": "object", "additionalProperties": false,
          "required": ["reservation_ref", "maximum_resource", "over_reservation_dispatch_allowed"],
          "properties": {
            "reservation_ref": { "$ref": "#/$defs/immutable_reference" },
            "maximum_resource": { "$ref": "#/$defs/execution_budget" },
            "over_reservation_dispatch_allowed": { "const": false },
            "reservation_created_event_ref": { "$ref": "#/$defs/resource_reservation_created_event_reference" },
            "operational_dimension_keys": {
              "type": "array", "minItems": 1, "uniqueItems": true,
              "items": { "$ref": "#/$defs/identifier" }
            },
            "verification_capacity_dimension_keys": {
              "type": "array", "minItems": 1, "uniqueItems": true,
              "items": { "$ref": "#/$defs/identifier" }
            },
            "combined_non_fungible_reservation": { "const": true },
            "cross_dimension_compensation_allowed": { "const": false },
            "claim_command_type": { "const": "attempt.start" },
            "claim_event_must_share_dispatch_commit": { "const": true },
            "release_or_expiry_preclaim_only": { "const": true },
            "claimed_ceiling_survives_terminal_attempt": { "const": true }
          }
        },
        "stale_or_revoked_disposition": { "const": "refuse" },
        "dispatch_command_type": { "enum": ["attempt.start", "external_effect.start"] },
        "dispatch_command_profile_ref": { "$ref": "#/$defs/versioned_reference" },
        "dispatch_consumption_point": { "const": "before_input_bytes_or_process_start" },
        "separate_work_dispatch_admission_required": { "const": true },
        "work_contract_is_dispatch_admission": { "const": false },
        "bytes_may_cross_before_dispatch_admission": { "const": false },
        "provider_spend_may_incur_before_dispatch_admission": { "const": false },
        "local_isolated": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": [
                "isolation_mode", "network_access", "external_egress_permitted",
                "provider_or_model_access_permitted", "provider_spend_permitted",
                "ambient_credentials_permitted", "external_effect_dispatch_required",
                "input_mount_allowed_only_after_attempt_start_commit",
                "process_spawn_allowed_only_after_attempt_start_commit"
              ],
              "properties": {
                "isolation_mode": { "const": "deny_by_default" },
                "network_access": { "const": "none" },
                "external_egress_permitted": { "const": false },
                "provider_or_model_access_permitted": { "const": false },
                "provider_spend_permitted": { "const": false },
                "ambient_credentials_permitted": { "const": false },
                "external_effect_dispatch_required": { "const": false },
                "input_mount_allowed_only_after_attempt_start_commit": { "const": true },
                "process_spawn_allowed_only_after_attempt_start_commit": { "const": true }
              }
            },
            { "type": "null" }
          ]
        },
        "governed_external_processing": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": ["provider_configuration_observation_ref", "exposure_intent_ref", "egress_recipient", "egress_region", "external_effect_dispatch_required", "external_effect_profile_ref"],
              "properties": {
                "provider_configuration_observation_ref": { "$ref": "#/$defs/artifact_reference" },
                "exposure_intent_ref": { "$ref": "#/$defs/immutable_reference" },
                "egress_recipient": { "$ref": "#/$defs/identifier" },
                "egress_region": { "$ref": "#/$defs/identifier" },
                "external_effect_dispatch_required": { "const": true },
                "external_effect_profile_ref": { "$ref": "#/$defs/immutable_reference" }
              }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "authority_boundary": {
      "type": "object", "additionalProperties": false,
      "required": ["authority_source", "caller_supplied_authority_accepted", "worker_can_modify_contract", "worker_can_modify_evaluator", "worker_can_modify_budget", "worker_can_modify_success_definition", "canonical_event_append_authorized"],
      "properties": {
        "authority_source": { "const": "canonical_grant_resolution" },
        "caller_supplied_authority_accepted": { "const": false },
        "worker_can_modify_contract": { "const": false },
        "worker_can_modify_evaluator": { "const": false },
        "worker_can_modify_budget": { "const": false },
        "worker_can_modify_success_definition": { "const": false },
        "canonical_event_append_authorized": { "const": false }
      }
    },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "created_by": { "$ref": "#/$defs/principal" }
  },
  "allOf": [
    {
      "if": { "properties": { "execution_mode": { "const": "local_isolated_worker" } }, "required": ["execution_mode"] },
      "then": {
        "properties": {
          "data_boundary": { "properties": { "egress": { "const": "none" }, "provider_retention": { "const": "none" } } },
          "dispatch_boundary": {
            "properties": {
              "local_isolated": { "type": "object" },
              "governed_external_processing": { "type": "null" },
              "prospective_materialization": { "type": "object" },
              "sandbox_capability": { "type": "object" },
              "dispatch_command_type": { "const": "attempt.start" },
              "required_authority_grant_refs": { "minItems": 5, "maxItems": 5 },
              "recheck_dimensions": { "not": { "contains": { "enum": ["exposure", "provider_configuration"] } } },
              "resource_and_spend_reservation": {
                "required": [
                  "reservation_created_event_ref", "operational_dimension_keys",
                  "verification_capacity_dimension_keys", "combined_non_fungible_reservation",
                  "cross_dimension_compensation_allowed", "claim_command_type",
                  "claim_event_must_share_dispatch_commit", "release_or_expiry_preclaim_only",
                  "claimed_ceiling_survives_terminal_attempt"
                ],
                "properties": {
                  "maximum_resource": {
                    "properties": {
                      "spend": { "properties": { "amount": { "const": "0" } } }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "data_boundary": { "properties": { "egress": { "not": { "const": "none" } } } },
          "dispatch_boundary": {
            "properties": {
              "local_isolated": { "type": "null" },
              "governed_external_processing": { "type": "object" },
              "prospective_materialization": { "type": "null" },
              "sandbox_capability": { "type": "null" },
              "dispatch_command_type": { "const": "external_effect.start" },
              "recheck_dimensions": {
                "allOf": [
                  { "contains": { "const": "exposure" } },
                  { "contains": { "const": "provider_configuration" } }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$" },
    "artifact_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "digest", "media_type"],
      "properties": { "artifact_id": { "$ref": "#/$defs/identifier" }, "digest": { "$ref": "#/$defs/digest" }, "media_type": { "type": "string", "minLength": 1 } }
    },
    "immutable_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "integer", "minimum": 1 }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "canonical_work_lease_reference": {
      "type": "object", "additionalProperties": false,
      "required": [
        "record_type", "work_item_id", "lease_id", "lease_version",
        "schema_id", "canonical_digest", "issuance_event_ref"
      ],
      "properties": {
        "record_type": { "const": "canonical_work_lease" },
        "work_item_id": { "$ref": "#/$defs/identifier" },
        "lease_id": { "$ref": "#/$defs/identifier" },
        "lease_version": { "type": "integer", "minimum": 1 },
        "schema_id": { "type": "string", "format": "uri" },
        "canonical_digest": { "$ref": "#/$defs/digest" },
        "issuance_event_ref": {
          "type": "object", "additionalProperties": false,
          "required": ["event_type", "event_version", "event_id", "schema_id", "event_digest"],
          "properties": {
            "event_type": { "const": "work.lease_acquired" },
            "event_version": { "const": "1.0.0" },
            "event_id": { "$ref": "#/$defs/identifier" },
            "schema_id": { "const": "urn:odeya:schema:research-event:0.6.0" },
            "event_digest": { "$ref": "#/$defs/digest" }
          }
        }
      }
    },
    "resource_reservation_created_event_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["event_type", "event_version", "event_id", "schema_id", "event_digest"],
      "properties": {
        "event_type": { "const": "resource.reservation_created" },
        "event_version": { "const": "1.0.0" },
        "event_id": { "$ref": "#/$defs/identifier" },
        "schema_id": { "const": "urn:odeya:schema:research-event:0.6.0" },
        "event_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "research_state_view_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["record_type", "id", "version", "schema_id", "digest"],
      "properties": {
        "record_type": { "const": "research_state_view" },
        "id": { "$ref": "#/$defs/identifier" },
        "version": { "type": "integer", "minimum": 1 },
        "schema_id": { "const": "urn:odeya:schema:research-state-view:0.1.0" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "context_compilation_receipt_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["record_type", "id", "version", "schema_id", "digest"],
      "properties": {
        "record_type": { "const": "context_compilation_receipt" },
        "id": { "$ref": "#/$defs/identifier" },
        "version": { "type": "integer", "minimum": 1 },
        "schema_id": { "const": "urn:odeya:schema:context-compilation-receipt:0.1.0" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "versioned_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "principal": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": { "principal_id": { "$ref": "#/$defs/identifier" }, "principal_type": { "enum": ["human", "deterministic_service", "model_run"] } }
    },
    "execution_budget": {
      "type": "object", "additionalProperties": false,
      "required": ["profile_ref", "limits", "spend", "cross_resource_conversion_allowed"],
      "properties": {
        "profile_ref": { "$ref": "#/$defs/execution_budget_profile_reference" },
        "limits": {
          "type": "array", "minItems": 9, "maxItems": 9, "uniqueItems": true,
          "items": { "$ref": "#/$defs/execution_limit" },
          "allOf": [
            { "contains": { "properties": { "resource_kind": { "const": "model_input_tokens" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "model_output_tokens" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "tool_calls" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "cpu_time" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "gpu_time" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "peak_memory_bytes" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "storage_bytes" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "network_egress_bytes" } }, "required": ["resource_kind"] } },
            { "contains": { "properties": { "resource_kind": { "const": "wall_time" } }, "required": ["resource_kind"] } }
          ]
        },
        "spend": { "$ref": "#/$defs/money_quantity" },
        "cross_resource_conversion_allowed": { "const": false }
      }
    },
    "execution_budget_profile_reference": { "type": "object", "additionalProperties": false, "required": ["id", "version", "digest"], "properties": { "id": { "const": "execution-budget.foundation" }, "version": { "const": "0.1.0" }, "digest": { "$ref": "#/$defs/digest" } } },
    "execution_limit": { "type": "object", "additionalProperties": false, "required": ["resource_kind", "limit", "unit_ref"], "properties": { "resource_kind": { "enum": ["model_input_tokens", "model_output_tokens", "tool_calls", "cpu_time", "gpu_time", "peak_memory_bytes", "storage_bytes", "network_egress_bytes", "wall_time"] }, "limit": { "$ref": "#/$defs/nonnegative_decimal" }, "unit_ref": { "$ref": "#/$defs/immutable_reference" } } },
    "money_quantity": { "type": "object", "additionalProperties": false, "required": ["amount", "currency"], "properties": { "amount": { "$ref": "#/$defs/nonnegative_decimal" }, "currency": { "type": "string", "pattern": "^[A-Z]{3}$" } } },
    "nonnegative_decimal": { "type": "string", "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$" }
  }
}
