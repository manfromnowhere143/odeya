{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:work-intent-core:0.10.0",
  "title": "Odeya WorkIntent Reference-Resolved Semantic Core Candidate",
  "description": "Identity-free WorkIntent semantic subject whose nested source-view and planning-epoch references separate exact raw candidate bindings from still-unissued canonical object digests, and whose output schema binds exact retained resource bytes. No profile, canonical identity, admission, assignment, or runtime authority is issued.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_status",
    "record_authority_status",
    "work_intent_id",
    "version",
    "mission_id",
    "stage_id",
    "branch_id",
    "source_view_ref",
    "planning_epoch_ref",
    "objective",
    "permitted_deliverable_classes",
    "candidate_worker_requirements",
    "data_boundary",
    "estimated_limits",
    "output_contract",
    "assignment_boundary",
    "prospective_authority_boundary",
    "canonical_collection_ordering",
    "created_at",
    "created_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.10.0"
    },
    "record_status": {
      "const": "proposed_non_authoritative"
    },
    "record_authority_status": {
      "const": "not_admitted_not_assignable"
    },
    "work_intent_id": {
      "$ref": "#/$defs/work_intent_core_identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "mission_id": {
      "$ref": "#/$defs/work_intent_core_identifier"
    },
    "stage_id": {
      "$ref": "#/$defs/work_intent_core_identifier"
    },
    "branch_id": {
      "$ref": "#/$defs/work_intent_core_identifier"
    },
    "source_view_ref": {
      "$ref": "#/$defs/work_intent_core_v02_source_view_reference"
    },
    "planning_epoch_ref": {
      "$ref": "#/$defs/work_intent_core_v02_planning_epoch_reference"
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "permitted_deliverable_classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/work_intent_core_identifier"
      }
    },
    "candidate_worker_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_classes",
        "execution_modes",
        "selection_status",
        "worker_principal_ref"
      ],
      "properties": {
        "capability_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/work_intent_core_identifier"
          }
        },
        "execution_modes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "local_isolated_worker",
              "governed_external_processing"
            ]
          }
        },
        "selection_status": {
          "const": "unassigned"
        },
        "worker_principal_ref": {
          "type": "null"
        }
      }
    },
    "data_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "maximum_data_classes",
        "allowed_residencies",
        "maximum_egress",
        "data_use_status",
        "active_data_use_decision_refs"
      ],
      "properties": {
        "purpose": {
          "$ref": "#/$defs/work_intent_core_identifier"
        },
        "maximum_data_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "public",
              "internal",
              "confidential",
              "restricted_allowed"
            ]
          }
        },
        "allowed_residencies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/work_intent_core_identifier"
          }
        },
        "maximum_egress": {
          "enum": [
            "none",
            "bounded_provider",
            "approved_region_only"
          ]
        },
        "data_use_status": {
          "const": "unresolved_until_assignment"
        },
        "active_data_use_decision_refs": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "estimated_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimate_status",
        "wall_time_seconds",
        "model_input_tokens",
        "model_output_tokens",
        "network_egress_bytes",
        "spend_minor_units",
        "currency"
      ],
      "properties": {
        "estimate_status": {
          "const": "planning_estimate_not_reservation"
        },
        "wall_time_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "model_input_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "model_output_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "network_egress_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "spend_minor_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_ref",
        "candidate_artifact_required",
        "claim_authority",
        "publication_authority"
      ],
      "properties": {
        "schema_ref": {
          "$ref": "#/$defs/work_intent_core_v02_output_schema_reference"
        },
        "candidate_artifact_required": {
          "const": true
        },
        "claim_authority": {
          "const": false
        },
        "publication_authority": {
          "const": false
        }
      }
    },
    "assignment_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_command_type",
        "intent_reference_required_in_command",
        "atomic_commit_required",
        "prerequisites_to_resolve_at_assignment",
        "work_contract_materialization",
        "dispatch_claim_required_after_work_contract"
      ],
      "properties": {
        "required_command_type": {
          "const": "verification.assign"
        },
        "intent_reference_required_in_command": {
          "const": true
        },
        "atomic_commit_required": {
          "const": true
        },
        "prerequisites_to_resolve_at_assignment": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "prefixItems": [
            {
              "const": "work_intent_canonical_identity"
            },
            {
              "const": "worker_principal"
            },
            {
              "const": "active_work_lease"
            },
            {
              "const": "authority_grants"
            },
            {
              "const": "active_data_use_decisions"
            },
            {
              "const": "sandbox_capability"
            },
            {
              "const": "resource_reservation"
            },
            {
              "const": "passing_state_compilation_bundle"
            }
          ],
          "items": false
        },
        "work_contract_materialization": {
          "const": "post_assignment_commit_derived"
        },
        "dispatch_claim_required_after_work_contract": {
          "const": true
        }
      }
    },
    "prospective_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_lease_required_at_intent",
        "active_lease_ref",
        "authority_grant_refs",
        "resource_reservation_required_at_intent",
        "resource_reservation_ref",
        "dispatch_authority_granted",
        "dispatch_admission_ref",
        "materialization_authority_granted",
        "external_effect_authority_granted",
        "bytes_may_cross_at_intent",
        "provider_spend_may_incur_at_intent"
      ],
      "properties": {
        "active_lease_required_at_intent": {
          "const": false
        },
        "active_lease_ref": {
          "type": "null"
        },
        "authority_grant_refs": {
          "type": "array",
          "maxItems": 0
        },
        "resource_reservation_required_at_intent": {
          "const": false
        },
        "resource_reservation_ref": {
          "type": "null"
        },
        "dispatch_authority_granted": {
          "const": false
        },
        "dispatch_admission_ref": {
          "type": "null"
        },
        "materialization_authority_granted": {
          "const": false
        },
        "external_effect_authority_granted": {
          "const": false
        },
        "bytes_may_cross_at_intent": {
          "const": false
        },
        "provider_spend_may_incur_at_intent": {
          "const": false
        }
      }
    },
    "canonical_collection_ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "set_like_string_arrays",
        "reference_arrays",
        "fixed_semantic_sequences",
        "unordered_input_disposition"
      ],
      "properties": {
        "set_like_string_arrays": {
          "const": "unicode_codepoint_ascending"
        },
        "reference_arrays": {
          "const": "id_then_version_then_digest_ascending"
        },
        "fixed_semantic_sequences": {
          "const": "schema_declared_prefix_order"
        },
        "unordered_input_disposition": {
          "const": "reject_before_identity"
        }
      }
    },
    "created_at": {
      "$ref": "#/$defs/work_intent_core_timestamp"
    },
    "created_by": {
      "$ref": "#/$defs/work_intent_core_principal"
    }
  },
  "$defs": {
    "work_intent_core_identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]+$"
    },
    "work_intent_core_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "work_intent_core_v02_source_view_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "id",
        "version",
        "schema_id",
        "schema_path",
        "schema_raw_digest",
        "candidate_path",
        "candidate_raw_digest",
        "candidate_bytes",
        "canonicalization_profile_ref",
        "canonical_digest",
        "identity_status",
        "admission_ref"
      ],
      "properties": {
        "record_type": {
          "const": "research_state_view"
        },
        "id": {
          "$ref": "#/$defs/work_intent_core_identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "schema_id": {
          "const": "urn:odeya:schema:research-state-view:0.8.0"
        },
        "schema_path": {
          "const": "schemas/research-state-view.schema.json"
        },
        "schema_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_schema_resource_digest",
            "subject": "schema_path sibling raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "exact_schema_binding"
          }
        },
        "candidate_path": {
          "const": "architecture/research-state-view-sentinel-candidate.json"
        },
        "candidate_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_file_digest",
            "subject": "candidate_path sibling raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "exact_candidate_subject_binding"
          }
        },
        "candidate_bytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 1048576
        },
        "canonicalization_profile_ref": {
          "$ref": "#/$defs/work_intent_core_profile_ref"
        },
        "canonical_digest": {
          "type": "null",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "subject": "referenced ResearchStateView candidate",
            "profile": "canonicalization_profile_ref sibling is unissued",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "not_constructible_until_profile_issuance_and_admission"
          }
        },
        "identity_status": {
          "const": "exact_raw_candidate_bound_profile_unissued_not_admitted"
        },
        "admission_ref": {
          "type": "null"
        }
      }
    },
    "work_intent_core_v02_planning_epoch_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "id",
        "version",
        "schema_id",
        "schema_path",
        "schema_raw_digest",
        "candidate_path",
        "candidate_raw_digest",
        "candidate_bytes",
        "canonicalization_profile_ref",
        "canonical_digest",
        "identity_status",
        "admission_ref"
      ],
      "properties": {
        "record_type": {
          "const": "planning_epoch"
        },
        "id": {
          "$ref": "#/$defs/work_intent_core_identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "schema_id": {
          "const": "urn:odeya:schema:planning-epoch:0.9.0"
        },
        "schema_path": {
          "const": "schemas/planning-epoch.schema.json"
        },
        "schema_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_schema_resource_digest",
            "subject": "schema_path sibling raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "exact_schema_binding"
          }
        },
        "candidate_path": {
          "const": "architecture/planning-epoch-sentinel-candidate.json"
        },
        "candidate_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_file_digest",
            "subject": "candidate_path sibling raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "exact_candidate_subject_binding"
          }
        },
        "candidate_bytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 1048576
        },
        "canonicalization_profile_ref": {
          "$ref": "#/$defs/work_intent_core_profile_ref"
        },
        "canonical_digest": {
          "type": "null",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "subject": "referenced PlanningEpoch candidate",
            "profile": "canonicalization_profile_ref sibling is unissued",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "not_constructible_until_profile_issuance_and_admission"
          }
        },
        "identity_status": {
          "const": "exact_raw_candidate_bound_profile_unissued_not_admitted"
        },
        "admission_ref": {
          "type": "null"
        }
      }
    },
    "work_intent_core_v02_output_schema_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "semantic_version",
        "schema_path",
        "schema_raw_digest",
        "schema_bytes",
        "dialect",
        "identity_status",
        "admission_ref"
      ],
      "properties": {
        "schema_id": {
          "const": "urn:odeya:schema:candidate-artifact:0.8.0"
        },
        "semantic_version": {
          "const": "0.1.0"
        },
        "schema_path": {
          "const": "schemas/candidate-artifact.schema.json"
        },
        "schema_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_schema_resource_digest",
            "subject": "schema_path sibling raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "schema_id sibling",
            "algorithm": "sha-256",
            "status": "exact_schema_binding"
          }
        },
        "schema_bytes": {
          "type": "integer",
          "minimum": 2,
          "maximum": 1048576
        },
        "dialect": {
          "const": "https://json-schema.org/draft/2020-12/schema"
        },
        "identity_status": {
          "const": "exact_schema_resource_raw_bytes_bound_not_admitted"
        },
        "admission_ref": {
          "type": "null"
        }
      }
    },
    "work_intent_core_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/work_intent_core_identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "model_run"
          ]
        }
      }
    },
    "work_intent_core_profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "profile_core_schema_id",
        "profile_core_raw_digest"
      ],
      "properties": {
        "profile_id": {
          "const": "urn:odeya:canonicalization:odeya-jcs-0.1"
        },
        "profile_version": {
          "const": "0.1.0"
        },
        "profile_core_schema_id": {
          "const": "urn:odeya:schema:canonicalization-profile-core:0.4.0"
        },
        "profile_core_raw_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "x-odeya-digest-scope": {
            "kind": "raw_file_digest",
            "subject": "architecture/canonicalization-profile-core-candidate.json raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "urn:odeya:schema:canonicalization-profile-core:0.4.0",
            "algorithm": "sha-256",
            "status": "candidate_profile_unissued"
          }
        }
      }
    }
  }
}
