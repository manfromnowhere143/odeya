        "silent_divergence_allowed"
      ],
      "properties": {
        "kind": {
          "enum": [
            "canonical_delivery_order",
            "reverse_delivery_order",
            "duplicate_delivery",
            "chunk_boundary_variation",
            "checkpoint_replay"
          ]
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "indeterminate",
            "not_run"
          ]
