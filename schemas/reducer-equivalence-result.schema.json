        "reason": {
          "const": "non_live_fixture_has_no_ledger_checkpoint"
        }
      }
    },
    "reducer_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_ref",
        "build_digest",
        "runtime_profile_ref",
