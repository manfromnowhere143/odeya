          "$ref": "#/$defs/identifier"
        },
        "stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "inclusive_global_position": {
          "type": "integer",
          "minimum": 0
        },
        "aggregate_id": {
          "$ref": "#/$defs/identifier"
        },
        "aggregate_version": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "live_checkpoint_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "checkpoint_ref",
        "ledger_point",
        "coverage",
        "witness_status"
      ],
      "properties": {
        "applicability": {
          "const": "applicable"
