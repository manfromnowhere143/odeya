{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:command-receipt:0.9.0",
  "title": "Odeya CommandReceipt",
  "description": "Closed structural candidate for immutable post-registry command settlement. This 0.4 resource is deliberately nonconstructible and not admitted while the exact CommandContractRecord and CommandContractRegistry identities remain unresolved; result and digest values in fixtures are comparison probes and do not assert that a receipt exists. A future admitted CommandReceipt may exist only after exact registry activation and standalone member resolution. Logical payload_type_id is distinct from schema resource, canonical, and closure identity; the member reference also separates dialect and source-blob identity. Schema validation does not prove admission, activation, membership, identity equality, currentness, evidence completeness, or external attestations, and a future schema-resource reissue is required before receipt construction can be admitted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "conformance_scope",
    "identity_resolution_status",
    "admission_status",
    "construction_status",
    "receipt_id",
    "command_id",
    "command_type",
    "command_version",
    "payload_type_id",
    "payload_schema_resource_id",
    "payload_schema_canonical_digest",
    "payload_schema_closure_digest",
    "command_registry_snapshot_ref",
    "command_registry_activation_ref",
    "command_contract_record_ref",
    "canonical_request_digest",
    "idempotency_scope",
    "actor_binding",
    "target_binding",
    "admission_evidence",
    "received_at",
    "settled_at",
    "result",
    "result_digest_contract",
    "result_digest",
    "replay_contract",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "const": "0.9.0"
    },
    "conformance_scope": {
      "const": "structural_fixture_only"
    },
    "identity_resolution_status": {
      "const": "unresolved_blocking"
    },
    "admission_status": {
      "const": "not_admitted"
    },
    "construction_status": {
      "const": "blocked_unresolved_command_contract_registry"
    },
    "receipt_id": {
      "$ref": "#/$defs/identifier"
    },
    "command_id": {
      "$ref": "#/$defs/identifier"
    },
    "command_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "command_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "payload_type_id": {
      "type": "string",
      "pattern": "^urn:odeya:command-payload:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "payload_schema_resource_id": {
      "type": "string",
      "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "payload_schema_canonical_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-payload-schema-canonical-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "payload_schema_closure_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-payload-schema-closure-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "command_registry_snapshot_ref": {
      "$ref": "#/$defs/command_registry_snapshot_reference"
    },
    "command_registry_activation_ref": {
      "$ref": "#/$defs/registry_activation_reference"
    },
    "command_contract_record_ref": {
      "$ref": "#/$defs/command_contract_record_reference"
    },
    "canonical_request_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-command-request-v2",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "idempotency_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "namespace"
      ],
      "properties": {
        "tenant_id": {
          "$ref": "#/$defs/identifier"
        },
        "namespace": {
          "enum": [
            "portfolio",
            "authority",
            "research",
            "publication",
            "operations",
            "learning",
            "data_governance",
            "recovery"
          ]
        }
      }
    },
    "actor_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type",
        "execution_identity"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "model_run",
            "instrument",
            "external_system"
          ]
        },
        "execution_identity": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "target_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stream_id",
        "stream_type",
        "expected_stream_position",
        "aggregate_type",
        "aggregate_id",
        "expected_aggregate_version"
      ],
      "properties": {
        "stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "stream_type": {
          "enum": [
            "portfolio",
            "proposal",
            "mission",
            "authority_root",
            "incident",
            "learning",
            "data_governance",
            "recovery"
          ]
        },
        "expected_stream_position": {
          "type": "integer",
          "minimum": -1
        },
        "aggregate_type": {
          "$ref": "#/$defs/identifier"
        },
        "aggregate_id": {
          "$ref": "#/$defs/identifier"
        },
        "expected_aggregate_version": {
          "type": "integer",
          "minimum": -1
        }
      }
    },
    "admission_evidence": {
      "$ref": "#/$defs/admission_evidence"
    },
    "received_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "settled_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "result": {
      "oneOf": [
        {
          "$ref": "#/$defs/accepted_result"
        },
        {
          "$ref": "#/$defs/rejected_result"
        },
        {
          "$ref": "#/$defs/noop_result"
        }
      ]
    },
    "result_digest_contract": {
      "$ref": "#/$defs/result_digest_contract"
    },
    "result_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-command-result-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "replay_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "lookup_key",
        "changed_digest_behavior",
        "retention_policy_ref"
      ],
      "properties": {
        "mode": {
          "const": "return_exact_bound_result"
        },
        "lookup_key": {
          "const": "idempotency_scope+command_id"
        },
        "changed_digest_behavior": {
          "const": "reject_command_id_reuse"
        },
        "retention_policy_ref": {
          "$ref": "#/$defs/versioned_identity"
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "receipt_digest_contract",
        "receipt_digest",
        "signature_ref"
      ],
      "properties": {
        "canonicalization": {
          "const": "odeya-jcs-draft-0.1"
        },
        "receipt_digest_contract": {
          "$ref": "#/$defs/receipt_digest_contract"
        },
        "receipt_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-receipt-v2",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "signature_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/artifact_reference"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "command_registry_snapshot_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "registry_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "schema_id": {
          "const": "urn:odeya:schema:command-contract-registry:0.6.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-contract-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "registry_activation_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activation_id",
        "activation_sequence",
        "schema_id",
        "activation_digest",
        "p0_prerequisite_id",
        "p0_admission_digest"
      ],
      "properties": {
        "activation_id": {
          "$ref": "#/$defs/identifier"
        },
        "activation_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:registry-activation:0.6.0"
        },
        "activation_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-registry-activation-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "p0_prerequisite_id": {
          "const": "P0.constitutional-recovery-admission"
        },
        "p0_admission_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-p0-constitutional-recovery-admission-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "command_contract_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "version",
        "schema_id",
        "digest",
        "registry_snapshot_digest",
        "command_type",
        "command_version",
        "payload_type_id",
        "payload_schema_resource_id",
        "payload_schema_dialect_id",
        "payload_schema_blob_digest",
        "payload_schema_canonical_digest",
        "payload_schema_closure_digest",
        "membership_proof_ref"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:command-contract-record:0.5.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-contract-record-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "registry_snapshot_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-contract-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "command_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
        },
        "command_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "payload_type_id": {
          "type": "string",
          "pattern": "^urn:odeya:command-payload:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "payload_schema_resource_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "payload_schema_dialect_id": {
          "const": "https://json-schema.org/draft/2020-12/schema"
        },
        "payload_schema_blob_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "schema blob bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "payload_schema_canonical_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-payload-schema-canonical-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "payload_schema_closure_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-payload-schema-closure-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "membership_proof_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "admission_evidence_bundle_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:admission-evidence-bundle:0.7.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-admission-evidence-bundle-v2",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "policy_decision_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:policy-decision:0.7.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-policy-decision-v2",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "validation_result_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:validation-result:0.4.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "semantic_rule_registry_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "schema_id": {
          "const": "urn:odeya:schema:validation-rule-registry:0.4.0"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-validation-rule-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "admission_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_ref",
        "evidence_profile_ref",
        "evaluation_frontier_digest",
        "policy_decision_refs",
        "validation_result_refs",
        "semantic_rule_registry_snapshot_ref"
      ],
      "properties": {
        "bundle_ref": {
          "$ref": "#/$defs/admission_evidence_bundle_reference"
        },
        "evidence_profile_ref": {
          "$ref": "#/$defs/versioned_identity"
        },
        "evaluation_frontier_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-evaluation-frontier-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "policy_decision_refs": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/policy_decision_reference"
          }
        },
        "validation_result_refs": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/validation_result_reference"
          }
        },
        "semantic_rule_registry_snapshot_ref": {
          "$ref": "#/$defs/semantic_rule_registry_reference"
        }
      }
    },
    "result_digest_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "domain_separator",
        "canonicalization_profile_ref",
        "included_json_pointers",
        "excluded_json_pointers"
      ],
      "properties": {
        "algorithm": {
          "const": "sha-256"
        },
        "domain_separator": {
          "const": "odeya-command-result-v1"
        },
        "canonicalization_profile_ref": {
          "$ref": "#/$defs/versioned_identity"
        },
        "included_json_pointers": {
          "const": [
            "/result"
          ]
        },
        "excluded_json_pointers": {
          "const": []
        }
      }
    },
    "receipt_digest_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "domain_separator",
        "canonicalization_profile_ref",
        "included_json_pointers",
        "excluded_json_pointers"
      ],
      "properties": {
        "algorithm": {
          "const": "sha-256"
        },
        "domain_separator": {
          "const": "odeya-command-receipt-v2"
        },
        "canonicalization_profile_ref": {
          "$ref": "#/$defs/versioned_identity"
        },
        "included_json_pointers": {
          "const": [
            "/schema_version",
            "/conformance_scope",
            "/identity_resolution_status",
            "/admission_status",
            "/construction_status",
            "/receipt_id",
            "/command_id",
            "/command_type",
            "/command_version",
            "/payload_type_id",
            "/payload_schema_resource_id",
            "/payload_schema_canonical_digest",
            "/payload_schema_closure_digest",
            "/command_registry_snapshot_ref",
            "/command_registry_activation_ref",
            "/command_contract_record_ref",
            "/canonical_request_digest",
            "/idempotency_scope",
            "/actor_binding",
            "/target_binding",
            "/admission_evidence",
            "/received_at",
            "/settled_at",
            "/result",
            "/result_digest_contract",
            "/result_digest",
            "/replay_contract",
            "/integrity/canonicalization",
            "/integrity/receipt_digest_contract"
          ]
        },
        "excluded_json_pointers": {
          "const": [
            "/integrity/receipt_digest",
            "/integrity/signature_ref"
          ]
        }
      }
    },
    "versioned_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "digest"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "stream_id",
        "stream_position",
        "event_digest"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/identifier"
        },
        "stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "stream_position": {
          "type": "integer",
          "minimum": 0
        },
        "event_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-research-event-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "stream_head": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stream_id",
        "position",
        "event_digest"
      ],
      "properties": {
        "stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "position": {
          "type": "integer",
          "minimum": 0
        },
        "event_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-research-event-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "accepted_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "commit_id",
        "events",
        "stream_heads"
      ],
      "properties": {
        "kind": {
          "const": "accepted"
        },
        "commit_id": {
          "$ref": "#/$defs/identifier"
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/event_reference"
          }
        },
        "stream_heads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stream_head"
          }
        }
      }
    },
    "rejected_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "rejection_code",
        "admission_stage",
        "reason_ref"
      ],
      "properties": {
        "kind": {
          "const": "rejected"
        },
        "rejection_code": {
          "enum": [
            "schema_unresolvable",
            "schema_invalid",
            "stale_stream_position",
            "stale_aggregate_version",
            "reference_unresolvable",
            "artifact_inadmissible",
            "rights_denied",
            "data_use_missing",
            "data_use_denied",
            "data_use_indeterminate",
            "data_use_expired",
            "data_use_revoked",
            "exposure_intent_missing",
            "provider_configuration_unverified",
            "dispatch_frontier_stale",
            "policy_denied",
            "authority_missing",
            "authority_conflict",
            "grant_expired",
            "grant_revoked",
            "grant_exhausted",
            "grant_consumption_point_mismatch",
            "grant_reservation_missing",
            "grant_reservation_mismatch",
            "grant_reservation_expired",
            "grant_reservation_released",
            "grant_reservation_cancelled",
            "dispatch_already_claimed",
            "budget_exceeded",
            "risk_gate_failed",
            "blocker_open",
            "illegal_transition",
            "external_effect_ambiguous"
          ]
        },
        "admission_stage": {
          "enum": [
            "registry",
            "idempotency",
            "structure",
            "concurrency",
            "references",
            "rights",
            "policy",
            "authority",
            "resources",
            "state_transition",
            "external_effect"
          ]
        },
        "reason_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "noop_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason_code",
        "stream_heads"
      ],
      "properties": {
        "kind": {
          "const": "noop"
        },
        "reason_code": {
          "enum": [
            "already_in_requested_state",
            "duplicate_fact",
            "withdrawal_already_settled"
          ]
        },
        "stream_heads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stream_head"
          }
        }
      }
    }
  }
}
