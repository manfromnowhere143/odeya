{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:external-effect-authorize-command:0.6.0",
  "x-odeya-command-payload-id": "urn:odeya:command-payload:external_effect.authorize:1.0.0",
  "title": "Authorize External Effect Command Payload",
  "description": "Exact T1 request inputs. Admission creates the effect intent and kernel-derived dispatch-bound grant-use reservation; the caller cannot supply a reservation, grant-use fact, event identity, or settlement. Governed processing dispatch additionally binds exact typed work-contract, data-use, exposure-intent, provider-configuration, source-frontier, purpose, recipient, provider, region, policy, authority, and resource inputs. JSON Schema does not prove those inputs are current; admission must re-resolve and recheck them at the commit position.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "effect_id",
    "effect_class",
    "operation",
    "effect_payload_ref",
    "target_descriptor_ref",
    "provider_profile_ref",
    "grant_refs",
    "resource_reservation_request_ref",
    "reservation_not_after",
    "provider_idempotency_key_digest",
    "authorization_inputs_digest",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.6.0"
    },
    "effect_id": {
      "$ref": "#/$defs/identifier"
    },
    "effect_class": {
      "enum": [
        "publication",
        "message",
        "governed_processing_dispatch",
        "repository_write",
        "payment",
        "physical_action",
        "provider_mutation"
      ]
    },
    "operation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "effect_payload_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "target_descriptor_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "provider_profile_ref": {
      "$ref": "#/$defs/versioned_identity"
    },
    "grant_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "resource_reservation_request_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "reservation_not_after": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "provider_idempotency_key_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "byte_digest",
        "subject": "exact key bytes",
        "algorithm": "sha-256",
        "profile": "not_a_canonical_object_digest",
        "status": "accepted_disposition_annotation"
      }
    },
    "authorization_inputs_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-authorization-input-snapshot-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "work_contract_ref": {
      "$ref": "#/$defs/work_contract_reference"
    },
    "data_use_decision_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/data_use_decision_reference"
      }
    },
    "data_exposure_intent_ref": {
      "$ref": "#/$defs/data_exposure_intent_reference"
    },
    "provider_configuration_observation_ref": {
      "$ref": "#/$defs/provider_configuration_observation_reference"
    },
    "dispatch_frontier": {
      "$ref": "#/$defs/dispatch_frontier"
    },
    "dispatch_binding": {
      "$ref": "#/$defs/dispatch_binding"
    },
    "current_policy_inputs_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-authorization-input-snapshot-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "current_authority_inputs_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-authorization-input-snapshot-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "current_resource_inputs_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-authorization-input-snapshot-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "effect_class": {
            "const": "governed_processing_dispatch"
          }
        },
        "required": [
          "effect_class"
        ]
      },
      "then": {
        "required": [
          "work_contract_ref",
          "data_use_decision_refs",
          "data_exposure_intent_ref",
          "provider_configuration_observation_ref",
          "dispatch_frontier",
          "dispatch_binding",
          "current_policy_inputs_digest",
          "current_authority_inputs_digest",
          "current_resource_inputs_digest"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "work_contract_ref"
              ]
            },
            {
              "required": [
                "data_use_decision_refs"
              ]
            },
            {
              "required": [
                "data_exposure_intent_ref"
              ]
            },
            {
              "required": [
                "provider_configuration_observation_ref"
              ]
            },
            {
              "required": [
                "dispatch_frontier"
              ]
            },
            {
              "required": [
                "dispatch_binding"
              ]
            },
            {
              "required": [
                "current_policy_inputs_digest"
              ]
            },
            {
              "required": [
                "current_authority_inputs_digest"
              ]
            },
            {
              "required": [
                "current_resource_inputs_digest"
              ]
            }
          ]
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "schema_bound_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest",
        "artifact_ref"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        },
        "artifact_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "work_contract_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/schema_bound_record_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:work-contract:0.1.0"
            }
          },
          "required": [
            "schema_id"
          ]
        }
      ]
    },
    "data_use_decision_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/schema_bound_record_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:data-use-decision:0.3.0"
            }
          },
          "required": [
            "schema_id"
          ]
        }
      ]
    },
    "data_exposure_intent_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/schema_bound_record_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:data-exposure-record:0.3.0"
            }
          },
          "required": [
            "schema_id"
          ]
        }
      ]
    },
    "ledger_checkpoint_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/schema_bound_record_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:ledger-checkpoint:0.7.0"
            }
          },
          "required": [
            "schema_id"
          ]
        }
      ]
    },
    "provider_configuration_observation_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type",
        "observation_kind"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "const": "application/json"
        },
        "observation_kind": {
          "const": "provider_configuration"
        }
      }
    },
    "dispatch_frontier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_stream_id",
        "source_ledger_epoch_id",
        "source_position",
        "checkpoint_ref",
        "checkpoint_position"
      ],
      "properties": {
        "source_stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "source_ledger_epoch_id": {
          "$ref": "#/$defs/identifier"
        },
        "source_position": {
          "type": "integer",
          "minimum": 0
        },
        "checkpoint_ref": {
          "$ref": "#/$defs/ledger_checkpoint_reference"
        },
        "checkpoint_position": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dispatch_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose_id",
        "purpose_version",
        "mission_id",
        "stage_id",
        "protocol_digest",
        "recipient_id",
        "recipient_class",
        "provider_id",
        "provider_profile_digest",
        "model_identity",
        "geographic_region",
        "residency_zone",
        "projected_payload_digest",
        "binding_digest"
      ],
      "properties": {
        "purpose_id": {
          "$ref": "#/$defs/identifier"
        },
        "purpose_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "mission_id": {
          "$ref": "#/$defs/identifier"
        },
        "stage_id": {
          "$ref": "#/$defs/identifier"
        },
        "protocol_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-protocol-snapshot-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "recipient_id": {
          "$ref": "#/$defs/identifier"
        },
        "recipient_class": {
          "enum": [
            "human",
            "organization",
            "deterministic_service",
            "model_service",
            "provider",
            "instrument"
          ]
        },
        "provider_id": {
          "$ref": "#/$defs/identifier"
        },
        "provider_profile_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-provider-profile-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "model_identity": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "geographic_region": {
          "$ref": "#/$defs/identifier"
        },
        "residency_zone": {
          "$ref": "#/$defs/identifier"
        },
        "projected_payload_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "projected payload bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "binding_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-dispatch-binding-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "versioned_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "digest"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    }
  }
}
