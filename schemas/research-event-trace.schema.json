  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "versioned_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "digest"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "event_id",
        "event_type",
        "event_version",
        "stream_position",
        "aggregate_type",
        "aggregate_id",
        "aggregate_version",
        "event_digest",
        "expected_axis_changes"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "event_id": {
          "$ref": "#/$defs/identifier"
        },
        "event_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
        },
        "event_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "stream_position": {
          "type": "integer",
          "minimum": 0
        },
        "aggregate_type": {
          "$ref": "#/$defs/identifier"
        },
        "aggregate_id": {
          "$ref": "#/$defs/identifier"
        },
        "aggregate_version": {
          "type": "integer",
          "minimum": 0
        },
        "event_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-research-event-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
