{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:research-event-trace:0.4.0",
  "title": "Odeya ResearchEvent Replay Trace",
  "description": "Architecture-time replay vector binding an ordered event sequence to expected scientific, authority, data-governance, and recovery axes plus forbidden inferences. Relational ordering, event identity, and reducer correctness still require independent semantic validators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "purpose",
    "stream_id",
    "stream_type",
    "mission_scope",
    "reducer_set",
    "steps",
    "expected_state",
    "forbidden_inferences"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "trace_id": {
      "$ref": "#/$defs/identifier"
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "stream_id": {
      "$ref": "#/$defs/identifier"
    },
    "stream_type": {
      "enum": [
        "portfolio",
        "proposal",
        "mission",
        "authority_root",
        "incident",
        "learning",
        "data_governance",
        "recovery"
      ]
    },
    "mission_scope": {
      "oneOf": [
        {
          "$ref": "#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "reducer_set": {
      "$ref": "#/$defs/versioned_identity"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "command_attempts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/command_attempt_observation"
      }
    },
    "expected_state": {
      "$ref": "#/$defs/expected_state"
    },
    "forbidden_inferences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    }
  },
