    "command_attempt_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_type",
        "command_schema_id",
        "canonical_request_digest",
        "source_stream_position",
        "receipt_ref",
        "admission_result",
        "rejection_code",
        "grant_use_reservation_committed",
        "grant_use_committed",
        "external_effect_authorization_committed",
        "external_effect_start_committed",
        "resource_spend_committed"
      ],
      "properties": {
        "command_id": {
          "$ref": "#/$defs/identifier"
        },
        "command_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
        },
        "command_schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:command-payload:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "canonical_request_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-command-request-v2",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "source_stream_position": {
          "type": "integer",
          "minimum": -1
        },
        "receipt_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "receipt_id",
            "schema_id",
            "digest"
          ],
          "properties": {
            "receipt_id": {
              "$ref": "#/$defs/identifier"
            },
            "schema_id": {
              "const": "urn:odeya:schema:command-receipt:0.3.0"
            },
            "digest": {
              "$ref": "#/$defs/digest"
            }
          }
        },
        "admission_result": {
          "enum": [
            "accepted",
            "rejected",
            "noop"
          ]
        },
        "rejection_code": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "grant_use_reservation_committed": {
          "type": "boolean"
        },
        "grant_use_committed": {
          "type": "boolean"
        },
        "external_effect_authorization_committed": {
          "type": "boolean"
        },
        "external_effect_start_committed": {
          "type": "boolean"
        },
        "resource_spend_committed": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "admission_result": {
                "const": "rejected"
              }
            },
            "required": [
              "admission_result"
            ]
          },
          "then": {
            "properties": {
              "rejection_code": {
                "$ref": "#/$defs/identifier"
              },
              "grant_use_reservation_committed": {
                "const": false
              },
              "grant_use_committed": {
                "const": false
              },
              "external_effect_authorization_committed": {
                "const": false
              },
              "external_effect_start_committed": {
                "const": false
              },
              "resource_spend_committed": {
                "const": false
              }
            }
          },
          "else": {
            "properties": {
              "rejection_code": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
