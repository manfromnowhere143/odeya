{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:handoff:0.3.0",
  "title": "Odeya Handoff",
  "description": "An immutable recovery packet at an exact ledger position. It contains reconstructible facts and next legal actions, not private reasoning. Freshness and reference integrity require semantic validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_id",
    "version",
    "mission_id",
    "mode",
    "source_checkpoint",
    "mission_state",
    "protocol_snapshot",
    "run_manifest_refs",
    "claim_refs",
    "publication_manifest_refs",
    "active_lease_refs",
    "open_blocker_refs",
    "unresolved_integrity_incident_refs",
    "dispatchable_effect_refs",
    "ambiguous_effect_refs",
    "authority_assignment_refs",
    "resource_ledger_ref",
    "artifact_checkpoint_ref",
    "aggregate_heads",
    "pending_decisions",
    "next_legal_actions",
    "recipient",
    "canonical_payload_digest",
    "prepared_at",
    "prepared_by",
    "reviewed_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "handoff_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "mission_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "enum": [
        "pause",
        "transfer",
        "close",
        "interruption"
      ]
    },
    "source_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_position",
        "event_checkpoint_digest",
        "captured_at"
      ],
      "properties": {
        "ledger_position": {
          "type": "integer",
          "minimum": 0
        },
        "event_checkpoint_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-ledger-checkpoint-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
        }
      }
    },
    "mission_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle",
        "operational",
        "scientific_validity",
        "measurement",
        "verification",
        "publication"
      ],
      "properties": {
        "lifecycle": {
          "enum": [
            "intake",
            "orient",
            "contract",
            "preregister",
            "preflight",
            "execute",
            "verify",
            "review",
            "adjudicate",
            "handoff",
            "learn",
            "closed"
          ]
        },
        "operational": {
          "enum": [
            "ready",
            "running",
            "paused",
            "interrupted",
            "blocked",
            "rights_blocked",
            "infrastructure_failure",
            "complete"
          ]
        },
        "scientific_validity": {
          "enum": [
            "not_assessed",
            "valid",
            "invalid"
          ]
        },
        "measurement": {
          "enum": [
            "not_assessed",
            "valid_measurement",
            "no_valid_measurement",
            "not_applicable"
          ]
        },
        "verification": {
          "enum": [
            "not_requested",
            "running",
            "confirmed",
            "rejected",
            "inconclusive",
            "invalid",
            "blocked",
            "disputed"
          ]
        },
        "publication": {
          "enum": [
            "not_requested",
            "candidate",
            "denied",
            "authorized",
            "sealed",
            "release_pending",
            "released",
            "correction_pending",
            "withdrawn"
          ]
        }
      }
    },
    "protocol_snapshot": {
      "oneOf": [
        {
          "$ref": "#/$defs/protocol_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "run_manifest_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "claim_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/claim_reference"
      }
    },
    "publication_manifest_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "active_lease_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "open_blocker_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "unresolved_integrity_incident_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "dispatchable_effect_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "ambiguous_effect_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "authority_assignment_refs": {
      "$ref": "#/$defs/identifier_array"
    },
    "resource_ledger_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "artifact_checkpoint_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "aggregate_heads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "aggregate_type",
          "aggregate_id",
          "position",
          "head_digest"
        ],
        "properties": {
          "aggregate_type": {
            "$ref": "#/$defs/identifier"
          },
          "aggregate_id": {
            "$ref": "#/$defs/identifier"
          },
          "position": {
            "type": "integer",
            "minimum": 0
          },
          "head_digest": {
            "$ref": "#/$defs/digest",
            "x-odeya-digest-scope": {
              "kind": "canonical_object_digest",
              "domain": "odeya-research-event-v1",
              "algorithm": "sha-256",
              "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
              "status": "registered_domain"
            }
          }
        }
      }
    },
    "pending_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_type",
          "subject_id",
          "required_authority_role",
          "blocking"
        ],
        "properties": {
          "decision_type": {
            "$ref": "#/$defs/identifier"
          },
          "subject_id": {
            "$ref": "#/$defs/identifier"
          },
          "required_authority_role": {
            "enum": [
              "proposal",
              "protocol",
              "safety",
              "data_rights",
              "resource",
              "execution",
              "verification",
              "outcome",
              "publication"
            ]
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "next_legal_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_type",
          "subject_id",
          "required_authority_role",
          "precondition_validation_ref"
        ],
        "properties": {
          "command_type": {
            "$ref": "#/$defs/identifier"
          },
          "subject_id": {
            "$ref": "#/$defs/identifier"
          },
          "required_authority_role": {
            "enum": [
              "proposal",
              "protocol",
              "safety",
              "data_rights",
              "resource",
              "execution",
              "verification",
              "outcome",
              "publication"
            ]
          },
          "precondition_validation_ref": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "recipient": {
      "oneOf": [
        {
          "$ref": "#/$defs/principal"
        },
        {
          "type": "null"
        }
      ]
    },
    "canonical_payload_digest": {
      "$ref": "#/$defs/digest"
    },
    "prepared_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "prepared_by": {
      "$ref": "#/$defs/execution_identity"
    },
    "reviewed_by": {
      "oneOf": [
        {
          "$ref": "#/$defs/human_principal"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "close"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "mission_state": {
            "properties": {
              "lifecycle": {
                "const": "closed"
              }
            }
          },
          "active_lease_refs": {
            "maxItems": 0
          },
          "open_blocker_refs": {
            "maxItems": 0
          },
          "unresolved_integrity_incident_refs": {
            "maxItems": 0
          },
          "dispatchable_effect_refs": {
            "maxItems": 0
          },
          "ambiguous_effect_refs": {
            "maxItems": 0
          },
          "pending_decisions": {
            "maxItems": 0
          },
          "next_legal_actions": {
            "maxItems": 0
          },
          "recipient": {
            "type": "null"
          },
          "reviewed_by": {
            "$ref": "#/$defs/human_principal"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "transfer"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "recipient": {
            "$ref": "#/$defs/principal"
          },
          "reviewed_by": {
            "$ref": "#/$defs/human_principal"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "identifier_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocol_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_snapshot_id",
        "version",
        "digest"
      ],
      "properties": {
        "protocol_snapshot_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "claim_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "version",
        "digest"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "service",
            "organization"
          ]
        }
      }
    },
    "human_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "const": "human"
        }
      }
    },
    "execution_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "execution_id",
        "code_digest",
        "environment_digest"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "execution_id": {
          "$ref": "#/$defs/identifier"
        },
        "code_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "source or code-bundle bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "environment_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-environment-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    }
  }
}
