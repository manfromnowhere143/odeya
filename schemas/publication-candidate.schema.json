{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:publication-candidate:0.1.0",
  "title": "Odeya PublicationCandidate",
  "description": "An immutable proposed disclosure projection. It carries neither a publication decision nor an authority grant; its canonical digest is computed externally and is what a later human decision binds.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "candidate_id", "version", "mission_id",
    "source_ledger_position", "claim_versions", "evidence_package",
    "rendered_artifacts", "visibility", "audience", "embargo_until",
    "destinations", "redactions", "omitted_private_dependencies",
    "decision_inputs", "canonical_release_payload_digest",
    "correction_and_withdrawal", "compiler", "expires_at", "created_at",
    "created_by"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "candidate_id": { "$ref": "#/$defs/identifier" },
    "version": { "type": "integer", "minimum": 1 },
    "mission_id": { "$ref": "#/$defs/identifier" },
    "source_ledger_position": { "type": "integer", "minimum": 0 },
    "claim_versions": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/claim_reference" }
    },
    "evidence_package": { "$ref": "#/$defs/artifact_reference" },
    "rendered_artifacts": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "$ref": "#/$defs/artifact_reference" }
    },
    "visibility": { "enum": ["private", "restricted", "embargoed", "public"] },
    "audience": { "$ref": "#/$defs/nonempty_unique_strings" },
    "embargo_until": { "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }] },
    "destinations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["channel_class", "channel_id", "destination", "geographic_region", "adapter_profile_ref"],
        "properties": {
          "channel_class": { "enum": ["private_package", "controlled_portal", "website", "repository", "paper_archive", "message", "other"] },
          "channel_id": { "$ref": "#/$defs/identifier" },
          "destination": { "type": "string", "minLength": 1 },
          "geographic_region": { "$ref": "#/$defs/identifier" },
          "adapter_profile_ref": { "$ref": "#/$defs/versioned_reference" }
        }
      }
    },
    "redactions": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["target_artifact_id", "selector", "reason_code", "replacement_digest", "scientific_consequence"],
        "properties": {
          "target_artifact_id": { "$ref": "#/$defs/identifier" },
          "selector": { "type": "string", "minLength": 1 },
          "reason_code": { "$ref": "#/$defs/identifier" },
          "replacement_digest": { "$ref": "#/$defs/digest" },
          "scientific_consequence": { "enum": ["none", "reproducibility_narrowed", "verification_private_only", "claim_scope_narrowed"] }
        }
      }
    },
    "omitted_private_dependencies": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["dependency_ref", "reason_code", "public_limitation"],
        "properties": {
          "dependency_ref": { "$ref": "#/$defs/artifact_reference" },
          "reason_code": { "$ref": "#/$defs/identifier" },
          "public_limitation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_inputs": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence", "rights", "privacy", "safety", "security", "contributors", "wording"],
      "properties": {
        "evidence": { "$ref": "#/$defs/artifact_reference" },
        "rights": { "$ref": "#/$defs/artifact_reference" },
        "privacy": { "$ref": "#/$defs/artifact_reference" },
        "safety": { "$ref": "#/$defs/artifact_reference" },
        "security": { "$ref": "#/$defs/artifact_reference" },
        "contributors": { "$ref": "#/$defs/artifact_reference" },
        "wording": { "$ref": "#/$defs/artifact_reference" }
      }
    },
    "canonical_release_payload_digest": { "$ref": "#/$defs/digest" },
    "correction_and_withdrawal": {
      "type": "object", "additionalProperties": false,
      "required": ["correction_endpoint", "correction_support", "withdrawal_support", "read_back_support", "declared_limitations"],
      "properties": {
        "correction_endpoint": { "type": "string", "format": "uri" },
        "correction_support": { "enum": ["supported", "unsupported", "unknown"] },
        "withdrawal_support": { "enum": ["supported", "unsupported", "unknown"] },
        "read_back_support": { "enum": ["exact_bytes", "registered_semantic_oracle", "unsupported", "unknown"] },
        "declared_limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "compiler": {
      "type": "object", "additionalProperties": false,
      "required": ["rule_ref", "code_digest", "environment_digest", "execution_identity"],
      "properties": {
        "rule_ref": { "$ref": "#/$defs/versioned_reference" },
        "code_digest": { "$ref": "#/$defs/digest" },
        "environment_digest": { "$ref": "#/$defs/digest" },
        "execution_identity": { "$ref": "#/$defs/identifier" }
      }
    },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "created_by": { "$ref": "#/$defs/principal" }
  },
  "allOf": [
    {
      "if": { "properties": { "visibility": { "const": "public" } }, "required": ["visibility"] },
      "then": { "properties": { "audience": { "contains": { "const": "public" } } } }
    },
    {
      "if": { "properties": { "visibility": { "const": "embargoed" } }, "required": ["visibility"] },
      "then": { "properties": { "embargo_until": { "$ref": "#/$defs/timestamp" } } },
      "else": { "properties": { "embargo_until": { "type": "null" } } }
    }
  ],
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$" },
    "artifact_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "digest", "media_type"],
      "properties": { "artifact_id": { "$ref": "#/$defs/identifier" }, "digest": { "$ref": "#/$defs/digest" }, "media_type": { "type": "string", "minLength": 1 } }
    },
    "claim_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["claim_id", "version", "digest"],
      "properties": { "claim_id": { "$ref": "#/$defs/identifier" }, "version": { "type": "integer", "minimum": 1 }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "versioned_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "principal": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": { "principal_id": { "$ref": "#/$defs/identifier" }, "principal_type": { "enum": ["human", "deterministic_service"] } }
    },
    "nonempty_unique_strings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
