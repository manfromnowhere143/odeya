{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:publication-decision:0.1.0",
  "title": "Odeya PublicationDecision",
  "description": "A human publication decision over one exact PublicationCandidate digest. Authorization requires an explicit passing check and human approval for every founding gate; this decision is not a manifest or dispatch grant.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "decision_id", "version", "mission_id", "candidate",
    "decision", "gates", "authorization_scope", "conflicts", "quorum",
    "reason_codes", "publication_assignment_ref", "seal_rule_ref",
    "decision_evidence", "decided_at_ledger_position", "decided_at", "decided_by"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "decision_id": { "$ref": "#/$defs/identifier" },
    "version": { "type": "integer", "minimum": 1 },
    "mission_id": { "$ref": "#/$defs/identifier" },
    "candidate": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_id", "version", "candidate_digest", "schema_id"],
      "properties": {
        "candidate_id": { "$ref": "#/$defs/identifier" },
        "version": { "type": "integer", "minimum": 1 },
        "candidate_digest": { "$ref": "#/$defs/digest" },
        "schema_id": { "const": "urn:odeya:schema:publication-candidate:0.1.0" }
      }
    },
    "decision": { "enum": ["authorized", "denied", "indeterminate"] },
    "gates": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence", "rights", "privacy", "safety", "security", "contributors", "wording"],
      "properties": {
        "evidence": { "$ref": "#/$defs/gate_disposition" },
        "rights": { "$ref": "#/$defs/gate_disposition" },
        "privacy": { "$ref": "#/$defs/gate_disposition" },
        "safety": { "$ref": "#/$defs/gate_disposition" },
        "security": { "$ref": "#/$defs/gate_disposition" },
        "contributors": { "$ref": "#/$defs/gate_disposition" },
        "wording": { "$ref": "#/$defs/gate_disposition" }
      }
    },
    "authorization_scope": {
      "oneOf": [
        { "$ref": "#/$defs/authorization_scope" },
        { "type": "null" }
      ]
    },
    "conflicts": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["principal_id", "conflict_type", "disposition", "evidence_ref"],
        "properties": {
          "principal_id": { "$ref": "#/$defs/identifier" },
          "conflict_type": { "type": "string", "minLength": 1 },
          "disposition": { "enum": ["recused", "accepted_under_policy", "unresolved"] },
          "evidence_ref": { "$ref": "#/$defs/artifact_reference" }
        }
      }
    },
    "quorum": {
      "type": "object", "additionalProperties": false,
      "required": ["required_count", "reviewers", "distinct_effective_principals"],
      "properties": {
        "required_count": { "type": "integer", "minimum": 1 },
        "reviewers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/human_principal" } },
        "distinct_effective_principals": { "type": "boolean" }
      }
    },
    "reason_codes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
    "publication_assignment_ref": { "$ref": "#/$defs/immutable_reference" },
    "seal_rule_ref": { "$ref": "#/$defs/versioned_reference" },
    "decision_evidence": { "$ref": "#/$defs/artifact_reference" },
    "decided_at_ledger_position": { "type": "integer", "minimum": 0 },
    "decided_at": { "$ref": "#/$defs/timestamp" },
    "decided_by": { "$ref": "#/$defs/human_principal" }
  },
  "allOf": [
    {
      "if": { "properties": { "decision": { "const": "authorized" } }, "required": ["decision"] },
      "then": {
        "properties": {
          "authorization_scope": { "$ref": "#/$defs/authorization_scope" },
          "gates": {
            "properties": {
              "evidence": { "$ref": "#/$defs/passing_gate" },
              "rights": { "$ref": "#/$defs/passing_gate" },
              "privacy": { "$ref": "#/$defs/passing_gate" },
              "safety": { "$ref": "#/$defs/passing_gate" },
              "security": { "$ref": "#/$defs/passing_gate" },
              "contributors": { "$ref": "#/$defs/passing_gate" },
              "wording": { "$ref": "#/$defs/passing_gate" }
            }
          },
          "conflicts": { "not": { "contains": { "properties": { "disposition": { "const": "unresolved" } }, "required": ["disposition"] } } },
          "quorum": { "properties": { "distinct_effective_principals": { "const": true } } }
        }
      },
      "else": { "properties": { "authorization_scope": { "type": "null" } } }
    },
    {
      "if": { "properties": { "decision": { "const": "denied" } }, "required": ["decision"] },
      "then": {
        "properties": {
          "gates": {
            "anyOf": [
              { "properties": { "evidence": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "rights": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "privacy": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "safety": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "security": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "contributors": { "$ref": "#/$defs/rejecting_gate" } } },
              { "properties": { "wording": { "$ref": "#/$defs/rejecting_gate" } } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "decision": { "const": "indeterminate" } }, "required": ["decision"] },
      "then": {
        "properties": {
          "gates": {
            "anyOf": [
              { "properties": { "evidence": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "rights": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "privacy": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "safety": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "security": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "contributors": { "$ref": "#/$defs/indeterminate_gate" } } },
              { "properties": { "wording": { "$ref": "#/$defs/indeterminate_gate" } } }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$" },
    "human_principal": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": { "principal_id": { "$ref": "#/$defs/identifier" }, "principal_type": { "const": "human" } }
    },
    "artifact_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "digest", "media_type"],
      "properties": { "artifact_id": { "$ref": "#/$defs/identifier" }, "digest": { "$ref": "#/$defs/digest" }, "media_type": { "type": "string", "minLength": 1 } }
    },
    "immutable_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "integer", "minimum": 1 }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "versioned_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "gate_disposition": {
      "type": "object", "additionalProperties": false,
      "required": ["check_result_ref", "check_disposition", "human_reviewer", "human_disposition", "limitations"],
      "properties": {
        "check_result_ref": { "$ref": "#/$defs/artifact_reference" },
        "check_disposition": { "enum": ["pass", "fail", "indeterminate"] },
        "human_reviewer": { "$ref": "#/$defs/human_principal" },
        "human_disposition": { "enum": ["approve", "reject", "indeterminate"] },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "passing_gate": {
      "allOf": [
        { "$ref": "#/$defs/gate_disposition" },
        { "properties": { "check_disposition": { "const": "pass" }, "human_disposition": { "const": "approve" } } }
      ]
    },
    "rejecting_gate": {
      "allOf": [
        { "$ref": "#/$defs/gate_disposition" },
        { "anyOf": [
          { "properties": { "check_disposition": { "const": "fail" } } },
          { "properties": { "human_disposition": { "const": "reject" } } }
        ] }
      ]
    },
    "indeterminate_gate": {
      "allOf": [
        { "$ref": "#/$defs/gate_disposition" },
        { "anyOf": [
          { "properties": { "check_disposition": { "const": "indeterminate" } } },
          { "properties": { "human_disposition": { "const": "indeterminate" } } }
        ] }
      ]
    },
    "authorization_scope": {
      "type": "object", "additionalProperties": false,
      "required": ["visibility", "audience", "channel_targets", "geographic_regions", "embargo_until", "expires_at", "required_redactions", "constraints"],
      "properties": {
        "visibility": { "enum": ["private", "restricted", "embargoed", "public"] },
        "audience": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "channel_targets": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "geographic_regions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
        "embargo_until": { "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }] },
        "expires_at": { "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }] },
        "required_redactions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
        "constraints": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
