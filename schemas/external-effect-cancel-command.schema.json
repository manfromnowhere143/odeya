{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:external-effect-cancel-command:0.4.0",
  "x-odeya-command-payload-id": "urn:odeya:command-payload:external_effect.cancel:1.0.0",
  "title": "Cancel Authorized External Effect Command Payload",
  "description": "Requests cancellation only while an effect remains authorized and undispatched. Admission closes the intent and releases or invalidates its exact reservations; it cannot cancel an in-flight call or synthesize not-applied settlement. The required effect class must equal the class retained by the authorized effect; that cross-record equality is a semantic check.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "effect_id",
    "effect_class",
    "expected_effect_state",
    "authorization_event_ref",
    "grant_use_reservation_refs",
    "expected_effect_payload_digest",
    "cancellation_reason",
    "reason_evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "effect_id": {
      "$ref": "#/$defs/external_effect_cancel_command_identifier"
    },
    "effect_class": {
      "enum": [
        "publication",
        "message",
        "governed_processing_dispatch",
        "repository_write",
        "payment",
        "physical_action",
        "provider_mutation"
      ]
    },
    "expected_effect_state": {
      "const": "authorized"
    },
    "authorization_event_ref": {
      "$ref": "#/$defs/external_effect_cancel_command_identifier"
    },
    "grant_use_reservation_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/external_effect_cancel_command_identifier"
      }
    },
    "expected_effect_payload_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "byte_digest",
        "subject": "effect payload bytes (copy)",
        "algorithm": "sha-256",
        "profile": "not_a_canonical_object_digest",
        "status": "accepted_disposition_annotation"
      }
    },
    "cancellation_reason": {
      "enum": [
        "operator_cancelled",
        "correction_invalidated",
        "rights_invalidated",
        "policy_invalidated",
        "safety_invalidated",
        "resource_invalidated",
        "superseded",
        "mission_quarantined",
        "shutdown"
      ]
    },
    "reason_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/external_effect_cancel_command_artifact_reference"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "external_effect_cancel_command_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "external_effect_cancel_command_artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/external_effect_cancel_command_identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    }
  }
}
