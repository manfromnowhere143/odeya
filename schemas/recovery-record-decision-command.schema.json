{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:recovery-record-decision-command:0.1.0",
  "title": "Odeya recovery.record_decision command payload",
  "description": "Architecture-only closed command payload. Structural validity does not establish referenced evidence, authority, time, signature, quorum, or execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recovery_decision_ref",
    "restore_report_ref",
    "security_frontier_digest",
    "security_frontier_position",
    "security_frontier_completeness",
    "decision",
    "allowed_service_scopes",
    "prohibited_service_scopes",
    "quorum_evidence_refs",
    "authority_assignment_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "security_frontier_position": {
      "type": "integer",
      "minimum": 0
    },
    "security_frontier_completeness": {
      "enum": [
        "proven_complete",
        "incomplete",
        "indeterminate"
      ]
    },
    "decision": {
      "enum": [
        "reject_restore",
        "remain_quarantined",
        "open_read_only",
        "open_reconciliation",
        "open_bounded_research_writes",
        "constitutional_new_epoch"
      ]
    },
    "allowed_service_scopes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/service_scope"
      }
    },
    "prohibited_service_scopes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "allOf": [
        {
          "contains": {
            "const": "publication"
          }
        },
        {
          "contains": {
            "const": "spending"
          }
        },
        {
          "contains": {
            "const": "r2_plus_effects"
          }
        },
        {
          "contains": {
            "const": "physical_actions"
          }
        }
      ],
      "items": {
        "$ref": "#/$defs/service_scope"
      }
    },
    "quorum_evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "authority_assignment_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "recovery_decision_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "restore_report_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "security_frontier_digest": {
      "$ref": "#/$defs/digest"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "enum": [
              "open_read_only",
              "open_reconciliation",
              "open_bounded_research_writes"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "security_frontier_completeness": {
            "const": "proven_complete"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "service_scope": {
      "enum": [
        "incident_cockpit",
        "canonical_reads",
        "reconciliation_commands",
        "ordinary_research_writes",
        "publication",
        "spending",
        "r2_plus_effects",
        "physical_actions"
      ]
    }
  }
}
