{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:registry-activation:0.3.0",
  "title": "Odeya RegistryActivation",
  "description": "An immutable prospective decision selecting one checkpointed EngineContractRoot for a bounded runtime scope. It embeds the nonrecursive P0 constitutional-recovery admission that must already bind non-self-issued root authority, the exact EngineContractRoot and C0 bundle, witnessed checkpoint evidence, and a current fail-closed recovery/fork/quarantine frontier. The activation is downstream of those subjects and cannot issue its own root authority or change any bound subject's meaning. Structural validity does not prove reference equality, signature truth, currentness, or branch ordering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "activation_id",
    "activation_sequence",
    "effect",
    "previous_activation_ref",
    "engine_contract_root_ref",
    "c0_registry_bundle_ref",
    "root_checkpoint_ref",
    "activation_ledger_binding",
    "p0_constitutional_recovery_admission",
    "scope",
    "command_surface",
    "handler_conformance",
    "authority_decision_ref",
    "policy_decision_ref",
    "controlled_time_window",
    "rollback_target_ref",
    "review_evidence_refs",
    "activation_digest_contract",
    "activation_digest",
    "attestations"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "activation_id": {
      "$ref": "#/$defs/identifier"
    },
    "activation_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "effect": {
      "enum": [
        "activate",
        "supersede",
        "rollback"
      ]
    },
    "previous_activation_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/activation_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "engine_contract_root_ref": {
      "$ref": "#/$defs/subject_reference"
    },
    "c0_registry_bundle_ref": {
      "$ref": "#/$defs/subject_reference"
    },
    "root_checkpoint_ref": {
      "$ref": "#/$defs/checkpoint_reference"
    },
    "activation_ledger_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_epoch",
        "global_position"
      ],
      "properties": {
        "ledger_epoch": {
          "$ref": "#/$defs/identifier"
        },
        "global_position": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "p0_constitutional_recovery_admission": {
      "$ref": "#/$defs/p0_constitutional_recovery_admission"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "namespaces",
        "mission_scope",
        "mission_ids",
        "environment_classes",
        "risk_ceiling",
        "data_ceiling",
        "permitted_action_classes",
        "action_profile_ref"
      ],
      "properties": {
        "tenant_id": {
          "$ref": "#/$defs/identifier"
        },
        "namespaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "mission_scope": {
          "enum": [
            "named_missions",
            "all_tenant_missions"
          ]
        },
        "mission_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "environment_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "local_isolated",
              "staging",
              "production"
            ]
          }
        },
        "risk_ceiling": {
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3",
            "R4"
          ]
        },
        "data_ceiling": {
          "enum": [
            "D0",
            "D1",
            "D2",
            "D3",
            "D4"
          ]
        },
        "permitted_action_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "action_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mission_scope": {
                "const": "named_missions"
              }
            },
            "required": [
              "mission_scope"
            ]
          },
          "then": {
            "properties": {
              "mission_ids": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "mission_ids": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "command_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_registry_ref",
        "admitted_command_set_ref",
        "generated_envelope_ref",
        "member_count",
        "set_digest"
      ],
      "properties": {
        "command_registry_ref": {
          "$ref": "#/$defs/subject_reference"
        },
        "admitted_command_set_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "generated_envelope_ref": {
          "$ref": "#/$defs/schema_bytes_reference"
        },
        "member_count": {
          "type": "integer",
          "minimum": 1
        },
        "set_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-reference-set-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "handler_conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handler_set_ref",
        "member_count",
        "set_digest",
        "conformance_report_refs",
        "independence_report_refs"
      ],
      "properties": {
        "handler_set_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "member_count": {
          "type": "integer",
          "minimum": 1
        },
        "set_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-reference-set-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "conformance_report_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "independence_report_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        }
      }
    },
    "authority_decision_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "policy_decision_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "controlled_time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not_before",
        "not_after",
        "controlled_time_evidence_ref"
      ],
      "properties": {
        "not_before": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
        },
        "not_after": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
            },
            {
              "type": "null"
            }
          ]
        },
        "controlled_time_evidence_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "rollback_target_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/subject_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "review_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "activation_digest_contract": {
      "$ref": "#/$defs/digest_contract"
    },
    "activation_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-registry-activation-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "attestations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/attestation"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "effect": {
            "const": "activate"
          }
        },
        "required": [
          "effect"
        ]
      },
      "then": {
        "properties": {
          "previous_activation_ref": {
            "type": "null"
          },
          "rollback_target_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "effect": {
            "const": "supersede"
          }
        },
        "required": [
          "effect"
        ]
      },
      "then": {
        "properties": {
          "previous_activation_ref": {
            "$ref": "#/$defs/activation_reference"
          },
          "rollback_target_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "effect": {
            "const": "rollback"
          }
        },
        "required": [
          "effect"
        ]
      },
      "then": {
        "properties": {
          "previous_activation_ref": {
            "$ref": "#/$defs/activation_reference"
          },
          "rollback_target_ref": {
            "$ref": "#/$defs/subject_reference"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "subject_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "version",
        "schema_id",
        "canonical_digest"
      ],
      "properties": {
        "subject_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "schema_id": {
          "type": "string",
          "format": "uri"
        },
        "canonical_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "activation_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activation_id",
        "activation_sequence",
        "activation_digest"
      ],
      "properties": {
        "activation_id": {
          "$ref": "#/$defs/identifier"
        },
        "activation_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "activation_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-registry-activation-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "checkpoint_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "version",
        "schema_id",
        "ledger_epoch",
        "inclusive_global_position",
        "digest"
      ],
      "properties": {
        "checkpoint_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:ledger-checkpoint:0.4.0"
        },
        "ledger_epoch": {
          "$ref": "#/$defs/identifier"
        },
        "inclusive_global_position": {
          "type": "integer",
          "minimum": 0
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "root_authority_manifest_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/subject_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:root-authority-manifest:0.2.0"
            }
          }
        }
      ]
    },
    "engine_contract_root_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/subject_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:engine-contract-root:0.2.0"
            }
          }
        }
      ]
    },
    "c0_registry_bundle_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/subject_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:c0-registry-bundle:0.2.0"
            }
          }
        }
      ]
    },
    "witness_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "failure_domain_id",
        "observation_ref",
        "checkpoint_digest",
        "consistency_verification"
      ],
      "properties": {
        "witness_id": {
          "$ref": "#/$defs/identifier"
        },
        "failure_domain_id": {
          "$ref": "#/$defs/identifier"
        },
        "observation_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "checkpoint_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-ledger-checkpoint-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "consistency_verification": {
          "const": "pass"
        }
      }
    },
    "p0_constitutional_recovery_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prerequisite_id",
        "version",
        "admission_status",
        "nonrecursive_boundary",
        "root_authority_binding",
        "engine_contract_root_ref",
        "c0_registry_bundle_ref",
        "witnessed_checkpoint_binding",
        "current_recovery_frontier",
        "admission_evidence_refs",
        "p0_digest_contract",
        "p0_digest"
      ],
      "properties": {
        "prerequisite_id": {
          "const": "P0.constitutional-recovery-admission"
        },
        "version": {
          "const": "0.1.0"
        },
        "admission_status": {
          "const": "admitted_before_registry_activation"
        },
        "nonrecursive_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "activation_reference_permitted",
            "parent_activation_digest_included",
            "self_issued_root_authority_permitted",
            "parent_root_and_c0_equality_required"
          ],
          "properties": {
            "activation_reference_permitted": {
              "const": false
            },
            "parent_activation_digest_included": {
              "const": false
            },
            "self_issued_root_authority_permitted": {
              "const": false
            },
            "parent_root_and_c0_equality_required": {
              "const": true
            }
          }
        },
        "root_authority_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "root_authority_manifest_ref",
            "constitutional_assignment_ref",
            "issuer_principal_id",
            "assignment_ledger_position",
            "issuance_mode",
            "self_issued",
            "activation_subject_may_issue_own_authority",
            "authority_chain_verification_ref"
          ],
          "properties": {
            "root_authority_manifest_ref": {
              "$ref": "#/$defs/root_authority_manifest_reference"
            },
            "constitutional_assignment_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "issuer_principal_id": {
              "$ref": "#/$defs/identifier"
            },
            "assignment_ledger_position": {
              "type": "integer",
              "minimum": 0
            },
            "issuance_mode": {
              "const": "preexisting_constitutional_assignment"
            },
            "self_issued": {
              "const": false
            },
            "activation_subject_may_issue_own_authority": {
              "const": false
            },
            "authority_chain_verification_ref": {
              "$ref": "#/$defs/artifact_reference"
            }
          }
        },
        "engine_contract_root_ref": {
          "$ref": "#/$defs/engine_contract_root_reference"
        },
        "c0_registry_bundle_ref": {
          "$ref": "#/$defs/c0_registry_bundle_reference"
        },
        "witnessed_checkpoint_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "checkpoint_ref",
            "signature_verification_ref",
            "witness_policy_ref",
            "witness_quorum_ref",
            "witness_observations",
            "independent_failure_domains_required",
            "consistency_disposition",
            "conflicting_view_refs"
          ],
          "properties": {
            "checkpoint_ref": {
              "$ref": "#/$defs/checkpoint_reference"
            },
            "signature_verification_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "witness_policy_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "witness_quorum_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "witness_observations": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/witness_observation"
              }
            },
            "independent_failure_domains_required": {
              "const": true
            },
            "consistency_disposition": {
              "const": "pass"
            },
            "conflicting_view_refs": {
              "type": "array",
              "maxItems": 0,
              "items": {
                "$ref": "#/$defs/artifact_reference"
              }
            }
          }
        },
        "current_recovery_frontier": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "frontier_ref",
            "ledger_epoch",
            "frontier_position",
            "frontier_digest",
            "frontier_completeness",
            "current_at_activation",
            "fork_disposition",
            "unresolved_fork_count",
            "open_recovery_case_count",
            "ambiguous_recovery_case_count",
            "recovery_ambiguity_disposition",
            "branch_selection_basis",
            "wall_clock_branch_selection",
            "recovery_control_state",
            "quarantine_disposition",
            "recovery_decision_ref",
            "frontier_verification_ref",
            "publication_enabled",
            "spending_enabled",
            "r2_plus_effects_enabled",
            "physical_actions_enabled"
          ],
          "properties": {
            "frontier_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "ledger_epoch": {
              "$ref": "#/$defs/identifier"
            },
            "frontier_position": {
              "type": "integer",
              "minimum": 0
            },
            "frontier_digest": {
              "$ref": "#/$defs/digest"
            },
            "frontier_completeness": {
              "const": "proven_complete"
            },
            "current_at_activation": {
              "const": true
            },
            "fork_disposition": {
              "enum": [
                "no_fork_detected",
                "constitutionally_resolved_new_epoch"
              ]
            },
            "unresolved_fork_count": {
              "const": 0
            },
            "open_recovery_case_count": {
              "const": 0
            },
            "ambiguous_recovery_case_count": {
              "const": 0
            },
            "recovery_ambiguity_disposition": {
              "const": "none_current"
            },
            "branch_selection_basis": {
              "enum": [
                "witnessed_continuity",
                "constitutional_recovery_decision"
              ]
            },
            "wall_clock_branch_selection": {
              "const": false
            },
            "recovery_control_state": {
              "const": "bounded_research_writes"
            },
            "quarantine_disposition": {
              "const": "cleared_by_current_recovery_frontier"
            },
            "recovery_decision_ref": {
              "oneOf": [
                {
                  "$ref": "#/$defs/artifact_reference"
                },
                {
                  "type": "null"
                }
              ]
            },
            "frontier_verification_ref": {
              "$ref": "#/$defs/artifact_reference"
            },
            "publication_enabled": {
              "const": false
            },
            "spending_enabled": {
              "const": false
            },
            "r2_plus_effects_enabled": {
              "const": false
            },
            "physical_actions_enabled": {
              "const": false
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "fork_disposition": {
                    "const": "no_fork_detected"
                  }
                },
                "required": [
                  "fork_disposition"
                ]
              },
              "then": {
                "properties": {
                  "branch_selection_basis": {
                    "const": "witnessed_continuity"
                  },
                  "recovery_decision_ref": {
                    "type": "null"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "fork_disposition": {
                    "const": "constitutionally_resolved_new_epoch"
                  }
                },
                "required": [
                  "fork_disposition"
                ]
              },
              "then": {
                "properties": {
                  "branch_selection_basis": {
                    "const": "constitutional_recovery_decision"
                  },
                  "recovery_decision_ref": {
                    "$ref": "#/$defs/artifact_reference"
                  }
                }
              }
            }
          ]
        },
        "admission_evidence_refs": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "p0_digest_contract": {
          "$ref": "#/$defs/p0_digest_contract"
        },
        "p0_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-p0-constitutional-recovery-admission-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
