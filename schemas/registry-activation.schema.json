{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:registry-activation:0.1.0",
  "title": "Odeya RegistryActivation",
  "description": "An immutable prospective decision selecting one checkpointed EngineContractRoot for a bounded runtime scope. It is downstream of the root and checkpoint and cannot change either subject's meaning. This contract does not itself prove handler deployment, authority, currentness, or branch ordering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "activation_id",
    "activation_sequence",
    "effect",
    "previous_activation_ref",
    "engine_contract_root_ref",
    "c0_registry_bundle_ref",
    "root_checkpoint_ref",
    "activation_ledger_binding",
    "scope",
    "command_surface",
    "handler_conformance",
    "authority_decision_ref",
    "policy_decision_ref",
    "controlled_time_window",
    "rollback_target_ref",
    "review_evidence_refs",
    "activation_digest_contract",
    "activation_digest",
    "attestations"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "activation_id": { "$ref": "#/$defs/identifier" },
    "activation_sequence": { "type": "integer", "minimum": 1 },
    "effect": { "enum": ["activate", "supersede", "rollback"] },
    "previous_activation_ref": {
      "oneOf": [
        { "$ref": "#/$defs/activation_reference" },
        { "type": "null" }
      ]
    },
    "engine_contract_root_ref": { "$ref": "#/$defs/subject_reference" },
    "c0_registry_bundle_ref": { "$ref": "#/$defs/subject_reference" },
    "root_checkpoint_ref": { "$ref": "#/$defs/checkpoint_reference" },
    "activation_ledger_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_epoch", "global_position"],
      "properties": {
        "ledger_epoch": { "$ref": "#/$defs/identifier" },
        "global_position": { "type": "integer", "minimum": 0 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "namespaces",
        "mission_scope",
        "mission_ids",
        "environment_classes",
        "risk_ceiling",
        "data_ceiling",
        "permitted_action_classes",
        "action_profile_ref"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "namespaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "mission_scope": { "enum": ["named_missions", "all_tenant_missions"] },
        "mission_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "environment_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["local_isolated", "staging", "production"] }
        },
        "risk_ceiling": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
        "data_ceiling": { "enum": ["D0", "D1", "D2", "D3", "D4"] },
        "permitted_action_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "action_profile_ref": { "$ref": "#/$defs/artifact_reference" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "mission_scope": { "const": "named_missions" } },
            "required": ["mission_scope"]
          },
          "then": { "properties": { "mission_ids": { "minItems": 1 } } },
          "else": { "properties": { "mission_ids": { "maxItems": 0 } } }
        }
      ]
    },
    "command_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_registry_ref",
        "admitted_command_set_ref",
        "generated_envelope_ref",
        "member_count",
        "set_digest"
      ],
      "properties": {
        "command_registry_ref": { "$ref": "#/$defs/subject_reference" },
        "admitted_command_set_ref": { "$ref": "#/$defs/artifact_reference" },
        "generated_envelope_ref": { "$ref": "#/$defs/schema_bytes_reference" },
        "member_count": { "type": "integer", "minimum": 1 },
        "set_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "handler_conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handler_set_ref",
        "member_count",
        "set_digest",
        "conformance_report_refs",
        "independence_report_refs"
      ],
      "properties": {
        "handler_set_ref": { "$ref": "#/$defs/artifact_reference" },
        "member_count": { "type": "integer", "minimum": 1 },
        "set_digest": { "$ref": "#/$defs/digest" },
        "conformance_report_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/artifact_reference" }
        },
        "independence_report_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/artifact_reference" }
        }
      }
    },
    "authority_decision_ref": { "$ref": "#/$defs/artifact_reference" },
    "policy_decision_ref": { "$ref": "#/$defs/artifact_reference" },
    "controlled_time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not_before", "not_after", "controlled_time_evidence_ref"],
      "properties": {
        "not_before": { "type": "string", "format": "date-time" },
        "not_after": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "controlled_time_evidence_ref": { "$ref": "#/$defs/artifact_reference" }
      }
    },
    "rollback_target_ref": {
      "oneOf": [
        { "$ref": "#/$defs/subject_reference" },
        { "type": "null" }
      ]
    },
    "review_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/artifact_reference" }
    },
    "activation_digest_contract": { "$ref": "#/$defs/digest_contract" },
    "activation_digest": { "$ref": "#/$defs/digest" },
    "attestations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/attestation" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "effect": { "const": "activate" } },
        "required": ["effect"]
      },
      "then": {
        "properties": {
          "previous_activation_ref": { "type": "null" },
          "rollback_target_ref": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "effect": { "const": "supersede" } },
        "required": ["effect"]
      },
      "then": {
        "properties": {
          "previous_activation_ref": { "$ref": "#/$defs/activation_reference" },
          "rollback_target_ref": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "effect": { "const": "rollback" } },
        "required": ["effect"]
      },
      "then": {
        "properties": {
          "previous_activation_ref": { "$ref": "#/$defs/activation_reference" },
          "rollback_target_ref": { "$ref": "#/$defs/subject_reference" }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "subject_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_id", "version", "schema_id", "canonical_digest"],
      "properties": {
        "subject_id": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/semantic_version" },
        "schema_id": { "type": "string", "format": "uri" },
        "canonical_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "activation_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activation_id", "activation_sequence", "activation_digest"],
      "properties": {
        "activation_id": { "$ref": "#/$defs/identifier" },
        "activation_sequence": { "type": "integer", "minimum": 1 },
        "activation_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "checkpoint_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "version",
        "ledger_epoch",
        "inclusive_global_position",
        "digest"
      ],
      "properties": {
        "checkpoint_id": { "$ref": "#/$defs/identifier" },
        "version": { "type": "integer", "minimum": 1 },
        "ledger_epoch": { "$ref": "#/$defs/identifier" },
        "inclusive_global_position": { "type": "integer", "minimum": 0 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "digest", "media_type"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/identifier" },
        "digest": { "$ref": "#/$defs/digest" },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 127 }
      }
    },
    "schema_bytes_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "semantic_version", "byte_digest", "byte_count", "dialect"],
      "properties": {
        "schema_id": { "type": "string", "format": "uri" },
        "semantic_version": { "$ref": "#/$defs/semantic_version" },
        "byte_digest": { "$ref": "#/$defs/digest" },
        "byte_count": { "type": "integer", "minimum": 2 },
        "dialect": { "const": "https://json-schema.org/draft/2020-12/schema" }
      }
    },
    "profile_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "version", "digest"],
      "properties": {
        "profile_id": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/semantic_version" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "schema_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_digest"],
      "properties": {
        "schema_id": { "type": "string", "format": "uri" },
        "schema_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "digest_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "domain_separator",
        "canonicalization_profile_ref",
        "subject_schema_ref",
        "included_json_pointers",
        "excluded_json_pointers"
      ],
      "properties": {
        "algorithm": { "const": "sha256" },
        "domain_separator": { "const": "odeya-registry-activation-v1" },
        "canonicalization_profile_ref": { "$ref": "#/$defs/profile_reference" },
        "subject_schema_ref": { "$ref": "#/$defs/schema_reference" },
        "included_json_pointers": {
          "type": "array",
          "minItems": 18,
          "maxItems": 18,
          "prefixItems": [
            { "const": "/schema_version" },
            { "const": "/activation_id" },
            { "const": "/activation_sequence" },
            { "const": "/effect" },
            { "const": "/previous_activation_ref" },
            { "const": "/engine_contract_root_ref" },
            { "const": "/c0_registry_bundle_ref" },
            { "const": "/root_checkpoint_ref" },
            { "const": "/activation_ledger_binding" },
            { "const": "/scope" },
            { "const": "/command_surface" },
            { "const": "/handler_conformance" },
            { "const": "/authority_decision_ref" },
            { "const": "/policy_decision_ref" },
            { "const": "/controlled_time_window" },
            { "const": "/rollback_target_ref" },
            { "const": "/review_evidence_refs" },
            { "const": "/activation_digest_contract" }
          ],
          "items": false
        },
        "excluded_json_pointers": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            { "const": "/activation_digest" },
            { "const": "/attestations" }
          ],
          "items": false
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attestation_id", "signer_id", "purpose", "algorithm", "key_id", "signed_digest", "signature"],
      "properties": {
        "attestation_id": { "$ref": "#/$defs/identifier" },
        "signer_id": { "$ref": "#/$defs/identifier" },
        "purpose": { "const": "registry_activation" },
        "algorithm": { "type": "string", "minLength": 1, "maxLength": 64 },
        "key_id": { "$ref": "#/$defs/identifier" },
        "signed_digest": { "$ref": "#/$defs/digest" },
        "signature": { "type": "string", "minLength": 16, "maxLength": 8192 }
      }
    }
  }
}
