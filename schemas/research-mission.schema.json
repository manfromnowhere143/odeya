      "properties": {
        "action_class": {
          "type": "string",
          "minLength": 1
        },
        "authority_role": {
          "enum": [
            "protocol",
            "safety",
            "data_rights",
            "resource",
            "execution",
            "verification",
            "outcome",
            "publication"
          ]
        },
        "timeout_behavior": {
          "const": "deny"
        }
      }
    },
    "scientific_outcome": {
      "enum": [
        "supported_within_scope",
        "contradicted",
        "falsified",
        "null_result",
        "inconclusive"
      ]
    },
    "governed_wall_time_seconds": {
