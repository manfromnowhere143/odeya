  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "immutable_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "research_state_view_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "record_type": {
          "const": "research_state_view"
        },
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "const": "urn:odeya:schema:research-state-view:0.3.0"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "versioned_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "check_result": {
      "enum": [
        "pass",
        "fail",
        "indeterminate",
        "not_run"
      ]
    },
    "coverage_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "missing_refs",
        "unknown_reason_codes",
        "rule_ref",
        "evidence_ref"
      ],
      "properties": {
        "result": {
          "enum": [
            "complete",
            "incomplete",
            "indeterminate",
            "not_run"
          ]
        },
        "missing_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "unknown_reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "rule_ref": {
          "$ref": "#/$defs/versioned_reference"
        },
        "evidence_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "const": "complete"
              }
            },
            "required": [
              "result"
            ]
          },
          "then": {
            "properties": {
              "missing_refs": {
                "maxItems": 0
              },
              "unknown_reason_codes": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "result": {
                "const": "incomplete"
              }
            },
            "required": [
              "result"
            ]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "missing_refs": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "unknown_reason_codes": {
                    "minItems": 1
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "result": {
                "enum": [
                  "indeterminate",
                  "not_run"
                ]
              }
            },
            "required": [
              "result"
            ]
          },
          "then": {
            "properties": {
              "unknown_reason_codes": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
