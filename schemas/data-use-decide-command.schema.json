{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:data-use-decide-command:0.4.0",
  "title": "Odeya data_use.decide command payload",
  "description": "Architecture-only closed command payload. Structural validity does not establish referenced evidence, authority, time, signature, quorum, or execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_record_ref",
    "asset_ref",
    "rights_assertion_refs",
    "expected_prior_decision",
    "decision",
    "scope_digest",
    "policy_profile_ref",
    "jurisdiction_profile_ref",
    "effective_at",
    "expires_at",
    "authority_assignment_refs",
    "decision_evidence_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "rights_assertion_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/canonical_record_reference"
      }
    },
    "expected_prior_decision": {
      "enum": [
        "none",
        "authorized",
        "denied",
        "indeterminate",
        "revoked",
        "expired"
      ]
    },
    "decision": {
      "enum": [
        "authorized",
        "denied",
        "indeterminate"
      ]
    },
    "scope_digest": {
      "oneOf": [
        {
          "$ref": "#/$defs/digest"
        },
        {
          "type": "null"
        }
      ],
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-scope-manifest-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "prospective_domain_reserved_not_declared"
      }
    },
    "effective_at": {
      "oneOf": [
        {
          "$ref": "#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "expires_at": {
      "oneOf": [
        {
          "$ref": "#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_assignment_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "decision_record_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "asset_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "policy_profile_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "jurisdiction_profile_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "decision_evidence_ref": {
      "$ref": "#/$defs/artifact_reference"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "authorized"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "scope_digest": {
            "$ref": "#/$defs/digest",
            "x-odeya-digest-scope": {
              "kind": "canonical_object_digest",
              "domain": "odeya-scope-manifest-v1",
              "algorithm": "sha-256",
              "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
              "status": "prospective_domain_reserved_not_declared"
            }
          },
          "effective_at": {
            "$ref": "#/$defs/timestamp"
          },
          "expires_at": {
            "$ref": "#/$defs/timestamp"
          }
        }
      },
      "else": {
        "properties": {
          "scope_digest": {
            "type": "null",
            "x-odeya-digest-scope": {
              "kind": "canonical_object_digest",
              "domain": "odeya-scope-manifest-v1",
              "algorithm": "sha-256",
              "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
              "status": "prospective_domain_reserved_not_declared"
            }
          },
          "effective_at": {
            "type": "null"
          },
          "expires_at": {
            "type": "null"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "service_scope": {
      "enum": [
        "incident_cockpit",
        "canonical_reads",
        "reconciliation_commands",
        "ordinary_research_writes",
        "publication",
        "spending",
        "r2_plus_effects",
        "physical_actions"
      ]
    }
  }
}
