{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:deletion-close-case-command:0.1.0",
  "title": "Odeya deletion.close_case command payload",
  "description": "Architecture-only closed command payload. Structural validity does not establish referenced evidence, authority, time, signature, quorum, or execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deletion_case_ref",
    "expected_status",
    "requested_terminal_status",
    "asset_scope_digest",
    "plane_result_refs",
    "closure_verification_ref",
    "residual_set_ref",
    "tombstone_event_refs",
    "scientific_consequence_event_refs",
    "active_legal_hold_refs",
    "authority_assignment_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "expected_status": {
      "enum": [
        "in_progress",
        "limited",
        "indeterminate"
      ]
    },
    "requested_terminal_status": {
      "enum": [
        "completed",
        "limited",
        "denied",
        "indeterminate"
      ]
    },
    "plane_result_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "residual_set_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/artifact_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "tombstone_event_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "scientific_consequence_event_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "active_legal_hold_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/canonical_record_reference"
      }
    },
    "authority_assignment_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "deletion_case_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "asset_scope_digest": {
      "$ref": "#/$defs/digest"
    },
    "closure_verification_ref": {
      "$ref": "#/$defs/artifact_reference"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "requested_terminal_status": {
            "const": "completed"
          }
        },
        "required": [
          "requested_terminal_status"
        ]
      },
      "then": {
        "properties": {
          "residual_set_ref": {
            "type": "null"
          },
          "tombstone_event_refs": {
            "minItems": 1
          },
          "active_legal_hold_refs": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "service_scope": {
      "enum": [
        "incident_cockpit",
        "canonical_reads",
        "reconciliation_commands",
        "ordinary_research_writes",
        "publication",
        "spending",
        "r2_plus_effects",
        "physical_actions"
      ]
    }
  }
}
