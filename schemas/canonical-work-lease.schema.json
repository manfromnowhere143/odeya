{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:canonical-work-lease:0.8.0",
  "title": "Odeya CanonicalWorkLease Blocked Candidate",
  "description": "A fail-closed first-slice local-verification architecture candidate for an immutable WorkLease state record. The resource fixes the five-state lease algebra and the prospective assignment binding, but every current instance remains identity-unresolved, unadmitted, and unusable as execution authority until the canonical profile, exact assignment cohort, registry member, reducer, and activation evidence exist. General renewal remains outside this candidate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope_profile",
    "record_status",
    "identity_resolution_status",
    "canonicalization_profile_ref",
    "canonical_digest",
    "record_authority_status",
    "lease_id",
    "lease_version",
    "mission_id",
    "work_item_id",
    "work_intent_ref",
    "worker_binding",
    "assignment_binding",
    "reservation_frontier",
    "temporal_bounds",
    "lease_state",
    "lease_allows_new_start_claims",
    "transition",
    "known_blockers"
  ],
  "properties": {
    "schema_version": {
      "const": "0.8.0"
    },
    "scope_profile": {
      "const": "first_slice_local_verification_candidate"
    },
    "record_status": {
      "const": "blocked_canonical_record_candidate"
    },
    "identity_resolution_status": {
      "const": "unresolved_blocking"
    },
    "canonicalization_profile_ref": {
      "type": "null"
    },
    "canonical_digest": {
      "type": "null",
      "x-odeya-digest-scope": {
        "algorithm": "sha-256",
        "subject": "canonical WorkLease record under its future admitted schema and canonicalization profile",
        "profile_source": "/canonicalization_profile_ref",
        "schema_source": "urn:odeya:schema:canonical-work-lease:0.8.0",
        "status": "not_computable_while_identity_resolution_status_is_unresolved_blocking",
        "kind": "canonical_object_digest"
      }
    },
    "record_authority_status": {
      "const": "not_admitted_not_execution_authority"
    },
    "lease_id": {
      "$ref": "#/$defs/work_lease_identifier"
    },
    "lease_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "mission_id": {
      "$ref": "#/$defs/work_lease_identifier"
    },
    "work_item_id": {
      "$ref": "#/$defs/work_lease_identifier"
    },
    "work_intent_ref": {
      "$ref": "#/$defs/work_lease_work_intent_reference"
    },
    "worker_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "execution_identity",
        "execution_slot_key"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "execution_identity": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "execution_slot_key": {
          "$ref": "#/$defs/work_lease_identifier"
        }
      }
    },
    "assignment_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assignment_command_type",
        "assignment_commit_id",
        "ordered_grant_roles",
        "assignment_event_ref",
        "cohort_evidence_ref",
        "cohort_resolution_status",
        "source_bytes_visible_at_assignment_commit",
        "launch_outbox_created_at_assignment_commit"
      ],
      "properties": {
        "assignment_command_type": {
          "const": "verification.assign"
        },
        "assignment_commit_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "ordered_grant_roles": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "prefixItems": [
            {
              "const": "safety"
            },
            {
              "const": "data_rights"
            },
            {
              "const": "resource"
            },
            {
              "const": "execution"
            },
            {
              "const": "verification"
            }
          ],
          "items": false
        },
        "assignment_event_ref": {
          "$ref": "#/$defs/work_lease_assignment_event_reference"
        },
        "cohort_evidence_ref": {
          "$ref": "#/$defs/work_lease_artifact_reference"
        },
        "cohort_resolution_status": {
          "const": "unresolved_blocking"
        },
        "source_bytes_visible_at_assignment_commit": {
          "const": false
        },
        "launch_outbox_created_at_assignment_commit": {
          "const": false
        }
      }
    },
    "reservation_frontier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reservation_created_event_ref",
        "claim_state_at_transition",
        "reservation_claim_event_ref",
        "lease_transition_changes_resource_reservation_state",
        "claimed_reservation_requires_separate_settlement"
      ],
      "properties": {
        "reservation_created_event_ref": {
          "$ref": "#/$defs/work_lease_reservation_created_event_reference"
        },
        "claim_state_at_transition": {
          "enum": [
            "unclaimed",
            "claimed"
          ]
        },
        "reservation_claim_event_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/work_lease_reservation_claimed_event_reference"
            },
            {
              "type": "null"
            }
          ]
        },
        "lease_transition_changes_resource_reservation_state": {
          "const": false
        },
        "claimed_reservation_requires_separate_settlement": {
          "const": true
        }
      }
    },
    "temporal_bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not_before",
        "expires_at",
        "controlled_time_evidence_ref"
      ],
      "properties": {
        "not_before": {
          "$ref": "#/$defs/work_lease_timestamp"
        },
        "expires_at": {
          "$ref": "#/$defs/work_lease_timestamp"
        },
        "controlled_time_evidence_ref": {
          "$ref": "#/$defs/work_lease_artifact_reference"
        }
      }
    },
    "lease_state": {
      "enum": [
        "active",
        "released",
        "revoked",
        "expired"
      ]
    },
    "lease_allows_new_start_claims": {
      "type": "boolean"
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "event_ref",
        "prior_active_event_ref",
        "reason_code",
        "evidence_refs"
      ],
      "properties": {
        "from": {
          "enum": [
            "unleased",
            "active"
          ]
        },
        "to": {
          "enum": [
            "active",
            "released",
            "revoked",
            "expired"
          ]
        },
        "event_ref": {
          "$ref": "#/$defs/canonical_work_lease_transition_event_reference"
        },
        "prior_active_event_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/work_lease_active_event_reference"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason_code": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/work_lease_artifact_reference"
          }
        }
      }
    },
    "known_blockers": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "const": "canonical_profile_not_frozen"
        },
        {
          "const": "work_intent_identity_unresolved"
        },
        {
          "const": "exact_assignment_cohort_not_admitted"
        },
        {
          "const": "registry_member_reducer_and_activation_absent"
        }
      ],
      "items": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "transition": {
            "properties": {
              "event_ref": {
                "properties": {
                  "event_type": {
                    "const": "work.lease_acquired"
                  }
                },
                "required": [
                  "event_type"
                ]
              }
            },
            "required": [
              "event_ref"
            ]
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "lease_version": {
            "const": 1
          },
          "lease_state": {
            "const": "active"
          },
          "lease_allows_new_start_claims": {
            "const": true
          },
          "reservation_frontier": {
            "properties": {
              "claim_state_at_transition": {
                "const": "unclaimed"
              },
              "reservation_claim_event_ref": {
                "type": "null"
              }
            }
          },
          "transition": {
            "properties": {
              "from": {
                "const": "unleased"
              },
              "to": {
                "const": "active"
              },
              "prior_active_event_ref": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transition": {
            "properties": {
              "event_ref": {
                "properties": {
                  "event_type": {
                    "enum": [
                      "work.lease_released",
                      "work.lease_revoked",
                      "work.lease_expired"
                    ]
                  }
                },
                "required": [
                  "event_type"
                ]
              }
            },
            "required": [
              "event_ref"
            ]
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "lease_version": {
            "type": "integer",
            "minimum": 2,
            "maximum": 9007199254740991
          },
          "lease_allows_new_start_claims": {
            "const": false
          },
          "transition": {
            "properties": {
              "from": {
                "const": "active"
              },
              "prior_active_event_ref": {
                "$ref": "#/$defs/work_lease_active_event_reference"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transition": {
            "properties": {
              "event_ref": {
                "properties": {
                  "event_type": {
                    "const": "work.lease_released"
                  }
                },
                "required": [
                  "event_type"
                ]
              }
            },
            "required": [
              "event_ref"
            ]
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "lease_state": {
            "const": "released"
          },
          "reservation_frontier": {
            "properties": {
              "claim_state_at_transition": {
                "const": "claimed"
              },
              "reservation_claim_event_ref": {
                "$ref": "#/$defs/work_lease_reservation_claimed_event_reference"
              }
            }
          },
          "transition": {
            "properties": {
              "to": {
                "const": "released"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transition": {
            "properties": {
              "event_ref": {
                "properties": {
                  "event_type": {
                    "const": "work.lease_revoked"
                  }
                },
                "required": [
                  "event_type"
                ]
              }
            },
            "required": [
              "event_ref"
            ]
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "lease_state": {
            "const": "revoked"
          },
          "transition": {
            "properties": {
              "to": {
                "const": "revoked"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transition": {
            "properties": {
              "event_ref": {
                "properties": {
                  "event_type": {
                    "const": "work.lease_expired"
                  }
                },
                "required": [
                  "event_type"
                ]
              }
            },
            "required": [
              "event_ref"
            ]
          }
        },
        "required": [
          "transition"
        ]
      },
      "then": {
        "properties": {
          "lease_state": {
            "const": "expired"
          },
          "reservation_frontier": {
            "properties": {
              "claim_state_at_transition": {
                "const": "unclaimed"
              },
              "reservation_claim_event_ref": {
                "type": "null"
              }
            }
          },
          "transition": {
            "properties": {
              "to": {
                "const": "expired"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reservation_frontier": {
            "properties": {
              "claim_state_at_transition": {
                "const": "unclaimed"
              }
            },
            "required": [
              "claim_state_at_transition"
            ]
          }
        },
        "required": [
          "reservation_frontier"
        ]
      },
      "then": {
        "properties": {
          "reservation_frontier": {
            "properties": {
              "reservation_claim_event_ref": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reservation_frontier": {
            "properties": {
              "claim_state_at_transition": {
                "const": "claimed"
              }
            },
            "required": [
              "claim_state_at_transition"
            ]
          }
        },
        "required": [
          "reservation_frontier"
        ]
      },
      "then": {
        "properties": {
          "reservation_frontier": {
            "properties": {
              "reservation_claim_event_ref": {
                "$ref": "#/$defs/work_lease_reservation_claimed_event_reference"
              }
            }
          }
        }
      }
    }
  ],
  "x-odeya-work-lease-state-machine": {
    "aggregate_absence_state": "unleased",
    "canonical_states": [
      "unleased",
      "active",
      "released",
      "revoked",
      "expired"
    ],
    "record_states": [
      "active",
      "released",
      "revoked",
      "expired"
    ],
    "terminal_states": [
      "released",
      "revoked",
      "expired"
    ],
    "projection_only_labels": [
      "stale",
      "completed"
    ],
    "terminal_reentry_allowed": false,
    "first_slice_transitions": [
      {
        "event_type": "work.lease_acquired",
        "from": "unleased",
        "to": "active"
      },
      {
        "event_type": "work.lease_released",
        "from": "active",
        "to": "released"
      },
      {
        "event_type": "work.lease_revoked",
        "from": "active",
        "to": "revoked"
      },
      {
        "event_type": "work.lease_expired",
        "from": "active",
        "to": "expired"
      }
    ],
    "first_slice_reservation_frontier": {
      "work.lease_acquired": "unclaimed",
      "work.lease_released": "claimed_requires_separate_settlement",
      "work.lease_revoked": "unclaimed_or_claimed_requires_separate_settlement_if_claimed",
      "work.lease_expired": "unclaimed",
      "lease_transition_changes_resource_reservation_state": false
    },
    "outside_first_slice_transition": {
      "event_type": "work.lease_renewed",
      "from": "active",
      "to": "active",
      "candidate_support_status": "outside_scope_not_constructible"
    }
  },
  "$defs": {
    "work_lease_identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]+$"
    },
    "work_lease_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "work_lease_record_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "x-odeya-digest-scope": {
        "algorithm": "sha-256",
        "subject": "exact referenced canonical record bytes",
        "profile_source": "referenced record registry member",
        "schema_source": "schema_id sibling",
        "status": "requires_offline_registry_resolution",
        "kind": "canonical_object_digest"
      }
    },
    "work_lease_event_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "x-odeya-digest-scope": {
        "algorithm": "sha-256",
        "subject": "exact referenced ResearchEvent canonical bytes",
        "profile_source": "referenced event contract member",
        "schema_source": "event_type and event_version siblings",
        "status": "requires_offline_event_registry_resolution",
        "kind": "canonical_object_digest"
      }
    },
    "work_lease_artifact_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "x-odeya-digest-scope": {
        "algorithm": "sha-256",
        "subject": "exact artifact bytes",
        "profile_source": "raw_bytes",
        "schema_source": "media_type sibling",
        "status": "requires_artifact_store_resolution",
        "kind": "byte_digest"
      }
    },
    "work_lease_artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_artifact_digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 3,
          "maxLength": 255,
          "pattern": "^[a-z0-9!#$&^_.+-]+/[a-z0-9!#$&^_.+-]+$"
        }
      }
    },
    "work_lease_schema_bound_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest",
        "artifact_ref"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "schema_id": {
          "type": "string",
          "minLength": 16,
          "maxLength": 255,
          "pattern": "^urn:odeya:schema:[a-z0-9-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_record_digest"
        },
        "artifact_ref": {
          "$ref": "#/$defs/work_lease_artifact_reference"
        }
      }
    },
    "work_lease_work_intent_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/work_lease_schema_bound_record_reference"
        },
        {
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:work-intent:0.7.0"
            }
          },
          "required": [
            "schema_id"
          ]
        }
      ]
    },
    "canonical_work_lease_transition_event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "digest"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "event_type": {
          "enum": [
            "work.lease_acquired",
            "work.lease_released",
            "work.lease_revoked",
            "work.lease_expired"
          ]
        },
        "event_version": {
          "const": "1.0.0"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_event_digest"
        }
      }
    },
    "work_lease_active_event_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/canonical_work_lease_transition_event_reference"
        },
        {
          "properties": {
            "event_type": {
              "const": "work.lease_acquired"
            }
          },
          "required": [
            "event_type"
          ]
        }
      ]
    },
    "work_lease_reservation_created_event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "digest"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "event_type": {
          "const": "resource.reservation_created"
        },
        "event_version": {
          "const": "1.0.0"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_event_digest"
        }
      }
    },
    "work_lease_reservation_claimed_event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "digest"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "event_type": {
          "const": "resource.reservation_claimed"
        },
        "event_version": {
          "const": "1.0.0"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_event_digest"
        }
      }
    },
    "work_lease_assignment_event_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "digest"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/work_lease_identifier"
        },
        "event_type": {
          "const": "verification.assigned"
        },
        "event_version": {
          "const": "1.0.0"
        },
        "digest": {
          "$ref": "#/$defs/work_lease_event_digest"
        }
      }
    }
  }
}
