          "properties": {
            "axis_id": {
              "const": "aggregate_state_member_version"
            }
          }
        }
      ]
    },
    "reducer_member_version_axis": {
      "allOf": [
        {
          "$ref": "#/$defs/version_axis_base"
        },
        {
          "properties": {
            "axis_id": {
              "const": "reducer_member_version"
            }
          }
        }
      ]
    },
    "prospective_domain_registration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_separator",
        "subject_class",
        "intended_declaring_schema_id",
        "reservation_source",
        "registration_status"
      ],
      "properties": {
        "domain_separator": {
          "type": "string",
          "pattern": "^odeya-[a-z0-9-]+-v[1-9][0-9]*$"
        },
        "subject_class": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "minLength": 1,
          "maxLength": 96
        },
        "intended_declaring_schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "reservation_source": {
          "const": "architecture/canonicalization-disposition-acceptance.json"
        },
        "registration_status": {
          "const": "prospective_name_reserved_no_declaring_constant"
        }
      }
    }
  }
}
