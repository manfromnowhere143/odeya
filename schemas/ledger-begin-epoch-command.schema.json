{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:ledger-begin-epoch-command:0.1.0",
  "title": "Odeya ledger.begin_epoch command payload",
  "description": "Architecture-only closed command payload. Structural validity does not establish referenced evidence, authority, time, signature, quorum, or execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recovery_decision_ref",
    "expected_recovery_decision",
    "new_epoch_id",
    "known_prior_head_refs",
    "checkpoint_refs",
    "branch_selection_evidence_ref",
    "identity_non_reuse_rule_ref",
    "unresolved_receipt_set_ref",
    "wall_clock_branch_selection",
    "authority_assignment_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "expected_recovery_decision": {
      "const": "constitutional_new_epoch"
    },
    "known_prior_head_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "checkpoint_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "wall_clock_branch_selection": {
      "const": false
    },
    "authority_assignment_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "recovery_decision_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "new_epoch_id": {
      "$ref": "#/$defs/identifier"
    },
    "branch_selection_evidence_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "identity_non_reuse_rule_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "unresolved_receipt_set_ref": {
      "$ref": "#/$defs/artifact_reference"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "service_scope": {
      "enum": [
        "incident_cockpit",
        "canonical_reads",
        "reconciliation_commands",
        "ordinary_research_writes",
        "publication",
        "spending",
        "r2_plus_effects",
        "physical_actions"
      ]
    }
  }
}
