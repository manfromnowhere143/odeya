{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:ledger-checkpoint:0.6.0",
  "title": "Odeya LedgerCheckpoint",
  "description": "A signed, immutable commitment to one inclusive canonical ledger frontier and the exact C0 semantic registry bundle required to interpret it. It supports integrity, registry-resolution, and consistency evidence; schema validity does not prove digest/signature/membership correctness, scientific validity, or preservation of private payload bytes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint_id",
    "version",
    "ledger_epoch",
    "inclusive_global_position",
    "controlled_commit_time",
    "commitments",
    "constitutional_snapshots",
    "artifact_verification_coverage",
    "previous_checkpoint",
    "witness_policy_ref",
    "checkpoint_digest_contract",
    "checkpoint_digest",
    "signatures"
  ],
  "properties": {
    "schema_version": {
      "const": "0.6.0"
    },
    "checkpoint_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "ledger_epoch": {
      "$ref": "#/$defs/identifier"
    },
    "inclusive_global_position": {
      "type": "integer",
      "minimum": 0
    },
    "controlled_commit_time": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "commitments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_batch_set",
        "aggregate_head_set",
        "command_receipt_set",
        "admission_evidence_set",
        "promoted_artifact_registry",
        "unresolved_external_effect_set",
        "open_incident_set"
      ],
      "properties": {
        "event_batch_set": {
          "$ref": "#/$defs/set_commitment"
        },
        "aggregate_head_set": {
          "$ref": "#/$defs/set_commitment"
        },
        "command_receipt_set": {
          "$ref": "#/$defs/set_commitment"
        },
        "admission_evidence_set": {
          "$ref": "#/$defs/set_commitment"
        },
        "promoted_artifact_registry": {
          "$ref": "#/$defs/set_commitment"
        },
        "unresolved_external_effect_set": {
          "$ref": "#/$defs/set_commitment"
        },
        "open_incident_set": {
          "$ref": "#/$defs/set_commitment"
        }
      }
    },
    "constitutional_snapshots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_contract_root",
        "aggregate_state_subject_registry",
        "root_authority_manifest",
        "trust_root_set",
        "schema_registry",
        "c0_registry_bundle",
        "command_contract_registry",
        "event_contract_registry",
        "reducer_registry",
        "module_dependency_manifest",
        "resource_unit_profile_registry",
        "semantic_rule_registry",
        "policy_registry",
        "canonicalization_profile",
        "method_registry"
      ],
      "properties": {
        "engine_contract_root": {
          "$ref": "#/$defs/engine_contract_root_reference"
        },
        "aggregate_state_subject_registry": {
          "$ref": "#/$defs/aggregate_state_subject_registry_reference"
        },
        "root_authority_manifest": {
          "$ref": "#/$defs/versioned_reference"
        },
        "trust_root_set": {
          "$ref": "#/$defs/versioned_reference"
        },
        "schema_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "c0_registry_bundle": {
          "$ref": "#/$defs/versioned_reference"
        },
        "command_contract_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "event_contract_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "reducer_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "module_dependency_manifest": {
          "$ref": "#/$defs/versioned_reference"
        },
        "resource_unit_profile_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "semantic_rule_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "policy_registry": {
          "$ref": "#/$defs/versioned_reference"
        },
        "canonicalization_profile": {
          "$ref": "#/$defs/versioned_reference"
        },
        "method_registry": {
          "$ref": "#/$defs/versioned_reference"
        }
      }
    },
    "artifact_verification_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered_count",
        "full_bytes_verified_count",
        "metadata_only_count",
        "missing_count",
        "corrupt_count",
        "verification_method_ref",
        "coverage_result_ref"
      ],
      "properties": {
        "registered_count": {
          "type": "integer",
          "minimum": 0
        },
        "full_bytes_verified_count": {
          "type": "integer",
          "minimum": 0
        },
        "metadata_only_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_count": {
          "type": "integer",
          "minimum": 0
        },
        "corrupt_count": {
          "type": "integer",
          "minimum": 0
        },
        "verification_method_ref": {
          "$ref": "#/$defs/method_reference"
        },
        "coverage_result_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "previous_checkpoint": {
      "oneOf": [
        {
          "$ref": "#/$defs/checkpoint_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "witness_policy_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "checkpoint_digest_contract": {
      "$ref": "#/$defs/checkpoint_digest_contract"
    },
    "checkpoint_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-ledger-checkpoint-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/signature_record"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "versioned_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "engine_contract_root_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/versioned_reference"
        },
        {
          "required": [
            "schema_id"
          ],
          "properties": {
            "version": {
              "const": "0.1.0"
            },
            "schema_id": {
              "const": "urn:odeya:schema:engine-contract-root:0.4.0"
            }
          }
        }
      ]
    },
    "aggregate_state_subject_registry_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/versioned_reference"
        },
        {
          "required": [
            "schema_id"
          ],
          "properties": {
            "version": {
              "const": "0.1.0"
            },
            "schema_id": {
              "const": "urn:odeya:schema:aggregate-state-subject-registry:0.4.0"
            }
          }
        }
      ]
    },
    "method_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "version",
        "registry_digest"
      ],
      "properties": {
        "method_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "registry_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-method-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "checkpoint_digest_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "domain_separator",
        "canonicalization_profile_ref",
        "schema_binding",
        "included_json_pointers",
        "excluded_json_pointers"
      ],
      "properties": {
        "algorithm": {
          "const": "sha-256"
        },
        "domain_separator": {
          "const": "odeya-ledger-checkpoint-v1"
        },
        "canonicalization_profile_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "object_id",
            "version",
            "digest"
          ],
          "properties": {
            "object_id": {
              "const": "odeya-jcs"
            },
            "version": {
              "const": "0.1.0"
            },
            "digest": {
              "$ref": "#/$defs/digest",
              "x-odeya-digest-scope": {
                "kind": "canonical_object_digest",
                "domain": "odeya-ledger-checkpoint-v1",
                "algorithm": "sha-256",
                "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
                "status": "registered_domain"
              }
            }
          }
        },
        "schema_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_id",
            "schema_digest"
          ],
          "properties": {
            "schema_id": {
              "const": "urn:odeya:schema:ledger-checkpoint:0.6.0"
            },
            "schema_digest": {
              "$ref": "#/$defs/digest",
              "x-odeya-digest-scope": {
                "kind": "byte_digest",
                "subject": "retained schema resource bytes",
                "algorithm": "sha-256",
                "profile": "not_a_canonical_object_digest",
                "status": "accepted_disposition_annotation"
              }
            }
          }
        },
        "included_json_pointers": {
          "const": [
            "/schema_version",
            "/checkpoint_id",
            "/version",
            "/ledger_epoch",
            "/inclusive_global_position",
            "/controlled_commit_time",
            "/commitments",
            "/constitutional_snapshots",
            "/artifact_verification_coverage",
            "/previous_checkpoint",
            "/witness_policy_ref",
            "/checkpoint_digest_contract"
          ]
        },
        "excluded_json_pointers": {
          "const": [
            "/checkpoint_digest",
            "/signatures"
          ]
        }
      }
    },
    "set_commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commitment_profile_ref",
        "root_digest",
        "element_count",
        "ordering_rule",
        "leaf_domain",
        "proof_profile_ref"
      ],
      "properties": {
        "commitment_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "root_digest": {
          "$ref": "#/$defs/digest"
        },
        "element_count": {
          "type": "integer",
          "minimum": 0
        },
        "ordering_rule": {
          "type": "string",
          "minLength": 1
        },
        "leaf_domain": {
          "$ref": "#/$defs/identifier"
        },
        "proof_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "checkpoint_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "version",
        "ledger_epoch",
        "inclusive_global_position",
        "digest"
      ],
      "properties": {
        "checkpoint_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "ledger_epoch": {
          "$ref": "#/$defs/identifier"
        },
        "inclusive_global_position": {
          "type": "integer",
          "minimum": 0
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-ledger-checkpoint-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "signature_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signer_id",
        "key_id",
        "algorithm_profile_ref",
        "signature_purpose",
        "signed_digest",
        "signature_ref",
        "signed_at"
      ],
      "properties": {
        "signer_id": {
          "$ref": "#/$defs/identifier"
        },
        "key_id": {
          "$ref": "#/$defs/identifier"
        },
        "algorithm_profile_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "signature_purpose": {
          "const": "odeya-ledger-checkpoint-v1"
        },
        "signed_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-ledger-checkpoint-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "signature_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
        }
      }
    }
  }
}
