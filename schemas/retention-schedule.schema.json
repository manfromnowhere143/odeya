{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:retention-schedule:0.1.0",
  "title": "Odeya RetentionSchedule",
  "description": "A bounded lifecycle schedule attached before admission. Unknown storage or deletion capability prevents activation; a legal hold pauses covered destruction only and grants no access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schedule_id", "version", "mission_id", "asset_scope",
    "status", "trigger", "minimum_retention_days", "maximum_retention_days",
    "authoritative_clock_ref", "representation_planes", "legal_hold_behavior",
    "tombstone_profile_ref", "unknown_capabilities", "review_at",
    "data_rights_assignment_ref", "decision_evidence", "decided_at", "decided_by"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "schedule_id": { "$ref": "#/$defs/identifier" },
    "version": { "type": "integer", "minimum": 1 },
    "mission_id": { "$ref": "#/$defs/identifier" },
    "asset_scope": {
      "type": "object", "additionalProperties": false,
      "required": ["asset_refs", "collection_selector_ref"],
      "properties": {
        "asset_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/immutable_reference" } },
        "collection_selector_ref": { "oneOf": [{ "$ref": "#/$defs/artifact_reference" }, { "type": "null" }] }
      },
      "anyOf": [
        { "properties": { "asset_refs": { "minItems": 1 } } },
        { "properties": { "collection_selector_ref": { "$ref": "#/$defs/artifact_reference" } } }
      ]
    },
    "status": { "enum": ["proposed", "active", "denied", "indeterminate"] },
    "trigger": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "event_type", "reference_time_source"],
      "properties": {
        "kind": { "enum": ["admission", "acquisition", "mission_close", "last_access", "contract_end", "consent_withdrawal", "fixed_time"] },
        "event_type": { "$ref": "#/$defs/identifier" },
        "reference_time_source": { "$ref": "#/$defs/versioned_reference" }
      }
    },
    "minimum_retention_days": { "type": "integer", "minimum": 0 },
    "maximum_retention_days": { "type": "integer", "minimum": 0 },
    "authoritative_clock_ref": { "$ref": "#/$defs/versioned_reference" },
    "representation_planes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["plane", "terminal_action", "method_profile_ref", "backup_treatment", "verification_profile_ref"],
        "properties": {
          "plane": { "$ref": "#/$defs/storage_plane" },
          "terminal_action": { "enum": ["delete", "cryptographic_erasure", "bounded_expiry", "return_to_controller", "retain_minimum_tombstone", "unknown"] },
          "method_profile_ref": { "oneOf": [{ "$ref": "#/$defs/versioned_reference" }, { "type": "null" }] },
          "backup_treatment": { "enum": ["selective_rewrite", "key_scoped_erasure", "access_blocked_bounded_expiry", "not_applicable", "unknown"] },
          "verification_profile_ref": { "oneOf": [{ "$ref": "#/$defs/versioned_reference" }, { "type": "null" }] }
        }
      }
    },
    "legal_hold_behavior": {
      "type": "object", "additionalProperties": false,
      "required": ["destruction_effect", "authority_effect", "review_rule_ref", "release_route_ref"],
      "properties": {
        "destruction_effect": { "const": "pause_covered_destruction_only" },
        "authority_effect": { "const": "no_new_access_processing_or_disclosure" },
        "review_rule_ref": { "$ref": "#/$defs/versioned_reference" },
        "release_route_ref": { "$ref": "#/$defs/versioned_reference" }
      }
    },
    "tombstone_profile_ref": { "$ref": "#/$defs/versioned_reference" },
    "unknown_capabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "review_at": { "$ref": "#/$defs/timestamp" },
    "data_rights_assignment_ref": { "$ref": "#/$defs/immutable_reference" },
    "decision_evidence": { "$ref": "#/$defs/artifact_reference" },
    "decided_at": { "$ref": "#/$defs/timestamp" },
    "decided_by": { "$ref": "#/$defs/human_principal" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "active" } }, "required": ["status"] },
      "then": {
        "properties": {
          "unknown_capabilities": { "maxItems": 0 },
          "representation_planes": {
            "items": {
              "properties": {
                "method_profile_ref": { "$ref": "#/$defs/versioned_reference" },
                "verification_profile_ref": { "$ref": "#/$defs/versioned_reference" }
              }
            },
            "not": {
              "contains": {
                "anyOf": [
                  { "properties": { "terminal_action": { "const": "unknown" } }, "required": ["terminal_action"] },
                  { "properties": { "backup_treatment": { "const": "unknown" } }, "required": ["backup_treatment"] }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "indeterminate" } }, "required": ["status"] },
      "then": { "properties": { "unknown_capabilities": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$" },
    "storage_plane": { "enum": ["canonical_metadata", "primary_artifact", "execution_working_set", "derived_retrieval", "observability", "provider_copy", "backup_or_replica", "export_or_publication"] },
    "human_principal": {
      "type": "object", "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": { "principal_id": { "$ref": "#/$defs/identifier" }, "principal_type": { "const": "human" } }
    },
    "immutable_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "integer", "minimum": 1 }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "versioned_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": { "id": { "$ref": "#/$defs/identifier" }, "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "artifact_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "digest", "media_type"],
      "properties": { "artifact_id": { "$ref": "#/$defs/identifier" }, "digest": { "$ref": "#/$defs/digest" }, "media_type": { "type": "string", "minLength": 1 } }
    }
  }
}
