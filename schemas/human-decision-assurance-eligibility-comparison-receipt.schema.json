{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:human-decision-assurance-eligibility-comparison-receipt:0.1.0",
  "title": "Odeya Human Decision Assurance Eligibility Comparison Receipt Candidate",
  "description": "An unissued architecture receipt over exactly three separately authored recomputation results: Python 3.14.2, Node.js 24.18.0, and Java 21.0.9. It binds their common exact inputs and compares every top-level field of the complete direct evaluator output, including participant identity, complete ordered domain and categorical result objects, failures, disposition, and reasons. Agreement is necessary evidence only; it is not approval, authority, or Gate A acceptance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_class",
    "artifact_id",
    "assurance_id",
    "version",
    "candidate_status",
    "common_input_bindings",
    "implementation_identity_inventory",
    "implementation_source_digest_inventory",
    "ordered_result_bindings",
    "field_comparisons",
    "comparison_disposition",
    "agreed_projection",
    "reason_codes",
    "proof_boundary",
    "compared_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "artifact_class": {
      "const": "human_decision_assurance_eligibility_comparison_receipt_candidate"
    },
    "artifact_id": {
      "$ref": "#/$defs/hda_successor_identifier"
    },
    "assurance_id": {
      "$ref": "#/$defs/hda_successor_identifier"
    },
    "version": {
      "const": 1
    },
    "candidate_status": {
      "const": "unissued_architecture_candidate_not_human_authority"
    },
    "common_input_bindings": {
      "$ref": "#/$defs/common_input_bindings"
    },
    "implementation_identity_inventory": {
      "description": "Implementation identifiers in Python, Node.js, Java order. The semantic checker must prove positional equality to ordered_result_bindings.",
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/hda_successor_identifier"
      }
    },
    "implementation_source_digest_inventory": {
      "description": "Pairwise-distinct evaluator source identities in Python, Node.js, Java order. The semantic checker must prove positional equality to ordered_result_bindings.",
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/raw_sha256"
      }
    },
    "ordered_result_bindings": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/python_result_binding"
        },
        {
          "$ref": "#/$defs/nodejs_result_binding"
        },
        {
          "$ref": "#/$defs/java_result_binding"
        }
      ],
      "items": false
    },
    "field_comparisons": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        {
          "$ref": "#/$defs/comparison_participant_id"
        },
        {
          "$ref": "#/$defs/comparison_domain_results"
        },
        {
          "$ref": "#/$defs/comparison_categorical_results"
        },
        {
          "$ref": "#/$defs/comparison_categorical_failures"
        },
        {
          "$ref": "#/$defs/comparison_final_disposition"
        },
        {
          "$ref": "#/$defs/comparison_reason_codes"
        }
      ],
      "items": false
    },
    "comparison_disposition": {
      "enum": [
        "exact_agreement",
        "indeterminate_missing_or_unreadable",
        "invalid_disagreement"
      ]
    },
    "agreed_projection": {
      "oneOf": [
        {
          "$ref": "#/$defs/hda_comparison_full_projection"
        },
        {
          "type": "null"
        }
      ]
    },
    "reason_codes": {
      "$ref": "#/$defs/hda_comparison_reason_codes"
    },
    "proof_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_self_digest_forbidden",
        "receipt_names_or_predicts_seal_identity",
        "one_result_substituted_for_multiple_implementations",
        "shared_evaluator_source_permitted",
        "final_disposition_only_comparison_permitted",
        "agreement_proves_normative_correctness",
        "agreement_is_approval",
        "comparison_grants_authority",
        "organizational_independence_proven",
        "gate_a_accepted",
        "runtime_authorized",
        "external_effects_authorized"
      ],
      "properties": {
        "receipt_self_digest_forbidden": {
          "const": true
        },
        "receipt_names_or_predicts_seal_identity": {
          "const": false
        },
        "one_result_substituted_for_multiple_implementations": {
          "const": false
        },
        "shared_evaluator_source_permitted": {
          "const": false
        },
        "final_disposition_only_comparison_permitted": {
          "const": false
        },
        "agreement_proves_normative_correctness": {
          "const": false
        },
        "agreement_is_approval": {
          "const": false
        },
        "comparison_grants_authority": {
          "const": false
        },
        "organizational_independence_proven": {
          "const": false
        },
        "gate_a_accepted": {
          "const": false
        },
        "runtime_authorized": {
          "const": false
        },
        "external_effects_authorized": {
          "const": false
        }
      }
    },
    "compared_at": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "comparison_disposition": {
            "const": "exact_agreement"
          }
        },
        "required": [
          "comparison_disposition"
        ]
      },
      "then": {
        "properties": {
          "agreed_projection": {
            "$ref": "#/$defs/hda_comparison_full_projection"
          },
          "ordered_result_bindings": {
            "not": {
              "contains": {
                "properties": {
                  "read_disposition": {
                    "enum": [
                      "missing",
                      "unreadable"
                    ]
                  }
                },
                "required": [
                  "read_disposition"
                ]
              }
            }
          },
          "field_comparisons": {
            "prefixItems": [
              {
                "$ref": "#/$defs/comparison_participant_id_agreement"
              },
              {
                "$ref": "#/$defs/comparison_domain_results_agreement"
              },
              {
                "$ref": "#/$defs/comparison_categorical_results_agreement"
              },
              {
                "$ref": "#/$defs/comparison_categorical_failures_agreement"
              },
              {
                "$ref": "#/$defs/comparison_final_disposition_agreement"
              },
              {
                "$ref": "#/$defs/comparison_reason_codes_agreement"
              }
            ]
          },
          "reason_codes": {
            "$ref": "#/$defs/hda_comparison_exact_agreement_reason_codes"
          }
        }
      },
      "else": {
        "properties": {
          "agreed_projection": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparison_disposition": {
            "const": "indeterminate_missing_or_unreadable"
          }
        },
        "required": [
          "comparison_disposition"
        ]
      },
      "then": {
        "properties": {
          "ordered_result_bindings": {
            "contains": {
              "properties": {
                "read_disposition": {
                  "enum": [
                    "missing",
                    "unreadable"
                  ]
                }
              },
              "required": [
                "read_disposition"
              ]
            }
          },
          "field_comparisons": {
            "not": {
              "contains": {
                "properties": {
                  "comparison_disposition": {
                    "const": "disagreement"
                  }
                },
                "required": [
                  "comparison_disposition"
                ]
              }
            }
          },
          "reason_codes": {
            "$ref": "#/$defs/hda_comparison_indeterminate_reason_codes"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparison_disposition": {
            "const": "invalid_disagreement"
          }
        },
        "required": [
          "comparison_disposition"
        ]
      },
      "then": {
        "properties": {
          "field_comparisons": {
            "contains": {
              "properties": {
                "comparison_disposition": {
                  "const": "disagreement"
                }
              },
              "required": [
                "comparison_disposition"
              ]
            }
          },
          "reason_codes": {
            "$ref": "#/$defs/hda_comparison_invalid_reason_codes"
          }
        }
      }
    }
  ],
  "$defs": {
    "hda_successor_identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
    },
    "raw_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "x-odeya-digest-scope": {
        "kind": "byte_digest",
        "subject": "exact raw bytes named by the adjacent immutable binding",
        "algorithm": "sha-256",
        "profile": "not_a_canonical_object_digest",
        "status": "candidate_unissued"
      }
    },
    "nullable_raw_sha256": {
      "oneOf": [
        {
          "$ref": "#/$defs/raw_sha256"
        },
        {
          "type": "null"
        }
      ]
    },
    "positive_byte_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1073741824
    },
    "nullable_positive_byte_count": {
      "oneOf": [
        {
          "$ref": "#/$defs/positive_byte_count"
        },
        {
          "type": "null"
        }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "hda_comparison_reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:eligible|indeterminate|invalid)\\.[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$"
      }
    },
    "hda_comparison_exact_agreement_reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "prefixItems": [
        {
          "const": "eligible.comparison.exact_three_way_full_projection_agreement"
        }
      ],
      "items": false
    },
    "hda_comparison_indeterminate_reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "indeterminate.comparison.java_21_0_9.result_missing",
          "indeterminate.comparison.java_21_0_9.result_unreadable",
          "indeterminate.comparison.nodejs_24_18_0.result_missing",
          "indeterminate.comparison.nodejs_24_18_0.result_unreadable",
          "indeterminate.comparison.python.result_missing",
          "indeterminate.comparison.python.result_unreadable"
        ]
      }
    },
    "hda_comparison_invalid_reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "contains": {
        "enum": [
          "invalid.comparison.categorical_failures.disagreement",
          "invalid.comparison.categorical_results.disagreement",
          "invalid.comparison.domain_results.disagreement",
          "invalid.comparison.final_disposition.disagreement",
          "invalid.comparison.participant_id.disagreement",
          "invalid.comparison.reason_codes.disagreement"
        ]
      },
      "items": {
        "enum": [
          "indeterminate.comparison.java_21_0_9.result_missing",
          "indeterminate.comparison.java_21_0_9.result_unreadable",
          "indeterminate.comparison.nodejs_24_18_0.result_missing",
          "indeterminate.comparison.nodejs_24_18_0.result_unreadable",
          "indeterminate.comparison.python.result_missing",
          "indeterminate.comparison.python.result_unreadable",
          "invalid.comparison.categorical_failures.disagreement",
          "invalid.comparison.categorical_results.disagreement",
          "invalid.comparison.domain_results.disagreement",
          "invalid.comparison.final_disposition.disagreement",
          "invalid.comparison.participant_id.disagreement",
          "invalid.comparison.reason_codes.disagreement"
        ]
      }
    },
    "hda_comparison_raw_schema_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "schema_resource_id",
        "raw_sha256",
        "byte_count",
        "mutable_alias_used"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/hda_successor_identifier"
        },
        "schema_resource_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9][a-z0-9-]*:[0-9]+\\.[0-9]+\\.[0-9]+$",
          "maxLength": 256
        },
        "raw_sha256": {
          "$ref": "#/$defs/raw_sha256"
        },
        "byte_count": {
          "$ref": "#/$defs/positive_byte_count"
        },
        "mutable_alias_used": {
          "const": false
        }
      }
    },
    "raw_artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "raw_sha256",
        "byte_count",
        "mutable_alias_used"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/hda_successor_identifier"
        },
        "raw_sha256": {
          "$ref": "#/$defs/raw_sha256"
        },
        "byte_count": {
          "$ref": "#/$defs/positive_byte_count"
        },
        "mutable_alias_used": {
          "const": false
        }
      }
    },
    "ruleset_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleset_id",
        "ruleset_version",
        "raw_sha256",
        "byte_count",
        "mutable_alias_used"
      ],
      "properties": {
        "ruleset_id": {
          "const": "urn:odeya:human-decision-assurance-eligibility:0.2.0-candidate"
        },
        "ruleset_version": {
          "const": "0.2.0"
        },
        "raw_sha256": {
          "$ref": "#/$defs/raw_sha256"
        },
        "byte_count": {
          "$ref": "#/$defs/positive_byte_count"
        },
        "mutable_alias_used": {
          "const": false
        }
      }
    },
    "common_input_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "backing_byte_verification_receipt",
        "eligibility_ruleset",
        "input_manifest",
        "normative_input_vector"
      ],
      "properties": {
        "evidence": {
          "allOf": [
            {
              "$ref": "#/$defs/hda_comparison_raw_schema_binding"
            },
            {
              "properties": {
                "schema_resource_id": {
                  "const": "urn:odeya:schema:human-decision-assurance-evidence:0.2.0"
                }
              }
            }
          ]
        },
        "backing_byte_verification_receipt": {
          "allOf": [
            {
              "$ref": "#/$defs/hda_comparison_raw_schema_binding"
            },
            {
              "properties": {
                "schema_resource_id": {
                  "const": "urn:odeya:schema:human-decision-assurance-backing-byte-verification-receipt:0.1.0"
                }
              }
            }
          ]
        },
        "eligibility_ruleset": {
          "$ref": "#/$defs/ruleset_binding"
        },
        "input_manifest": {
          "$ref": "#/$defs/raw_artifact_binding"
        },
        "normative_input_vector": {
          "$ref": "#/$defs/raw_artifact_binding"
        }
      }
    },
    "final_disposition": {
      "enum": [
        "eligible",
        "indeterminate",
        "invalid"
      ]
    },
    "hda_comparison_domain": {
      "enum": [
        "exact_core_and_evidence_binding",
        "backing_byte_integrity",
        "challenge_and_replay",
        "decision_confirmation",
        "authentication",
        "identity_and_authenticator_binding",
        "custody",
        "delegation_objections_conflicts",
        "controlled_time",
        "verifier_independence",
        "sanitation"
      ]
    },
    "hda_comparison_domain_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "input_observation_count",
        "folded_status",
        "reason_codes"
      ],
      "properties": {
        "domain": {
          "$ref": "#/$defs/hda_comparison_domain"
        },
        "input_observation_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "folded_status": {
          "enum": [
            "supported",
            "contradicted",
            "unknown",
            "not_applicable"
          ]
        },
        "reason_codes": {
          "$ref": "#/$defs/hda_comparison_reason_codes"
        }
      }
    },
    "hda_comparison_domain_results": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "prefixItems": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result_exact_binding"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_backing_integrity"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_challenge"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_confirmation"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_authentication"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_identity"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_custody"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_delegation"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_controlled_time"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_verifier"
        },
        {
          "$ref": "#/$defs/hda_comparison_domain_result_sanitation"
        }
      ],
      "items": false
    },
    "hda_comparison_domain_result_exact_binding": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "exact_core_and_evidence_binding"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_backing_integrity": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "backing_byte_integrity"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_challenge": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "challenge_and_replay"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_confirmation": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "decision_confirmation"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_authentication": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "authentication"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_identity": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "identity_and_authenticator_binding"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_custody": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "custody"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_delegation": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "delegation_objections_conflicts"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_controlled_time": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "controlled_time"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_verifier": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "verifier_independence"
            }
          }
        }
      ]
    },
    "hda_comparison_domain_result_sanitation": {
      "allOf": [
        {
          "$ref": "#/$defs/hda_comparison_domain_result"
        },
        {
          "properties": {
            "domain": {
              "const": "sanitation"
            }
          }
        }
      ]
    },
    "hda_comparison_categorical_condition": {
      "enum": [
        "challenge_consumption_state_fresh_consumed_once",
        "challenge_not_previously_consumed",
        "challenge_consumed_exactly_once",
        "assertion_acceptance_and_consumption_atomic_action_equal",
        "decision_confirmation_principal_matches_observation",
        "decision_confirmation_human_initiated",
        "decision_confirmation_separate_from_authenticator_gesture",
        "same_origin_candidate_context_supported",
        "no_authenticator_clone_risk_signal",
        "no_shared_effective_control_principals",
        "verifier_distinct_principal_and_effective_control"
      ]
    },
    "hda_comparison_categorical_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition_id",
        "status",
        "reason_codes"
      ],
      "properties": {
        "condition_id": {
          "$ref": "#/$defs/hda_comparison_categorical_condition"
        },
        "status": {
          "enum": [
            "satisfied",
            "failed",
            "unknown",
            "not_applicable"
          ]
        },
        "reason_codes": {
          "$ref": "#/$defs/hda_comparison_reason_codes"
        }
      }
    },
    "hda_comparison_categorical_results": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "prefixItems": [
        {
          "$ref": "#/$defs/hda_comparison_categorical_result_consumption_state"
        },
        {
          "$ref": "#/$defs/hda_comparison_categorical_result_prior_consumption"
        },
        {
          "$ref": "#/$defs/hda_comparison_categorical_result_result_consumption"
        },
        {
          "$ref": "#/$defs/hda_comparison_categorical_result_atomic_action"
        },
