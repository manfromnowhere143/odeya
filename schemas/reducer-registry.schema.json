{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:reducer-registry:0.4.0",
  "title": "Odeya ReducerRegistry",
  "description": "An immutable canonical-reducer map with exactly one reducer slot per aggregate type in a snapshot. Each reducer starts only from explicit absence plus an origin event, accepts a closed event set, returns next state or typed failure for every input, and binds independent implementation requirements. Structural validity does not prove an implementation or replay result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_kind",
    "registry_id",
    "version",
    "conformance_scope",
    "supersedes_registry_subject_ref",
    "canonicalization_profile_ref",
    "canonical_slot_contract",
    "members_by_aggregate",
    "member_set_commitment",
    "graph_closure_contract",
    "historical_read_policy",
    "source_manifest_ref",
    "generator_identity_ref",
    "review_evidence_refs",
    "known_limitations",
    "registry_digest_contract",
    "registry_digest",
    "external_attestations"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "registry_kind": {
      "const": "reducer_registry"
    },
    "registry_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "$ref": "#/$defs/semantic_version"
    },
    "conformance_scope": {
      "enum": [
        "registry_subject",
        "structural_fixture_only"
      ]
    },
    "supersedes_registry_subject_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/subject_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "canonicalization_profile_ref": {
      "$ref": "#/$defs/profile_reference"
    },
    "canonical_slot_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map_key",
        "reducers_per_aggregate",
        "duplicate_json_keys",
        "member_key_must_equal_aggregate_type_rule_ref"
      ],
      "properties": {
        "map_key": {
          "const": "aggregate_type"
        },
        "reducers_per_aggregate": {
          "const": 1
        },
        "duplicate_json_keys": {
          "const": "reject_before_canonicalization"
        },
        "member_key_must_equal_aggregate_type_rule_ref": {
          "$ref": "#/$defs/rule_reference"
        }
      }
    },
    "members_by_aggregate": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 256,
      "propertyNames": {
        "$ref": "#/$defs/identifier"
      },
      "additionalProperties": {
        "$ref": "#/$defs/reducer_contract"
      }
    },
    "member_set_commitment": {
      "$ref": "#/$defs/member_set_commitment"
    },
    "graph_closure_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_events_must_resolve",
        "state_subject_must_resolve",
        "event_owner_must_match",
        "accepted_event_reference",
        "content_digest_dependency_order",
        "content_digest_cycles",
        "unresolved_or_ambiguous_edge"
      ],
      "properties": {
        "accepted_events_must_resolve": {
          "const": true
        },
        "state_subject_must_resolve": {
          "const": true
        },
        "event_owner_must_match": {
          "const": true
        },
        "accepted_event_reference": {
          "const": "same_root_exact_member_logical_back_reference"
        },
        "content_digest_dependency_order": {
          "const": "schema_to_state_to_reducer_to_event_to_command"
        },
        "content_digest_cycles": {
          "const": "forbidden"
        },
        "unresolved_or_ambiguous_edge": {
          "const": "block_root_construction"
        }
      }
    },
    "historical_read_policy": {
      "$ref": "#/$defs/historical_read_policy"
    },
    "source_manifest_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "generator_identity_ref": {
      "$ref": "#/$defs/artifact_reference"
    },
    "review_evidence_refs": {
      "$ref": "#/$defs/nonempty_artifact_array"
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/known_limitation"
      }
    },
    "registry_digest_contract": {
      "$ref": "#/$defs/registry_digest_contract"
    },
    "registry_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-reducer-registry-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "external_attestations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/attestation"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "subject_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "version",
        "schema_id",
        "canonical_digest"
      ],
      "properties": {
        "subject_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "schema_id": {
          "type": "string",
          "format": "uri"
        },
        "canonical_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "profile_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "version",
        "digest"
      ],
      "properties": {
        "profile_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 127
        }
      }
    },
    "nonempty_artifact_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "rule_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "version",
        "rule_digest"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "rule_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-rule-record-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        }
      }
    },
    "state_member_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregate_type",
        "state_subject_id",
        "state_subject_version",
        "state_member_digest"
      ],
      "properties": {
        "aggregate_type": {
          "$ref": "#/$defs/identifier"
        },
        "state_subject_id": {
          "$ref": "#/$defs/identifier"
        },
        "state_subject_version": {
          "$ref": "#/$defs/semantic_version"
        },
        "state_member_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-aggregate-state-subject-member-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "event_member_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "event_version",
        "resolution"
      ],
      "properties": {
        "event_type": {
          "$ref": "#/$defs/identifier"
        },
        "event_version": {
          "$ref": "#/$defs/semantic_version"
        },
        "resolution": {
          "const": "same_root_exact_member"
        }
      }
    },
    "origin_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pre_origin_input",
        "aggregate_absent_before_origin",
        "absence_is_state",
        "origin_event_refs",
        "first_materialized_version",
        "fabricated_v0_state",
        "non_origin_on_absence"
      ],
      "properties": {
        "pre_origin_input": {
          "const": "explicit_absence_sentinel"
        },
        "aggregate_absent_before_origin": {
          "const": true
        },
        "absence_is_state": {
          "const": false
        },
        "origin_event_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/event_member_reference"
          }
        },
        "first_materialized_version": {
          "const": 1
        },
        "fabricated_v0_state": {
          "const": "forbidden"
        },
        "non_origin_on_absence": {
          "const": "typed_failure"
        }
      }
    },
    "total_fold_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_union",
        "unknown_event",
        "unknown_major_version",
        "wrong_aggregate",
        "broken_event_head",
        "invalid_prior_state",
        "invariant_failure",
        "exception_or_timeout",
        "ignore_unknown_events"
      ],
      "properties": {
        "result_union": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "const": "next_state"
            },
            {
              "const": "typed_reduction_failure"
            }
          ],
          "items": false
        },
        "unknown_event": {
          "const": "typed_reduction_failure"
        },
        "unknown_major_version": {
          "const": "typed_reduction_failure"
        },
        "wrong_aggregate": {
          "const": "typed_reduction_failure"
        },
        "broken_event_head": {
          "const": "typed_reduction_failure"
        },
        "invalid_prior_state": {
          "const": "typed_reduction_failure"
        },
        "invariant_failure": {
          "const": "typed_reduction_failure"
        },
        "exception_or_timeout": {
          "const": "typed_reduction_failure"
        },
        "ignore_unknown_events": {
          "const": false
        }
      }
    },
    "state_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis_id",
        "state_json_pointer",
        "value_schema_ref",
        "unknown_semantics",
        "cross_axis_inference"
      ],
      "properties": {
        "axis_id": {
          "$ref": "#/$defs/identifier"
        },
        "state_json_pointer": {
          "type": "string",
          "pattern": "^/([A-Za-z0-9_.-]|~0|~1)+$"
        },
        "value_schema_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "unknown_semantics": {
          "enum": [
            "explicit_unknown_value",
            "axis_not_applicable",
            "unknown_forbidden"
          ]
        },
        "cross_axis_inference": {
          "const": "forbidden_without_rule"
        }
      }
    },
    "trace_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "positive",
        "negative",
        "boundary",
        "metamorphic",
        "race",
        "replay",
        "compatibility"
      ],
      "properties": {
        "positive": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "negative": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "boundary": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "metamorphic": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "race": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "replay": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "compatibility": {
          "$ref": "#/$defs/nonempty_artifact_array"
        }
      }
    },
    "implementation_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_independent_implementations",
        "requirement_refs",
        "language_and_runtime_separation",
        "shared_reducer_code",
        "copied_logic",
        "per_event_state_digest_required",
        "agreement_is_sufficient_for_acceptance"
      ],
      "properties": {
        "minimum_independent_implementations": {
          "const": 2
        },
        "requirement_refs": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "language_and_runtime_separation": {
          "const": true
        },
        "shared_reducer_code": {
          "const": "forbidden"
        },
        "copied_logic": {
          "const": "forbidden"
        },
        "per_event_state_digest_required": {
          "const": true
        },
        "agreement_is_sufficient_for_acceptance": {
          "const": false
        }
      }
    },
    "upcast_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "policy_ref",
        "registered_upcast_refs",
        "implicit_upcast",
        "historical_event_rewrite"
      ],
      "properties": {
        "policy": {
          "enum": [
            "exact_version_only",
            "explicit_registered_upcast_only"
          ]
        },
        "policy_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "registered_upcast_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "implicit_upcast": {
          "const": false
        },
        "historical_event_rewrite": {
          "const": "forbidden"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "policy": {
                "const": "explicit_registered_upcast_only"
              }
            },
            "required": [
              "policy"
            ]
          },
          "then": {
            "properties": {
              "registered_upcast_refs": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "registered_upcast_refs": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "reducer_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregate_type",
        "reducer_id",
        "reducer_version",
        "owning_module",
        "state_subject_ref",
        "origin_contract",
        "accepted_events",
        "total_fold_semantics",
        "state_axes",
        "invariant_rule_refs",
        "transition_rule_refs",
        "upcast_contract",
        "trace_contract",
        "implementation_requirements",
        "resource_limits",
        "review_evidence_refs",
        "member_digest_contract",
        "member_digest"
      ],
      "properties": {
        "aggregate_type": {
          "$ref": "#/$defs/identifier"
        },
        "reducer_id": {
          "$ref": "#/$defs/identifier"
        },
        "reducer_version": {
          "$ref": "#/$defs/semantic_version"
        },
        "owning_module": {
          "$ref": "#/$defs/identifier"
        },
        "state_subject_ref": {
          "$ref": "#/$defs/state_member_reference"
        },
        "origin_contract": {
          "$ref": "#/$defs/origin_contract"
        },
        "accepted_events": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/event_member_reference"
          }
        },
        "total_fold_semantics": {
          "$ref": "#/$defs/total_fold_semantics"
        },
        "state_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/state_axis"
          }
        },
        "invariant_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rule_reference"
          }
        },
        "transition_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rule_reference"
          }
        },
        "upcast_contract": {
          "$ref": "#/$defs/upcast_contract"
        },
        "trace_contract": {
          "$ref": "#/$defs/trace_contract"
        },
        "implementation_requirements": {
          "$ref": "#/$defs/implementation_requirements"
        },
        "resource_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_event_bytes",
            "max_state_bytes",
            "max_steps_per_event",
            "wall_clock_or_io_inputs"
          ],
          "properties": {
            "max_event_bytes": {
              "type": "integer",
              "minimum": 2
            },
            "max_state_bytes": {
              "type": "integer",
              "minimum": 2
            },
            "max_steps_per_event": {
              "type": "integer",
              "minimum": 1
            },
            "wall_clock_or_io_inputs": {
              "const": "forbidden"
            }
          }
        },
        "review_evidence_refs": {
          "$ref": "#/$defs/nonempty_artifact_array"
        },
        "member_digest_contract": {
          "$ref": "#/$defs/reducer_member_digest_contract"
        },
        "member_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-reducer-registry-member-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        }
      }
    },
    "member_set_commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "member_count",
        "ordered_member_digests_digest"
      ],
      "properties": {
        "algorithm": {
          "const": "odeya-canonical-map-commitment-v1"
        },
        "member_count": {
          "type": "integer",
          "minimum": 1
        },
        "ordered_member_digests_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "historical_read_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution",
        "historical_reducers_required",
        "mutable_aliases_allowed",
        "unsupported_reader"
      ],
      "properties": {
        "resolution": {
          "const": "exact_reducer_version_and_digest"
        },
        "historical_reducers_required": {
          "const": true
        },
        "mutable_aliases_allowed": {
          "const": false
        },
        "unsupported_reader": {
          "const": "typed_reduction_failure"
        }
      }
    },
    "known_limitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "limitation_id",
        "severity",
        "statement",
        "consequence"
      ],
      "properties": {
        "limitation_id": {
          "$ref": "#/$defs/identifier"
        },
        "severity": {
          "enum": [
            "low",
            "moderate",
            "high",
            "critical"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "consequence": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestation_id",
        "subject_digest",
        "signer_id",
        "algorithm",
        "signature_ref"
      ],
      "properties": {
        "attestation_id": {
          "$ref": "#/$defs/identifier"
        },
        "subject_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-reducer-registry-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "registered_domain"
          }
        },
        "signer_id": {
          "$ref": "#/$defs/identifier"
        },
        "algorithm": {
          "type": "string",
          "minLength": 1,
          "maxLength": 127
        },
        "signature_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "schema_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "schema_digest"
      ],
      "properties": {
        "schema_id": {
          "type": "string",
          "format": "uri"
        },
        "schema_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "retained schema resource bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        }
      }
    },
    "reducer_member_digest_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
