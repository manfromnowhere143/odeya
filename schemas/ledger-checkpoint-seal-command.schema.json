{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:ledger-checkpoint-seal-command:0.3.0",
  "title": "Odeya ledger_checkpoint.seal command payload",
  "description": "Architecture-only closed command payload. Structural validity does not establish referenced evidence, authority, time, signature, quorum, or execution truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_event_ref",
    "checkpoint_ref",
    "ledger_epoch",
    "inclusive_global_position",
    "candidate_digest",
    "checkpoint_digest",
    "previous_checkpoint_ref",
    "signature_verification_refs",
    "consistency_verification_ref",
    "authority_assignment_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "inclusive_global_position": {
      "type": "integer",
      "minimum": 0
    },
    "previous_checkpoint_ref": {
      "oneOf": [
        {
          "$ref": "#/$defs/canonical_record_reference"
        },
        {
          "type": "null"
        }
      ]
    },
    "signature_verification_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "authority_assignment_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "proposal_event_ref": {
      "$ref": "#/$defs/identifier"
    },
    "checkpoint_ref": {
      "$ref": "#/$defs/canonical_record_reference"
    },
    "ledger_epoch": {
      "$ref": "#/$defs/identifier"
    },
    "candidate_digest": {
      "$ref": "#/$defs/digest"
    },
    "checkpoint_digest": {
      "$ref": "#/$defs/digest",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "domain": "odeya-ledger-checkpoint-v1",
        "algorithm": "sha-256",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
        "status": "registered_domain"
      }
    },
    "consistency_verification_ref": {
      "$ref": "#/$defs/artifact_reference"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "canonical_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_id",
        "version",
        "schema_id",
        "digest"
      ],
      "properties": {
        "object_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "schema_id": {
          "type": "string",
          "pattern": "^urn:odeya:schema:[a-z0-9._-]+:[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "service_scope": {
      "enum": [
        "incident_cockpit",
        "canonical_reads",
        "reconciliation_commands",
        "ordinary_research_writes",
        "publication",
        "spending",
        "r2_plus_effects",
        "physical_actions"
      ]
    }
  }
}
