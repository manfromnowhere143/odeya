{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:rights-assertion:0.2.0",
  "title": "Odeya RightsAssertion",
  "description": "Evidence of a source-provided rights claim. authority_effect is permanently evidence_only_no_permission; only a separate DataUseDecision can authorize use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assertion_id",
    "version",
    "asset",
    "basis_type",
    "assertion_status",
    "authority_effect",
    "asserted_by",
    "evidence_refs",
    "claimed_terms",
    "verification_disposition",
    "limitations",
    "observed_at",
    "recorded_at",
    "recorded_by"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "assertion_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "asset": {
      "$ref": "#/$defs/immutable_reference"
    },
    "basis_type": {
      "enum": [
        "license",
        "contract",
        "consent",
        "public_domain_claim",
        "terms_of_service",
        "policy_assertion",
        "controller_attestation",
        "unknown"
      ]
    },
    "assertion_status": {
      "enum": [
        "asserted",
        "disputed",
        "withdrawn",
        "basis_unavailable"
      ]
    },
    "authority_effect": {
      "const": "evidence_only_no_permission"
    },
    "asserted_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type",
        "claimed_relationship_to_asset",
        "authentication_evidence_ref"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "organization",
            "source_system",
            "unknown"
          ]
        },
        "claimed_relationship_to_asset": {
          "enum": [
            "controller",
            "licensor",
            "data_subject",
            "contributor",
            "publisher",
            "custodian",
            "unknown"
          ]
        },
        "authentication_evidence_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/artifact_reference"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifact_reference"
      }
    },
    "claimed_terms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license_expression",
        "purposes",
        "operations",
        "recipient_classes",
        "geographic_regions",
        "effective_at",
        "expires_at",
        "withdrawal_route",
        "unknown_terms_present"
      ],
      "properties": {
        "license_expression": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "purposes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "operations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/operation"
          }
        },
        "recipient_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "geographic_regions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "effective_at": {
          "oneOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "oneOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "withdrawal_route": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "unknown_terms_present": {
          "type": "boolean"
        }
      }
    },
    "verification_disposition": {
      "enum": [
        "unreviewed",
        "supported_as_evidence",
        "disputed",
        "indeterminate"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observed_at": {
      "$ref": "#/$defs/timestamp"
    },
    "recorded_at": {
      "$ref": "#/$defs/timestamp"
    },
    "recorded_by": {
      "$ref": "#/$defs/principal"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "basis_type": {
            "const": "unknown"
          }
        },
        "required": [
          "basis_type"
        ]
      },
      "then": {
        "properties": {
          "assertion_status": {
            "const": "basis_unavailable"
          },
          "verification_disposition": {
            "const": "indeterminate"
          },
          "claimed_terms": {
            "properties": {
              "purposes": {
                "maxItems": 0
              },
              "operations": {
                "maxItems": 0
              },
              "recipient_classes": {
                "maxItems": 0
              },
              "geographic_regions": {
                "maxItems": 0
              },
              "unknown_terms_present": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assertion_status": {
            "enum": [
              "disputed",
              "withdrawn",
              "basis_unavailable"
            ]
          }
        },
        "required": [
          "assertion_status"
        ]
      },
      "then": {
        "properties": {
          "verification_disposition": {
            "enum": [
              "disputed",
              "indeterminate"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "operation": {
      "enum": [
        "acquire",
        "inspect",
        "transform",
        "link",
        "infer",
        "execute_on",
        "model_inference",
        "train",
        "fine_tune",
        "embed",
        "cache",
        "log",
        "human_review",
        "evaluate",
        "verify",
        "export",
        "publish",
        "support_access"
      ]
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "deterministic_service"
          ]
        }
      }
    },
    "immutable_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
