{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:authority-assignment:0.3.0",
  "title": "Odeya AuthorityAssignment",
  "description": "An immutable constitutional role assignment derived from a root manifest or an authorized rotation/delegation decision. It is not an operational grant.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assignment_id",
    "version",
    "assignment_kind",
    "role",
    "assignee",
    "source",
    "scope",
    "decision_mode",
    "delegation",
    "separation_constraints",
    "temporal",
    "revocation_route_ref",
    "decision_evidence",
    "signed_by",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "assignment_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "assignment_kind": {
      "enum": [
        "initial",
        "rotation",
        "delegated"
      ]
    },
    "role": {
      "$ref": "#/$defs/role"
    },
    "assignee": {
      "$ref": "#/$defs/principal_binding"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_manifest_digest",
        "root_declaration_id",
        "issuer_assignment_ref",
        "authorization_decision_ref"
      ],
      "properties": {
        "root_manifest_digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain": "odeya-root-authority-manifest-v1",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "prospective_domain_reserved_not_declared"
          }
        },
        "root_declaration_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "issuer_assignment_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/immutable_reference"
            },
            {
              "type": "null"
            }
          ]
        },
        "authorization_decision_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_selectors",
        "action_classes",
        "maximum_risk_tier",
        "data_classes",
        "publication_visibilities",
        "resource_ceiling_ref",
        "policy_profile_ref",
        "forbidden_actions"
      ],
      "properties": {
        "mission_selectors": {
          "$ref": "#/$defs/nonempty_unique_strings"
        },
        "action_classes": {
          "$ref": "#/$defs/nonempty_unique_strings"
        },
        "maximum_risk_tier": {
          "enum": [
            "R0",
            "R1",
            "R2",
            "R3",
            "R4"
          ]
        },
        "data_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "D0",
              "D1",
              "D2",
              "D3",
              "D4"
            ]
          }
        },
        "publication_visibilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "private",
              "restricted",
              "embargoed",
              "public"
            ]
          }
        },
        "resource_ceiling_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "policy_profile_ref": {
          "$ref": "#/$defs/versioned_reference"
        },
        "forbidden_actions": {
          "$ref": "#/$defs/nonempty_unique_strings"
        }
      }
    },
    "decision_mode": {
      "enum": [
        "human_discretionary",
        "mechanical_within_preauthorized_policy"
      ]
    },
    "delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "maximum_depth",
        "child_scope_rule"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "maximum_depth": {
          "type": "integer",
          "minimum": 0
        },
        "child_scope_rule": {
          "enum": [
            "none",
            "strict_subset"
          ]
        }
      }
    },
    "separation_constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "cannot_verify_own_output",
          "cannot_settle_own_outcome",
          "cannot_publish_own_output",
          "cannot_rotate_self_alone",
          "distinct_safety_execution_for_r3_r4"
        ]
      }
    },
    "temporal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_at",
        "review_at",
        "expires_at"
      ],
      "properties": {
        "effective_at": {
          "$ref": "#/$defs/timestamp"
        },
        "review_at": {
          "$ref": "#/$defs/timestamp"
        },
        "expires_at": {
          "oneOf": [
            {
              "$ref": "#/$defs/timestamp"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "revocation_route_ref": {
      "$ref": "#/$defs/versioned_reference"
    },
    "decision_evidence": {
      "$ref": "#/$defs/artifact_reference"
    },
    "signed_by": {
      "$ref": "#/$defs/human_principal"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "assignment_kind": {
            "const": "initial"
          }
        },
        "required": [
          "assignment_kind"
        ]
      },
      "then": {
        "properties": {
          "source": {
            "properties": {
              "root_declaration_id": {
                "$ref": "#/$defs/identifier"
              },
              "issuer_assignment_ref": {
                "type": "null"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "source": {
            "properties": {
              "root_declaration_id": {
                "type": "null"
              },
              "issuer_assignment_ref": {
                "$ref": "#/$defs/immutable_reference"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assignee": {
            "properties": {
              "principal_type": {
                "const": "deterministic_service"
              }
            },
            "required": [
              "principal_type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "decision_mode": {
            "const": "mechanical_within_preauthorized_policy"
          },
          "scope": {
            "properties": {
              "maximum_risk_tier": {
                "enum": [
                  "R0",
                  "R1"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation": {
            "properties": {
              "allowed": {
                "const": false
              }
            },
            "required": [
              "allowed"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "delegation": {
            "properties": {
              "maximum_depth": {
                "const": 0
              },
              "child_scope_rule": {
                "const": "none"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "delegation": {
            "properties": {
              "maximum_depth": {
                "minimum": 1
              },
              "child_scope_rule": {
                "const": "strict_subset"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "role": {
      "enum": [
        "proposal",
        "protocol",
        "safety",
        "data_rights",
        "resource",
        "execution",
        "verification",
        "outcome",
        "publication"
      ]
    },
    "principal_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type",
        "authentication_binding_ref",
        "accountable_human_ref"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "enum": [
            "human",
            "organization",
            "deterministic_service"
          ]
        },
        "authentication_binding_ref": {
          "$ref": "#/$defs/digest"
        },
        "accountable_human_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "principal_type": {
                "enum": [
                  "organization",
                  "deterministic_service"
                ]
              }
            },
            "required": [
              "principal_type"
            ]
          },
          "then": {
            "properties": {
              "accountable_human_ref": {
                "$ref": "#/$defs/identifier"
              }
            }
          },
          "else": {
            "properties": {
              "accountable_human_ref": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "human_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "principal_type"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/identifier"
        },
        "principal_type": {
          "const": "human"
        }
      }
    },
    "immutable_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "versioned_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "canonical_object_digest",
            "domain_resolution": "target_resolved_via_sibling_reference",
            "algorithm": "sha-256",
            "profile": "urn:odeya:canonicalization:odeya-jcs-0.1",
            "status": "target_resolved_domain"
          }
        }
      }
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest",
          "x-odeya-digest-scope": {
            "kind": "byte_digest",
            "subject": "exact retained artifact or profile document bytes",
            "algorithm": "sha-256",
            "profile": "not_a_canonical_object_digest",
            "status": "accepted_disposition_annotation"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nonempty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
