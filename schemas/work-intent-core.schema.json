{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:work-intent-core:0.1.0",
  "title": "Odeya WorkIntent Semantic Core Candidate",
  "description": "Identity-free semantic subject for a prospective non-authoritative WorkIntent. The core contains no canonicalization-profile binding, canonical self-digest, registry admission, assignment, lease, grant, reservation, materialization, dispatch, spend, or external-effect authority. Exact core bytes are bound only by separate architecture evidence while the canonical profile and transitive WorkIntent/WorkLease/WorkContract reissue remain blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_status",
    "record_authority_status",
    "work_intent_id",
    "version",
    "mission_id",
    "stage_id",
    "branch_id",
    "source_view_ref",
    "planning_epoch_ref",
    "objective",
    "permitted_deliverable_classes",
    "candidate_worker_requirements",
    "data_boundary",
    "estimated_limits",
    "output_contract",
    "assignment_boundary",
    "prospective_authority_boundary",
    "canonical_collection_ordering",
    "created_at",
    "created_by"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "record_status": { "const": "proposed_non_authoritative" },
    "record_authority_status": { "const": "not_admitted_not_assignable" },
    "work_intent_id": { "$ref": "#/$defs/work_intent_core_identifier" },
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "mission_id": { "$ref": "#/$defs/work_intent_core_identifier" },
    "stage_id": { "$ref": "#/$defs/work_intent_core_identifier" },
    "branch_id": { "$ref": "#/$defs/work_intent_core_identifier" },
    "source_view_ref": {
      "$ref": "#/$defs/work_intent_core_source_view_reference"
    },
    "planning_epoch_ref": {
      "$ref": "#/$defs/work_intent_core_planning_epoch_reference"
    },
    "objective": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "permitted_deliverable_classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/work_intent_core_identifier" }
    },
    "candidate_worker_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_classes",
        "execution_modes",
        "selection_status",
        "worker_principal_ref"
      ],
      "properties": {
        "capability_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/work_intent_core_identifier" }
        },
        "execution_modes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "local_isolated_worker",
              "governed_external_processing"
            ]
          }
        },
        "selection_status": { "const": "unassigned" },
        "worker_principal_ref": { "type": "null" }
      }
    },
    "data_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "maximum_data_classes",
        "allowed_residencies",
        "maximum_egress",
        "data_use_status",
        "active_data_use_decision_refs"
      ],
      "properties": {
        "purpose": { "$ref": "#/$defs/work_intent_core_identifier" },
        "maximum_data_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "public",
              "internal",
              "confidential",
              "restricted_allowed"
            ]
          }
        },
        "allowed_residencies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/work_intent_core_identifier" }
        },
        "maximum_egress": {
          "enum": ["none", "bounded_provider", "approved_region_only"]
        },
        "data_use_status": { "const": "unresolved_until_assignment" },
        "active_data_use_decision_refs": { "type": "array", "maxItems": 0 }
      }
    },
    "estimated_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimate_status",
        "wall_time_seconds",
        "model_input_tokens",
        "model_output_tokens",
        "network_egress_bytes",
        "spend_minor_units",
        "currency"
      ],
      "properties": {
        "estimate_status": { "const": "planning_estimate_not_reservation" },
        "wall_time_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "model_input_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "model_output_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "network_egress_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "spend_minor_units": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_ref",
        "candidate_artifact_required",
        "claim_authority",
        "publication_authority"
      ],
      "properties": {
        "schema_ref": {
          "$ref": "#/$defs/work_intent_core_output_schema_reference"
        },
        "candidate_artifact_required": { "const": true },
        "claim_authority": { "const": false },
        "publication_authority": { "const": false }
      }
    },
    "assignment_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_command_type",
        "intent_reference_required_in_command",
        "atomic_commit_required",
        "prerequisites_to_resolve_at_assignment",
        "work_contract_materialization",
        "dispatch_claim_required_after_work_contract"
      ],
      "properties": {
        "required_command_type": { "const": "verification.assign" },
        "intent_reference_required_in_command": { "const": true },
        "atomic_commit_required": { "const": true },
        "prerequisites_to_resolve_at_assignment": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "prefixItems": [
            { "const": "work_intent_canonical_identity" },
            { "const": "worker_principal" },
            { "const": "active_work_lease" },
            { "const": "authority_grants" },
            { "const": "active_data_use_decisions" },
            { "const": "sandbox_capability" },
            { "const": "resource_reservation" },
            { "const": "passing_state_compilation_bundle" }
          ],
          "items": false
        },
        "work_contract_materialization": {
          "const": "post_assignment_commit_derived"
        },
        "dispatch_claim_required_after_work_contract": { "const": true }
      }
    },
    "prospective_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_lease_required_at_intent",
        "active_lease_ref",
        "authority_grant_refs",
        "resource_reservation_required_at_intent",
        "resource_reservation_ref",
        "dispatch_authority_granted",
        "dispatch_admission_ref",
        "materialization_authority_granted",
        "external_effect_authority_granted",
        "bytes_may_cross_at_intent",
        "provider_spend_may_incur_at_intent"
      ],
      "properties": {
        "active_lease_required_at_intent": { "const": false },
        "active_lease_ref": { "type": "null" },
        "authority_grant_refs": { "type": "array", "maxItems": 0 },
        "resource_reservation_required_at_intent": { "const": false },
        "resource_reservation_ref": { "type": "null" },
        "dispatch_authority_granted": { "const": false },
        "dispatch_admission_ref": { "type": "null" },
        "materialization_authority_granted": { "const": false },
        "external_effect_authority_granted": { "const": false },
        "bytes_may_cross_at_intent": { "const": false },
        "provider_spend_may_incur_at_intent": { "const": false }
      }
    },
    "canonical_collection_ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "set_like_string_arrays",
        "reference_arrays",
        "fixed_semantic_sequences",
        "unordered_input_disposition"
      ],
      "properties": {
        "set_like_string_arrays": {
          "const": "unicode_codepoint_ascending"
        },
        "reference_arrays": {
          "const": "id_then_version_then_digest_ascending"
        },
        "fixed_semantic_sequences": {
          "const": "schema_declared_prefix_order"
        },
        "unordered_input_disposition": { "const": "reject_before_identity" }
      }
    },
    "created_at": { "$ref": "#/$defs/work_intent_core_timestamp" },
    "created_by": { "$ref": "#/$defs/work_intent_core_principal" }
  },
  "$defs": {
    "work_intent_core_identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]+$"
    },
    "work_intent_core_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "work_intent_core_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "work_intent_core_source_view_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/work_intent_core_identifier" },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "digest": {
          "$ref": "#/$defs/work_intent_core_digest",
          "x-odeya-digest-scope": {
            "kind": "legacy_canonical_object_reference_digest",
            "subject": "referenced_research_state_view",
            "profile": "legacy_reference_does_not_embed_profile",
            "schema": "legacy_reference_does_not_embed_schema_id",
            "algorithm": "sha-256",
            "status": "requires_profile_bound_reference_reissue_before_admission"
          }
        }
      }
    },
    "work_intent_core_planning_epoch_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/work_intent_core_identifier" },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "digest": {
          "$ref": "#/$defs/work_intent_core_digest",
          "x-odeya-digest-scope": {
            "kind": "legacy_canonical_object_reference_digest",
            "subject": "referenced_planning_epoch",
            "profile": "legacy_reference_does_not_embed_profile",
            "schema": "legacy_reference_does_not_embed_schema_id",
            "algorithm": "sha-256",
            "status": "requires_profile_bound_reference_reissue_before_admission"
          }
        }
      }
    },
    "work_intent_core_output_schema_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {
        "id": { "$ref": "#/$defs/work_intent_core_identifier" },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "digest": {
          "$ref": "#/$defs/work_intent_core_digest",
          "x-odeya-digest-scope": {
            "kind": "schema_resource_raw_digest",
            "subject": "referenced_output_schema_raw_bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "legacy_reference_uses_id_and_version_components",
            "algorithm": "sha-256",
            "status": "requires_exact_schema_id_and_raw_digest_reissue_before_admission"
          }
        }
      }
    },
    "work_intent_core_principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "principal_type"],
      "properties": {
        "principal_id": { "$ref": "#/$defs/work_intent_core_identifier" },
        "principal_type": { "enum": ["human", "service", "model_run"] }
      }
    }
  }
}
