{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:projection-impact-record:0.3.0",
  "title": "Odeya ProjectionImpactRecord",
  "description": "A deterministic, derived and non-authoritative dependency/fanout computation for correction, invalidation, retraction, rights, deletion, recovery, effect, or release facts. It records affected logical projections and fail-closed transitions without authorizing a pointer, cache, deletion, release, or recovery action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_status",
    "impact_id",
    "version",
    "projection_family",
    "trigger",
    "source_binding",
    "dependency_index_ref",
    "selection",
    "fanout_protocol",
    "monotonicity",
    "controlled_time",
    "construction",
    "authority_semantics"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "record_status": {
      "const": "derived_non_authoritative_impact_computation"
    },
    "impact_id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "projection_family": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "projection_types",
        "successor_projection_content_digest_included"
      ],
      "properties": {
        "family_id": {
          "$ref": "#/$defs/identifier"
        },
        "projection_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "private_cockpit",
              "thesis_intake",
              "public_research",
              "static_architecture_fixture"
            ]
          }
        },
        "successor_projection_content_digest_included": {
          "const": false
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "fact_ref",
        "ledger_position",
        "affected_scope_ref",
        "deletion_retention_disposition"
      ],
      "properties": {
        "kind": {
          "enum": [
            "correction",
            "invalidation",
            "retraction",
            "rights_change",
            "deletion",
            "recovery",
            "external_effect_change",
            "release_change"
          ]
        },
        "fact_ref": {
          "$ref": "#/$defs/exact_record_reference"
        },
        "ledger_position": {
          "$ref": "#/$defs/ledger_point"
        },
        "affected_scope_ref": {
          "$ref": "#/$defs/artifact_reference"
        },
        "deletion_retention_disposition": {
          "enum": [
            "not_applicable",
            "current_policy_allows_retention",
            "minimum_noncontent_tombstone_only"
          ]
        }
      }
    },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_contract_root_ref",
        "c0_registry_bundle_ref",
        "canonicalization_profile_ref",
        "checkpoint_ref",
        "checkpoint_ledger_position",
        "witness_status"
      ],
      "properties": {
        "engine_contract_root_ref": {
          "$ref": "#/$defs/engine_contract_root_reference"
        },
        "c0_registry_bundle_ref": {
          "$ref": "#/$defs/c0_registry_bundle_reference"
        },
        "canonicalization_profile_ref": {
          "$ref": "#/$defs/versioned_reference"
        },
        "checkpoint_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_record_reference"
            },
            {
              "properties": {
                "record_type": {
                  "const": "ledger_checkpoint"
                },
                "version": {
                  "const": "0.2.0"
                },
                "schema_id": {
                  "const": "urn:odeya:schema:ledger-checkpoint:0.4.0"
                }
              }
            }
          ]
        },
        "checkpoint_ledger_position": {
          "$ref": "#/$defs/ledger_point"
        },
        "witness_status": {
          "const": "acknowledged"
        }
      }
    },
    "dependency_index_ref": {
      "$ref": "#/$defs/exact_record_reference"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_rule_ref",
        "candidate_projection_count",
        "affected_projection_count",
        "unaffected_projection_count",
        "affected",
        "unaffected",
        "omitted_candidate_count",
        "coverage_evidence_ref"
      ],
      "properties": {
        "selection_rule_ref": {
          "$ref": "#/$defs/versioned_reference"
        },
        "candidate_projection_count": {
          "type": "integer",
          "minimum": 0
        },
        "affected_projection_count": {
          "type": "integer",
          "minimum": 0
        },
        "unaffected_projection_count": {
          "type": "integer",
          "minimum": 0
        },
        "affected": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/affected_projection"
          }
        },
        "unaffected": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/unaffected_projection"
          }
        },
        "omitted_candidate_count": {
          "const": 0
        },
        "coverage_evidence_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "fanout_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_phases",
        "fail_closed_before_rebuild",
        "current_pointer_advance_requires_equivalence",
        "cache_invalidation_precedes_current_serve"
      ],
      "properties": {
        "ordered_phases": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {
              "const": "observe_invalidating_fact"
            },
            {
              "const": "mark_affected_noncurrent"
            },
            {
              "const": "invalidate_cache_and_pointer_lease"
            },
            {
              "const": "rebuild_under_current_policy_and_reader"
            },
            {
              "const": "independently_compare_where_required"
            },
            {
              "const": "atomically_advance_pointer_if_eligible"
            }
          ],
          "items": false
        },
        "fail_closed_before_rebuild": {
          "const": true
        },
        "current_pointer_advance_requires_equivalence": {
          "const": true
        },
        "cache_invalidation_precedes_current_serve": {
          "const": true
        }
      }
    },
    "monotonicity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_set_may_shrink_without_new_evidence",
        "new_dependency_may_remove_existing_affected_member",
        "correction_or_rights_fact_may_be_silently_ignored",
        "restored_snapshot_may_reopen_before_current_frontier",
        "proof_ref"
      ],
      "properties": {
        "affected_set_may_shrink_without_new_evidence": {
          "const": false
        },
        "new_dependency_may_remove_existing_affected_member": {
          "const": false
        },
        "correction_or_rights_fact_may_be_silently_ignored": {
          "const": false
        },
        "restored_snapshot_may_reopen_before_current_frontier": {
          "const": false
        },
        "proof_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "controlled_time": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "computed_at",
        "clock_profile_ref"
      ],
      "properties": {
        "computed_at": {
          "$ref": "#/$defs/timestamp"
        },
        "clock_profile_ref": {
          "$ref": "#/$defs/versioned_reference"
        }
      }
    },
    "construction": {
      "$ref": "#/$defs/non_recursive_construction"
    },
    "authority_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_is_authority",
        "record_is_canonical_state",
        "record_is_publication_decision",
        "record_executes_cache_pointer_or_deletion_action"
      ],
      "properties": {
        "record_is_authority": {
          "const": false
        },
        "record_is_canonical_state": {
          "const": false
        },
        "record_is_publication_decision": {
          "const": false
        },
        "record_executes_cache_pointer_or_deletion_action": {
          "const": false
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "trigger": {
            "properties": {
              "kind": {
                "const": "deletion"
              },
              "deletion_retention_disposition": {
                "const": "minimum_noncontent_tombstone_only"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "selection": {
            "properties": {
              "affected": {
                "items": {
                  "properties": {
                    "retention_action": {
                      "const": "destroy_prior_bytes_keep_minimum_noncontent_tombstone"
                    },
                    "prior_projection_bytes_retained": {
                      "const": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trigger": {
            "properties": {
              "kind": {
                "not": {
                  "const": "deletion"
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "trigger": {
            "properties": {
              "deletion_retention_disposition": {
                "const": "not_applicable"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{6}Z$"
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "digest",
        "media_type"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "media_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 127
        }
      }
    },
    "versioned_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "canonicalization_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "version",
        "digest"
      ],
      "properties": {
        "profile_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "exact_record_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "record_id",
        "version",
        "schema_id",
        "canonicalization_profile",
        "canonical_digest"
      ],
      "properties": {
        "record_type": {
          "$ref": "#/$defs/identifier"
        },
        "record_id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/semantic_version"
        },
        "schema_id": {
          "type": "string",
          "format": "uri"
        },
        "canonicalization_profile": {
          "$ref": "#/$defs/canonicalization_binding"
        },
        "canonical_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "engine_contract_root_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/exact_record_reference"
        },
        {
          "properties": {
            "record_type": {
              "const": "engine_contract_root"
            },
            "version": {
              "const": "0.1.0"
            },
            "schema_id": {
              "const": "urn:odeya:schema:engine-contract-root:0.2.0"
            }
          }
        }
      ]
    },
    "c0_registry_bundle_reference": {
      "allOf": [
        {
          "$ref": "#/$defs/exact_record_reference"
        },
        {
          "properties": {
            "record_type": {
              "const": "c0_registry_bundle"
            },
            "version": {
              "const": "0.1.0"
            },
            "schema_id": {
              "const": "urn:odeya:schema:c0-registry-bundle:0.2.0"
            }
          }
        }
      ]
    },
    "ledger_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_epoch",
        "stream_id",
        "inclusive_global_position",
        "aggregate_id",
        "aggregate_version"
      ],
      "properties": {
        "ledger_epoch": {
          "$ref": "#/$defs/identifier"
        },
        "stream_id": {
          "$ref": "#/$defs/identifier"
        },
        "inclusive_global_position": {
          "type": "integer",
          "minimum": 0
        },
        "aggregate_id": {
          "$ref": "#/$defs/identifier"
        },
        "aggregate_version": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "affected_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "projection_version",
        "projection_type",
        "dependency_paths",
        "reason_codes",
        "mark_state_before_rebuild",
        "mark_before_rebuild_required",
        "cache_invalidation_required",
        "pointer_lease_revocation_required",
        "rebuild_required",
        "independent_equivalence_required",
        "atomic_pointer_advance_only_after_pass",
        "public_notice_or_fail_closed_required",
        "retention_action",
        "prior_projection_bytes_retained",
        "minimum_tombstone_ref"
      ],
      "properties": {
        "projection_id": {
          "$ref": "#/$defs/identifier"
        },
        "projection_version": {
          "type": "integer",
          "minimum": 1
        },
        "projection_type": {
          "enum": [
            "private_cockpit",
            "thesis_intake",
            "public_research",
            "static_architecture_fixture"
          ]
        },
        "dependency_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^/"
          }
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "correction_pending",
              "invalidated",
              "retracted",
              "rights_changed",
              "deletion_pending",
              "restore_unverified",
              "effect_ambiguous",
              "release_changed"
            ]
          }
        },
        "mark_state_before_rebuild": {
          "enum": [
            "stale",
            "quarantined",
            "unavailable"
          ]
        },
        "mark_before_rebuild_required": {
          "const": true
        },
        "cache_invalidation_required": {
          "const": true
        },
        "pointer_lease_revocation_required": {
          "const": true
        },
        "rebuild_required": {
          "const": true
        },
        "independent_equivalence_required": {
          "const": true
        },
        "atomic_pointer_advance_only_after_pass": {
          "const": true
        },
        "public_notice_or_fail_closed_required": {
          "const": true
        },
        "retention_action": {
          "enum": [
            "retain_if_current_policy_allows",
            "destroy_prior_bytes_keep_minimum_noncontent_tombstone"
          ]
        },
        "prior_projection_bytes_retained": {
          "type": "boolean"
        },
        "minimum_tombstone_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "unaffected_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "projection_version",
        "projection_type",
        "non_dependency_evidence_ref"
      ],
      "properties": {
        "projection_id": {
          "$ref": "#/$defs/identifier"
        },
        "projection_version": {
          "type": "integer",
          "minimum": 1
        },
        "projection_type": {
          "enum": [
            "private_cockpit",
            "thesis_intake",
            "public_research",
            "static_architecture_fixture"
          ]
        },
        "non_dependency_evidence_ref": {
          "$ref": "#/$defs/artifact_reference"
        }
      }
    },
    "non_recursive_construction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_digest_issued_externally_after_validation",
        "self_digest_included",
        "successor_projection_content_digest_included",
        "mutual_content_digest_cycle_allowed"
      ],
      "properties": {
        "canonical_digest_issued_externally_after_validation": {
          "const": true
        },
        "self_digest_included": {
          "const": false
        },
        "successor_projection_content_digest_included": {
          "const": false
        },
        "mutual_content_digest_cycle_allowed": {
          "const": false
        }
      }
    }
  }
}
