{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:odeya:schema:canonical-work-lease:0.11.0",
  "title": "Odeya Profile-Bound CanonicalWorkLease Successor Candidate",
  "description": "Side-by-side immutable successor wrapper for canonical WorkLease 0.1. It retains the exact fail-closed lease record and externally binds its legacy WorkIntent reference to the present WorkIntent 0.2 successor resource. The WorkIntent canonical identity, profile issuance, assignment cohort, lease record identity, reducer, registry admission, and activation remain absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_class",
    "candidate_status",
    "canonicalization_profile_ref",
    "identity_subject",
    "canonical_digest",
    "canonical_identity_status",
    "registry_member_ref",
    "admission_ref",
    "operator_acceptance_ref",
    "authority_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "0.11.0"
    },
    "artifact_class": {
      "const": "canonical_work_lease_profile_bound_successor_candidate"
    },
    "candidate_status": {
      "const": "successor_materialized_work_intent_successor_bound_identity_unissued"
    },
    "canonicalization_profile_ref": {
      "$ref": "#/$defs/work_lease_successor_profile_ref"
    },
    "identity_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predecessor_binding",
        "lease_record",
        "work_intent_successor_binding"
      ],
      "properties": {
        "predecessor_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_path",
            "schema_id",
            "schema_raw_digest",
            "schema_bytes",
            "fixture_path",
            "fixture_raw_digest",
            "fixture_bytes"
          ],
          "properties": {
            "schema_path": {
              "const": "schemas/canonical-work-lease.schema.json"
            },
            "schema_id": {
              "const": "urn:odeya:schema:canonical-work-lease:0.6.0"
            },
            "schema_raw_digest": {
              "const": "sha256:7ed8e18d12a448be4c7ea884342d57fc95a2c1c32e1eb23bd73bd02b64f8e8fd",
              "x-odeya-digest-scope": {
                "kind": "raw_schema_resource_digest",
                "subject": "schemas/canonical-work-lease.schema.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:canonical-work-lease:0.6.0",
                "algorithm": "sha-256",
                "status": "immutable_predecessor_binding"
              }
            },
            "schema_bytes": {
              "const": 23087
            },
            "fixture_path": {
              "const": "tests/architecture-schema/fixtures/canonical-work-lease-acquired.valid.json"
            },
            "fixture_raw_digest": {
              "const": "sha256:52343c540e62a6c182c48c5552bd747e19bf144ec70014c7f4a14019dc6c6518",
              "x-odeya-digest-scope": {
                "kind": "raw_fixture_digest",
                "subject": "canonical-work-lease-acquired.valid.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:canonical-work-lease:0.6.0",
                "algorithm": "sha-256",
                "status": "architecture_fixture_binding"
              }
            },
            "fixture_bytes": {
              "const": 3802
            }
          }
        },
        "lease_record": {
          "$ref": "urn:odeya:schema:canonical-work-lease:0.6.0"
        },
        "work_intent_successor_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lease_record_pointer",
            "legacy_work_intent_schema_id",
            "legacy_object_id",
            "legacy_version",
            "legacy_digest",
            "successor_work_intent_schema_id",
            "successor_work_intent_schema_raw_digest",
            "successor_work_intent_schema_bytes",
            "successor_candidate_raw_digest",
            "successor_candidate_bytes",
            "successor_canonical_digest",
            "binding_status",
            "admission_ref"
          ],
          "properties": {
            "lease_record_pointer": {
              "const": "/work_intent_ref"
            },
            "legacy_work_intent_schema_id": {
              "const": "urn:odeya:schema:work-intent:0.6.0"
            },
            "legacy_object_id": {
              "$ref": "#/$defs/work_lease_successor_identifier"
            },
            "legacy_version": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "legacy_digest": {
              "$ref": "#/$defs/work_lease_successor_digest",
              "x-odeya-digest-scope": {
                "kind": "legacy_candidate_canonical_object_reference_digest",
                "subject": "WorkIntent reference retained inside WorkLease 0.1 subject",
                "profile": "legacy reference does not embed profile",
                "schema": "urn:odeya:schema:work-intent:0.6.0",
                "algorithm": "sha-256",
                "status": "synthetic_architecture_value_not_admitted"
              }
            },
            "successor_work_intent_schema_id": {
              "const": "urn:odeya:schema:work-intent:0.15.0"
            },
            "successor_work_intent_schema_raw_digest": {
              "const": "sha256:2074352b5910076a7bc240e49f374b152c83a584e0f83acf5fd2035ed9709835",
              "x-odeya-digest-scope": {
                "kind": "raw_schema_resource_digest",
                "subject": "schemas/work-intent-profile-bound-candidate.schema.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-intent:0.15.0",
                "algorithm": "sha-256",
                "status": "exact_successor_schema_binding"
              }
            },
            "successor_work_intent_schema_bytes": {
              "const": 13915
            },
            "successor_candidate_raw_digest": {
              "const": "sha256:b750eb3c6772bff052f7b02d9bd079f853f6c24afe1d3ea4e84245fd5ed19618",
              "x-odeya-digest-scope": {
                "kind": "raw_file_digest",
                "subject": "architecture/work-intent-profile-bound-candidate.json raw bytes",
                "profile": "not_a_canonical_object_digest",
                "schema": "urn:odeya:schema:work-intent:0.15.0",
                "algorithm": "sha-256",
                "status": "successor_candidate_bootstrap_binding"
              }
            },
            "successor_candidate_bytes": {
              "const": 8657
            },
            "successor_canonical_digest": {
              "type": "null",
              "x-odeya-digest-scope": {
                "kind": "canonical_object_digest",
                "subject": "WorkIntent 0.2 identity subject",
                "profile": "urn:odeya:canonicalization:odeya-jcs-0.1 unissued",
                "schema": "urn:odeya:schema:work-intent:0.15.0",
                "algorithm": "sha-256",
                "status": "not_constructible"
              }
            },
            "binding_status": {
              "const": "successor_present_identity_unissued_equality_unproven"
            },
            "admission_ref": {
              "type": "null"
            }
          }
        }
      }
    },
    "canonical_digest": {
      "type": "null",
      "x-odeya-digest-scope": {
        "kind": "canonical_object_digest",
        "subject": "identity_subject under canonical-work-lease:0.2.0 envelope",
        "profile": "urn:odeya:canonicalization:odeya-jcs-0.1 unissued",
        "schema": "urn:odeya:schema:canonical-work-lease:0.11.0",
        "algorithm": "sha-256",
        "status": "not_constructible_until_profile_work_intent_assignment_member_reducer_and_admission"
      }
    },
    "canonical_identity_status": {
      "const": "not_constructible_work_intent_successor_identity_unissued"
    },
    "registry_member_ref": {
      "type": "null"
    },
    "admission_ref": {
      "type": "null"
    },
    "operator_acceptance_ref": {
      "type": "null"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_lease_admitted",
        "lease_state_is_execution_authority",
        "assignment_authorized",
        "start_claim_authorized",
        "dispatch_authorized",
        "runtime_authorized",
        "deployment_authorized",
        "external_effects_authorized"
      ],
      "properties": {
        "work_lease_admitted": {
          "const": false
        },
        "lease_state_is_execution_authority": {
          "const": false
        },
        "assignment_authorized": {
          "const": false
        },
        "start_claim_authorized": {
          "const": false
        },
        "dispatch_authorized": {
          "const": false
        },
        "runtime_authorized": {
          "const": false
        },
        "deployment_authorized": {
          "const": false
        },
        "external_effects_authorized": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "work_lease_successor_identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._:-]+$"
    },
    "work_lease_successor_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "work_lease_successor_profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "profile_core_schema_id",
        "profile_core_raw_digest"
      ],
      "properties": {
        "profile_id": {
          "const": "urn:odeya:canonicalization:odeya-jcs-0.1"
        },
        "profile_version": {
          "const": "0.1.0"
        },
        "profile_core_schema_id": {
          "const": "urn:odeya:schema:canonicalization-profile-core:0.3.0"
        },
        "profile_core_raw_digest": {
          "const": "sha256:c8909c88bfbeb0252fd6b29e62420df30b8c05dc26a9872d4f9f630035b2a4d8",
          "x-odeya-digest-scope": {
            "kind": "raw_file_digest",
            "subject": "architecture/canonicalization-profile-core-candidate.json raw bytes",
            "profile": "not_a_canonical_object_digest",
            "schema": "urn:odeya:schema:canonicalization-profile-core:0.3.0",
            "algorithm": "sha-256",
            "status": "candidate_profile_unissued"
          }
        }
      }
    }
  }
}
