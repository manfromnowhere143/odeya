{
  "name": "@odeya/repository-release-tooling",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "description": "Pinned architecture-only tooling for validating Odeya's repository release surface.",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "lint:markdown": "markdownlint-cli2 --config ../../.markdownlint-cli2.jsonc ../../README.md ../../docs/REPOSITORY_RELEASE.md ../../.github/SECURITY.md",
    "render:readme": "bash ../../scripts/ci/render-readme-architecture.sh"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "11.16.0",
    "markdownlint-cli2": "0.23.0",
    "puppeteer": "25.3.0"
  }
}
